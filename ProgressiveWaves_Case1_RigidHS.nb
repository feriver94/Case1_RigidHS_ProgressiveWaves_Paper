(* ---- Figure 1013: T vs H/V (all dispersive) ---- *)
Print[\"\\nFig 1013: T vs H/V + U/csL (all dispersive, combined dual-axis)\"];

Quiet[
Module[{allTHV, allTU, allTUsc,
        tLo = 0.2, tHi = 15, hvLo = 0, hvHi = 30,
        uLo = -1, uHi = 6, scaleU, rightTicks},
  
  scaleU[u_] := hvLo + (u - uLo)/(uHi - uLo) * (hvHi - hvLo);
  rightTicks = Table[{scaleU[v], v}, {v, 0, uHi, 1}];
  
  allTHV = Select[
    Transpose[{dispData[[All, 8]], dispData[[All, 7]]}],
    #[[1]] > 0 && tLo < #[[1]] < tHi && 0 < #[[2]] < hvHi &];
  allTU = Select[
    Transpose[{dispData[[All, 8]], Re[dispData[[All, 6]]]}],
    #[[1]] > 0 && tLo < #[[1]] < tHi && uLo <= #[[2]] <= uHi &];
  allTUsc = If[Length[allTU] > 0, {#[[1]], scaleU[#[[2]]]} & /@ allTU, \
{{-1,-1}}];
  
  If[Length[allTHV] == 0, allTHV = {{1, 1}}];
  
  fig1013 = ListLogLinearPlot[{allTHV, allTUsc},
    PlotStyle -> {
      Directive[retroC, AbsolutePointSize[2]],
      Directive[RGBColor[0.12, 0.47, 0.71], AbsolutePointSize[2], \
Opacity[0.5]]},
    PlotRange -> {{tLo, tHi}, {hvLo, hvHi}},
    Frame -> True,
    FrameStyle -> Directive[Black, AbsoluteThickness[1.5], 13],
    FrameTicksStyle -> Directive[Black, 11],
    FrameTicks -> {{Automatic, rightTicks}, {Automatic, None}},
    FrameLabel -> {
      {Style[\"H/V Ratio\", 14, Bold], Style[\"Group Velocity, U/csL\", 14, \
Bold]},
      {Style[\"T (dimensionless period)\", 14, Bold], None}},
    Epilog -> resonanceEpilog[hvLo, hvHi, \"loglin\"],
    GridLines -> Automatic,
    GridLinesStyle -> Directive[GrayLevel[0.85], AbsoluteThickness[0.5]],
    PlotLabel -> Style[
      \"Ellipticity & Group Velocity\\n\" <> titleStr, 10],
    PlotLegends -> Placed[
      PointLegend[{retroC, RGBColor[0.12, 0.47, 0.71]},
        {Style[\"H/V\", 10], Style[\"U/csL\", 10]},
        LegendMarkerSize -> 8], {Right, Top}],
    ImageSize -> 750,
    ImagePadding -> {{70, 80}, {55, 65}},
    Background -> White,
    AspectRatio -> 0.6
  ];
];
];
showFig[fig1013];



(* ---- Figure 1014: T vs H/V + U/csL (retro/pro, combined dual-axis) ---- *)
Print[\"\\nFig 1014: T vs H/V + U/csL (retrograde/prograde, combined \
dual-axis)\"];

Quiet[
Module[{rTHV, pTHV, rTU, pTU, rTUsc, pTUsc,
        tLo = 0.2, tHi = 15, hvLo = 0, hvHi = 30,
        uLo = -1, uHi = 6, scaleU, rightTicks},
  
  scaleU[u_] := hvLo + (u - uLo)/(uHi - uLo) * (hvHi - hvLo);
  rightTicks = Table[{scaleU[v], v}, {v, 0, uHi, 1}];
  
  rTHV = If[nRetro > 0,
    Select[Transpose[{retroData[[All, 6]], retroData[[All, 5]]}],
           tLo < #[[1]] < tHi && 0 < #[[2]] < hvHi &], {{-1, -1}}];
  pTHV = If[nPro > 0,
    Select[Transpose[{proData[[All, 6]], proData[[All, 5]]}],
           tLo < #[[1]] < tHi && 0 < #[[2]] < hvHi &], {{-1, -1}}];
  rTU = If[nRetro > 0,
    Select[Transpose[{retroData[[All, 6]], Re[retroData[[All, 4]]]}],
           tLo < #[[1]] < tHi && uLo <= #[[2]] <= uHi &], {{-1, -1}}];
  pTU = If[nPro > 0,
    Select[Transpose[{proData[[All, 6]], Re[proData[[All, 4]]]}],
           tLo < #[[1]] < tHi && uLo <= #[[2]] <= uHi &], {{-1, -1}}];
  
  rTUsc = If[Length[rTU] > 0 && rTU =!= {{-1, -1}},
    {#[[1]], scaleU[#[[2]]]} & /@ rTU, {{-1, -1}}];
  pTUsc = If[Length[pTU] > 0 && pTU =!= {{-1, -1}},
    {#[[1]], scaleU[#[[2]]]} & /@ pTU, {{-1, -1}}];
  
  fig1014 = ListLogLinearPlot[{rTHV, pTHV, rTUsc, pTUsc},
    PlotStyle -> {
      Directive[Black, AbsolutePointSize[2.5]],
      Directive[Red, AbsolutePointSize[2.5]],
      Directive[RGBColor[0.12, 0.47, 0.71], AbsolutePointSize[2], \
Opacity[0.45]],
      Directive[RGBColor[0.55, 0.0, 0.55], AbsolutePointSize[2], \
Opacity[0.45]]},
    PlotRange -> {{tLo, tHi}, {hvLo, hvHi}},
    Frame -> True,
    FrameStyle -> Directive[Black, AbsoluteThickness[1.5], 13],
    FrameTicksStyle -> Directive[Black, 11],
    FrameTicks -> {{Automatic, rightTicks}, {Automatic, None}},
    FrameLabel -> {
      {Style[\"H/V Ratio\", 14, Bold], Style[\"Group Velocity, U/csL\", 14, \
Bold]},
      {Style[\"T (dimensionless period)\", 14, Bold], None}},
    Epilog -> resonanceEpilog[hvLo, hvHi, \"loglin\"],
    GridLines -> Automatic,
    GridLinesStyle -> Directive[GrayLevel[0.85], AbsoluteThickness[0.5]],
    PlotLabel -> Style[
      \"Ellipticity & Group Velocity by Motion Type\\n\" <> titleStr <> 
      \"\\nT_s = \" <> ToString[NumberForm[Ts, {4, 2}]] <>
      \", T_p = \" <> ToString[NumberForm[Tp, {4, 2}]], 10],
    PlotLegends -> Placed[
      PointLegend[
        {Black, Red, Directive[RGBColor[0.12, 0.47, 0.71], Opacity[0.45]],
         Directive[RGBColor[0.55, 0.0, 0.55], Opacity[0.45]]},
        {Style[\"Retro H/V\", 10], Style[\"Pro H/V\", 10],
         Style[\"Retro U/csL\", 10], Style[\"Pro U/csL\", 10]},
        LegendMarkerSize -> 8, LegendLayout -> \"Column\"],
      {Right, Top}],
    ImageSize -> 750,
    ImagePadding -> {{70, 80}, {55, 65}},
    Background -> White,
    AspectRatio -> 0.6
  ];
];
];
showFig[fig1014];



(* ---- Figure 1015: Determinant residual diagnostic ---- *)
Print[\"\\nFig 1015: Determinant residual\"];

Quiet[
Module[{resPts, reRes, imRes},
  reRes = Table[
    Module[{f = detEval[dispData[[k, 1]], dispData[[k, 2]]]},
      {dispData[[k, 2]], Abs[f[[1]]] + 1.0*^-20}
    ], {k, Min[nDisp, 5000]}];
  imRes = Table[
    Module[{f = detEval[dispData[[k, 1]], dispData[[k, 2]]]},
      {dispData[[k, 2]], Abs[f[[2]]] + 1.0*^-20}
    ], {k, Min[nDisp, 5000]}];
  
  fig1015 = ListLogPlot[{reRes, imRes},
    PlotStyle -> {
      Directive[retroC, AbsolutePointSize[2], Opacity[0.5]],
      Directive[proC, AbsolutePointSize[2], Opacity[0.5]]},
    PlotRange -> {{0, 8}, All},
    FrameLabel -> {Style[\"kh\", 14, Bold], Style[\"|det|\", 14, Bold]},
    PlotLabel -> Style[\"Residual Diagnostic\\n\" <> titleStr, 10],
    PlotLegends -> Placed[
      PointLegend[{retroC, proC}, 
        {Style[\"|Re[det]|\", 10], Style[\"|Im[det]|\", 10]},
        LegendMarkerSize -> 8], {Right, Top}],
    commonOpts
  ];
];
];
showFig[fig1015];



(* ---- Figure 1016: T vs c/csL and U/csL (matching MATLAB fig 1013) ---- *)
(* This shows phase velocity dispersion: c \[Rule] \[Infinity] at          *)
(* quarter-wavelength resonance periods T_s, T_p                           *)
Print[\"\\nFig 1016: T vs c/csL & U/csL (phase + group velocity dispersion)\"];

Quiet[
Module[{rCT, pCT, rUT, pUT, tLo = 0.2, tHi = 15, yLo = -2, yHi = 6},
  rCT = If[nRetro > 0,
    Select[Transpose[{retroData[[All, 6]], retroData[[All, 3]]}],
           #[[1]] > tLo && #[[1]] < tHi && NumericQ[#[[2]]] &], {{tLo, 0}}];
  pCT = If[nPro > 0,
    Select[Transpose[{proData[[All, 6]], proData[[All, 3]]}],
           #[[1]] > tLo && #[[1]] < tHi && NumericQ[#[[2]]] &], {{tLo, 0}}];
  rUT = If[nRetro > 0,
    Select[Transpose[{retroData[[All, 6]], Re[retroData[[All, 4]]]}],
           #[[1]] > tLo && #[[1]] < tHi && NumericQ[#[[2]]] &], {{tLo, 0}}];
  pUT = If[nPro > 0,
    Select[Transpose[{proData[[All, 6]], Re[proData[[All, 4]]]}],
           #[[1]] > tLo && #[[1]] < tHi && NumericQ[#[[2]]] &], {{tLo, 0}}];
  
  fig1016 = ListLogLinearPlot[{rCT, pCT, rUT, pUT},
    PlotStyle -> {
      Directive[retroC, AbsolutePointSize[2]],
      Directive[proC, AbsolutePointSize[2]],
      Directive[RGBColor[0, 0.6, 0], AbsolutePointSize[2.5], Opacity[0.6]],
      Directive[RGBColor[0.8, 0, 0.8], AbsolutePointSize[2.5], Opacity[0.6]]},
    PlotRange -> {{tLo, tHi}, {yLo, yHi}},
    Frame -> True,
    FrameStyle -> Directive[Black, AbsoluteThickness[1.5], 13],
    FrameTicksStyle -> Directive[Black, 11],
    FrameLabel -> {Style[\"T (dimensionless period)\", 14, Bold], 
      Style[\"c/csL, U/csL\", 14, Bold]},
    PlotLabel -> Style[
      \"Phase & Group Velocity Dispersion\\n\" <> titleStr <> 
      \"\\nResonance: T_s=\" <> ToString[NumberForm[Ts, {4, 2}]] <>
      \", T_p=\" <> ToString[NumberForm[Tp, {4, 2}]], 10],
    Epilog -> {
      resonanceEpilog[yLo, yHi, \"loglin\"],
      (* c/csL = 1 reference *)
,
      (* cpL/csL reference *)
      {GrayLevel[0.5], Dotted, AbsoluteThickness[1],
       Line[{{Log[tLo], cpL/csL}, {Log[tHi], cpL/csL}}],
       Text[Style[\"c = cpL\", 8, GrayLevel[0.4]], {Log[tHi*0.9], cpL/csL}, \
{1, -1.5}]}
    },
    GridLines -> Automatic,
    GridLinesStyle -> Directive[GrayLevel[0.85], AbsoluteThickness[0.5]],
    PlotLegends -> Placed[
      PointLegend[{retroC, proC, RGBColor[0, 0.6, 0], RGBColor[0.8, 0, 0.8]},
        {Style[\"Retro c/csL\", 10], Style[\"Pro c/csL\", 10],
         Style[\"Retro U/csL\", 10], Style[\"Pro U/csL\", 10]},
        LegendMarkerSize -> 8, LegendLayout -> \"Column\"],
      {Right, Top}],
    ImageSize -> 750,
    ImagePadding -> {{65, 80}, {55, 65}},
    Background -> White,
    AspectRatio -> 0.6
  ];
];
];
showFig[fig1016];



(* ---- Figure 1017: Combined T vs H/V + U/csL (THE ) ---- *)
(* Dual-axis: H/V ratio (left), Group velocity U/csL (right)         *)
(* Period on x-axis (semilog) with resonance reference lines          *)
(* This figure shows whether U_min coincides with H/V_max at T_s     *)
Print[\"\\nFig 1017: Combined T vs H/V + U/csL \"];

Quiet[
Module[{rTHV, pTHV, rTU, pTU, rTUsc, pTUsc,
        tLo = 0.2, tHi = 15, hvLo = 0, hvHi = 30, 
        uLo = -1, uHi = 6, scaleU, rightTicks},
  
  scaleU[u_] := hvLo + (u - uLo)/(uHi - uLo) * (hvHi - hvLo);
  rightTicks = Table[{scaleU[v], v}, {v, 0, uHi, 1}];
  
  rTHV = If[nRetro > 0,
    Select[Transpose[{retroData[[All, 6]], retroData[[All, 5]]}],
           tLo < #[[1]] < tHi && 0 < #[[2]] < hvHi &], {{-1, -1}}];
  pTHV = If[nPro > 0,
    Select[Transpose[{proData[[All, 6]], proData[[All, 5]]}],
           tLo < #[[1]] < tHi && 0 < #[[2]] < hvHi &], {{-1, -1}}];
  
  rTU = If[nRetro > 0,
    Select[Transpose[{retroData[[All, 6]], Re[retroData[[All, 4]]]}],
           tLo < #[[1]] < tHi && uLo <= #[[2]] <= uHi &], {{-1, -1}}];
  pTU = If[nPro > 0,
    Select[Transpose[{proData[[All, 6]], Re[proData[[All, 4]]]}],
           tLo < #[[1]] < tHi && uLo <= #[[2]] <= uHi &], {{-1, -1}}];
  
  rTUsc = If[Length[rTU] > 0 && rTU =!= {{-1, -1}}, 
    {#[[1]], scaleU[#[[2]]]} & /@ rTU, {{-1, -1}}];
  pTUsc = If[Length[pTU] > 0 && pTU =!= {{-1, -1}}, 
    {#[[1]], scaleU[#[[2]]]} & /@ pTU, {{-1, -1}}];
  
  fig1017 = ListLogLinearPlot[{rTHV, pTHV, rTUsc, pTUsc},
    PlotStyle -> {
      Directive[Black, AbsolutePointSize[2.5]],
      Directive[Red, AbsolutePointSize[2.5]],
      Directive[RGBColor[0.12, 0.47, 0.71], AbsolutePointSize[2], \
Opacity[0.45]],
      Directive[RGBColor[0.55, 0.0, 0.55], AbsolutePointSize[2], \
Opacity[0.45]]},
    PlotRange -> {{tLo, tHi}, {hvLo, hvHi}},
    Frame -> True,
    FrameStyle -> Directive[Black, AbsoluteThickness[1.5], 13],
    FrameTicksStyle -> Directive[Black, 11],
    FrameTicks -> {{Automatic, rightTicks}, {Automatic, None}},
    FrameLabel -> {
      {Style[\"H/V Ratio\", 14, Bold], 
       Style[\"Group Velocity, U/csL\", 14, Bold]},
      {Style[\"T (dimensionless period)\", 14, Bold], None}},
    Epilog -> {
      resonanceEpilog[hvLo, hvHi, \"loglin\"],
      (* U = 1 (csL) reference *)
      
    },
    GridLines -> Automatic,
    GridLinesStyle -> Directive[GrayLevel[0.85], AbsoluteThickness[0.5]],
    PlotLabel -> Style[
      \"H/V & Group Velocity vs Period \\n\" <>
      titleStr <> \"\\nT_s = \" <> ToString[NumberForm[Ts, {4, 2}]] <> 
      \", T_p = \" <> ToString[NumberForm[Tp, {4, 2}]], 11],
    PlotLegends -> Placed[
      PointLegend[
        {Black, Red, Directive[RGBColor[0.12, 0.47, 0.71], Opacity[0.45]], 
         Directive[RGBColor[0.55, 0.0, 0.55], Opacity[0.45]]}, 
        {Style[\"Retro H/V\", 10], Style[\"Pro H/V\", 10],
         Style[\"Retro U/csL\", 10], Style[\"Pro U/csL\", 10]},
        LegendMarkerSize -> 8, LegendLayout -> \"Column\"],
      {Right, Top}],
    ImageSize -> 750,
    ImagePadding -> {{70, 80}, {55, 55}},
    Background -> White,
    AspectRatio -> 0.6
  ];
];
];
showFig[fig1017];


\
\>", "Input",ExpressionUUID->"febdb633-694c-4741-91d3-e316601f3398"],

Cell["\<\
(* ================================================================ *)


(* ---- Figure 1018: Combined T vs H/V + c/csL (phase velocity at H/V peaks) \
---- *)
(* This figure reveals: at quarter-wavelength resonance T_s,                  \
      *)
(* c \[Rule] \[Infinity] (mode cutoff) AND H/V peaks. The phase velocity      \
    *)
(* divergence is the physical cause of the H/V maximum.                       \
      *)
Print[\"\\nFig 1018: Combined T vs H/V + c/csL (phase velocity at H/V \
peaks)\"];

Quiet[
Module[{rTHV, pTHV, rTc, pTc, rTcSc, pTcSc,
        tLo = 0.2, tHi = 15, hvLo = 0, hvHi = 30, 
        cLo = 0, cHi = 30, scaleC, rightTicks},
  
  scaleC[cv_] := hvLo + (cv - cLo)/(cHi - cLo) * (hvHi - hvLo);
  rightTicks = Table[{scaleC[v], v}, {v, 0, cHi, 5}];
  
  rTHV = If[nRetro > 0,
    Select[Transpose[{retroData[[All, 6]], retroData[[All, 5]]}],
           tLo < #[[1]] < tHi && 0 < #[[2]] < hvHi &], {{-1, -1}}];
  pTHV = If[nPro > 0,
    Select[Transpose[{proData[[All, 6]], proData[[All, 5]]}],
           tLo < #[[1]] < tHi && 0 < #[[2]] < hvHi &], {{-1, -1}}];
  
  rTc = If[nRetro > 0,
    Select[Transpose[{retroData[[All, 6]], retroData[[All, 3]]}],
           tLo < #[[1]] < tHi && cLo <= #[[2]] <= cHi &], {{-1, -1}}];
  pTc = If[nPro > 0,
    Select[Transpose[{proData[[All, 6]], proData[[All, 3]]}],
           tLo < #[[1]] < tHi && cLo <= #[[2]] <= cHi &], {{-1, -1}}];
  
  rTcSc = If[Length[rTc] > 0 && rTc =!= {{-1, -1}}, {#[[1]], scaleC[#[[2]]]} \
& /@ rTc, {{-1, -1}}];
  pTcSc = If[Length[pTc] > 0 && pTc =!= {{-1, -1}}, {#[[1]], scaleC[#[[2]]]} \
& /@ pTc, {{-1, -1}}];
  
  fig1018 = ListLogLinearPlot[{rTHV, pTHV, rTcSc, pTcSc},
    PlotStyle -> {
      Directive[retroC, AbsolutePointSize[2]],
      Directive[proC, AbsolutePointSize[2]],
      Directive[RGBColor[0, 0.6, 0], AbsolutePointSize[2.5], Opacity[0.5]],
      Directive[RGBColor[0.8, 0, 0.8], AbsolutePointSize[2.5], Opacity[0.5]]},
    PlotRange -> {{tLo, tHi}, {hvLo, hvHi}},
    Frame -> True,
    FrameStyle -> Directive[Black, AbsoluteThickness[1.5], 13],
    FrameTicksStyle -> Directive[Black, 11],
    FrameTicks -> {{Automatic, rightTicks}, {Automatic, None}},
    FrameLabel -> {
      {Style[\"H/V Ratio\", 14, Bold], Style[\"Phase Velocity, c/csL\", 14, \
Bold]},
      {Style[\"T (dimensionless period)\", 14, Bold], None}},
    PlotLabel -> Style[
      \"Phase Velocity at H/V Maxima\\n\" <> titleStr <>
      \"\\nT_s=4h/csL=\" <> ToString[NumberForm[Ts, {4, 2}]] <>
      \", T_p=4h/cpL=\" <> ToString[NumberForm[Tp, {4, 2}]], 10],
    Epilog -> {
      resonanceEpilog[hvLo, hvHi, \"loglin\"],

      {GrayLevel[0.5], Dotted, AbsoluteThickness[1],
       Line[{{Log[tLo], scaleC[1]}, {Log[tHi], scaleC[1]}}],
       Text[Style[\"c = csL\", 8, GrayLevel[0.4]], {Log[tHi*0.9], scaleC[1]}, \
{1, -1.5}]}
    },
    GridLines -> Automatic,
    GridLinesStyle -> Directive[GrayLevel[0.85], AbsoluteThickness[0.5]],
    PlotLegends -> Placed[
      PointLegend[{retroC, proC, RGBColor[0, 0.6, 0], RGBColor[0.8, 0, 0.8]},
        {Style[\"Retro H/V\", 10], Style[\"Pro H/V\", 10],
         Style[\"Retro c/csL\", 10], Style[\"Pro c/csL\", 10]},
        LegendMarkerSize -> 8, LegendLayout -> \"Column\"],
      {Right, Top}],
    ImageSize -> 750,
    ImagePadding -> {{70, 80}, {55, 65}},
    Background -> White,
    AspectRatio -> 0.6
  ];
];
];
showFig[fig1018];
\
\>", "Input",ExpressionUUID->"ca2c6a05-b579-4240-ac84-9cd034111e65"],

Cell["\<\
(* 13. PHASE 2: DIMENSIONAL FORMULATION                              *)
(*     Physical units: c (m/s), f (Hz), T (s), U (m/s)              *)
(*     Combined group velocity + ellipticity plots                   *)
(* ================================================================ *)

Print[\"\\n================================================================\"];
Print[\"  Phase 2: Dimensional Formulation\"];
Print[\"================================================================\\n\"];

(* ---- WHAT YOU CAN CHANGE HERE ----                               *)
(* \[Rho]LDim : Layer mass density in kg/m^3 (default 1800)        *)
(* VsLDim    : Layer shear-wave velocity in m/s (default 200)       *)
(* hDim      : Layer thickness in m (default 10)                    *)
(* These control the BASELINE dimensional figures only.             *)
(* The parametric study (Section 18) uses its own sweep values.     *)
(* ---------------------------------------------------------------- *)

(* Physical properties *)
\[Rho]LDim = 1800.0;
VsLDim    = 200.0;
VpLDim    = VsLDim * (cpL/csL);
VsHDim    = Infinity;  (* Rigid halfspace *)
VpHDim    = Infinity;  (* Rigid halfspace *)
\[Rho]HDim = \[Rho]LDim * (\[Rho]H/\[Rho]L);

hDim = 30;   (* m \[AHat]\.80\.94 dimensional baseline *)

(* Dimensional resonance frequencies and periods *)
fsDim = VsLDim / (4*hDim);     (* S-wave fundamental frequency, Hz *)
fpDim = VpLDim / (4*hDim);     (* P-wave fundamental frequency, Hz *)
TsDim = 1/fsDim;               (* S-wave fundamental period, s *)
TpDim = 1/fpDim;               (* P-wave fundamental period, s *)

Print[\"\\n  DIMENSIONAL RESONANCE:\"];
Print[\"    S-wave: f_s = Vs/(4h) = \", NumberForm[fsDim, {5, 2}], \" Hz\"];
Print[\"            T_s = 4h/Vs  = \", NumberForm[TsDim, {5, 4}], \" s\"];
Print[\"    P-wave: f_p = Vp/(4h) = \", NumberForm[fpDim, {5, 2}], \" Hz\"];
Print[\"            T_p = 4h/Vp  = \", NumberForm[TpDim, {5, 4}], \" s\"];
Print[\"    S-wave harmonics: f = \", NumberForm[fsDim, {4, 1}], \", \", 
      NumberForm[3*fsDim, {4, 1}], \", \", NumberForm[5*fsDim, {4, 1}], \" Hz\
\"];

Print[\"  Layer:  Vs = \", NumberForm[VsLDim, {5, 1}], \" m/s\",
      \"  Vp = \", NumberForm[VpLDim, {6, 1}], \" m/s\",
      \"  \[Rho] = \", \[Rho]LDim, \" kg/m^3\"];
Print[\"  Rock:   VsH = \", \"\[Infinity]\", \" m/s\",
      \"  VpH = \", \"\[Infinity]\", \" m/s\",
      \"  \[Rho]H = \", NumberForm[\[Rho]HDim, {5, 0}], \" kg/m^3\"];
Print[\"  h = \", hDim, \" m\"];
Print[\"\"];

(* ---- Dimensional Properties Summary Table ---- *)
Print[Style[\"  DIMENSIONAL PROPERTIES\", Bold, 14]];
Print[Grid[{
    {Style[\"Property\", Bold], Style[\"Layer\", Bold], Style[\"Halfspace\", \
Bold]},
    {\"Vs (m/s)\", NumberForm[VsLDim, {5, 1}], \"\[Infinity]\"},
    {\"Vp (m/s)\", NumberForm[VpLDim, {6, 1}], \"\[Infinity]\"},
    {\"\[Rho] (kg/m^3)\", NumberForm[\[Rho]LDim, {5, 0}], 
     NumberForm[\[Rho]HDim, {5, 0}]},
    {\"\[Nu]\", NumberForm[\[Nu]L, {4, 3}], 
     NumberForm[(\[Lambda]H/(2*(\[Lambda]H + \[Mu]H))), {4, 3}]},
    {\"h (m)\", hDim, \"\[Infinity]\"},
    {\"Vs ratio (H/L)\", \"\", NumberForm[Infinity, {4, 2}]}
  },
  Frame -> All, Alignment -> Left, Spacings -> {2, 0.8},
  Background -> {{LightBlue, None, None}, {LightGray, None}}
]];
Print[\"\"];

(* Dimensional conversion utilities:                                 *)
(*   c (m/s)  = VsLDim * (c/csL)                                    *)
(*   f (Hz)   = VsLDim * ksh / (2\[Pi] h)                           *)
(*   T (s)    = 2\[Pi] h / (VsLDim * ksh)                           *)
(*   U (m/s)  = VsLDim * (U/csL)                                    *)



(* Comprehensive title string for all dimensional figures *)
dimTitleStr = \"h = \" <> ToString[hDim] <> \" m, Vs = \" <> \
ToString[Round[VsLDim]] <> \" m/s\\n\" <>
  \"\[Nu]L=\" <> ToString[\[Nu]L] <>
  \", \[Lambda]L=\" <> ToString[NumberForm[\[Lambda]L, {5, 1}]] <>
  \", \[Mu]L=\" <> ToString[\[Mu]L] <>
  \", \[Rho]L=\" <> ToString[\[Rho]L] <>
  \"\\nRigid halfspace\" <>
  \"\\ncsL=\" <> ToString[NumberForm[csL, {4, 2}]] <>
  \", cpL=\" <> ToString[NumberForm[cpL, {4, 2}]];




(* ---- Dim Figure 2: Frequency vs c (m/s), range 0.1\[Dash]20 Hz ---- *)
Print[\"\\nDim Fig 2: Frequency (0.1\[Dash]20 Hz) vs c (m/s)\"];

figDim2 = Quiet[Module[{rPts, pPts, sPts, fRange = {0.1, 20}},
  rPts = If[nRetro > 0, 
    Select[
      Transpose[{VsLDim*retroDataF[[All, 1]]/(2*Pi*hDim), \
VsLDim*retroDataF[[All, 3]]}],
      fRange[[1]] <= #[[1]] <= fRange[[2]] &], {{-1, -1}}];
  pPts = If[nPro > 0,   
    Select[
      Transpose[{VsLDim*proDataF[[All, 1]]/(2*Pi*hDim), VsLDim*proDataF[[All, \
3]]}],
      fRange[[1]] <= #[[1]] <= fRange[[2]] &], {{-1, -1}}];
  sPts = If[nShear > 0, 
    Select[
      Transpose[{VsLDim*shearData[[All, 1]]/(2*Pi*hDim), \
VsLDim*shearData[[All, 3]]}],
      fRange[[1]] <= #[[1]] <= fRange[[2]] &], {{-1, -1}}];
  
  ListPlot[{rPts, pPts, sPts},
    PlotStyle -> {
      Directive[retroC, AbsolutePointSize[2.5]],
      Directive[proC, AbsolutePointSize[2.5]],
      Directive[shearC, AbsolutePointSize[2.5]]},
    PlotRange -> {{fRange[[1]], fRange[[2]]}, {0, Automatic}},
    Epilog -> {
      {Dashed, AbsoluteThickness[2], RGBColor[0.0, 0.5, 0.0],
       Line[{{fRange[[1]], VsLDim}, {fRange[[2]], VsLDim}}],
       Text[Style[\"Vs\", 9, Bold, RGBColor[0.0, 0.5, 0.0]], \
{fRange[[2]]*0.9, VsLDim}, {0, -1.5}]},
      {Dashed, AbsoluteThickness[2], RGBColor[0.85, 0.45, 0],
       Line[{{fRange[[1]], VpLDim}, {fRange[[2]], VpLDim}}],
       Text[Style[\"Vp\", 9, Bold, RGBColor[0.85, 0.45, 0]], \
{fRange[[2]]*0.9, VpLDim}, {0, -1.5}]}
    },
    FrameLabel -> {Style[\"Frequency, f (Hz)\", 14, Bold], 
      Style[\"Phase Velocity, c (m/s)\", 14, Bold]},
    PlotLabel -> Style[\"Dimensional Phase Velocity Dispersion\\n\" <> \
dimTitleStr, 9],
    PlotLegends -> Placed[
      PointLegend[{retroC, proC, shearC}, 
        {Style[\"Retrograde\", 10], Style[\"Prograde\", 10],
         Style[\"Shear wave\", 10]},
        LegendMarkerSize -> 8, LegendLayout -> \"Column\"],
      {Right, Top}],
    commonOpts
  ]
]];
showFig[figDim2];



(* ---- Dim Figure 3: Frequency vs Group Velocity U (m/s) ---- *)
Print[\"\\nDim Fig 3: Frequency (0.1\[Dash]20 Hz) vs U (m/s)\"];

figDim3 = Quiet[Module[{rPts, pPts, fRange = {0.1, 20}},
  rPts = If[Length[retroDataF] > 0, 
    Select[
      Transpose[{VsLDim*retroDataF[[All, 1]]/(2*Pi*hDim), \
VsLDim*retroDataF[[All, 4]]}],
      fRange[[1]] <= #[[1]] <= fRange[[2]] &], {{-1, -1}}];
  pPts = If[Length[proDataF] > 0,   
    Select[
      Transpose[{VsLDim*proDataF[[All, 1]]/(2*Pi*hDim), VsLDim*proDataF[[All, \
4]]}],
      fRange[[1]] <= #[[1]] <= fRange[[2]] &], {{-1, -1}}];
  
  ListPlot[{rPts, pPts},
    PlotStyle -> {
      Directive[retroC, AbsolutePointSize[2.5]],
      Directive[proC, AbsolutePointSize[2.5]]},
    PlotRange -> {{fRange[[1]], fRange[[2]]}, {Automatic, Automatic}},
    FrameLabel -> {Style[\"Frequency, f (Hz)\", 14, Bold], 
      Style[\"Group Velocity, U (m/s)\", 14, Bold]},
    PlotLabel -> Style[\"Dimensional Group Velocity Dispersion\\n\" <> \
dimTitleStr, 9],
    PlotLegends -> Placed[
      PointLegend[{retroC, proC}, 
        {Style[\"Retrograde\", 10], Style[\"Prograde\", 10]},
        LegendMarkerSize -> 8], {Right, Top}],
    commonOpts
  ]
]];
showFig[figDim3];



(* ---- Dim Figure 4: Period vs H/V (retro/pro), 0.1\[Dash]20 s ---- *)
Print[\"\\nDim Fig 4: Period (0.1\[Dash]20 s) vs H/V + U (combined dual-axis)\
\"];

figDim4 = Quiet[Module[{rTHV, pTHV, rTU, pTU, rTUsc, pTUsc,
    tRange = {0.05, 20}, hvRange = {0, 30}, uRange = {0, 500},
    scaleU, rightTicks},
  
  scaleU[u_] := hvRange[[1]] + (u - uRange[[1]])/(uRange[[2]] - uRange[[1]]) \
* (hvRange[[2]] - hvRange[[1]]);
  rightTicks = Table[{scaleU[v], v}, {v, 0, uRange[[2]], 100}];
  
  rTHV = If[nRetro > 0,
    Select[Transpose[{2*Pi*hDim/(VsLDim*retroData[[All, 1]]), retroData[[All, \
5]]}],
      tRange[[1]] <= #[[1]] <= tRange[[2]] && 0 < #[[2]] < hvRange[[2]] &], \
{{-1, -1}}];
  pTHV = If[nPro > 0,
    Select[Transpose[{2*Pi*hDim/(VsLDim*proData[[All, 1]]), proData[[All, \
5]]}],
      tRange[[1]] <= #[[1]] <= tRange[[2]] && 0 < #[[2]] < hvRange[[2]] &], \
{{-1, -1}}];
  rTU = If[nRetro > 0,
    Select[Transpose[{2*Pi*hDim/(VsLDim*retroData[[All, 1]]), \
VsLDim*retroData[[All, 4]]}],
      tRange[[1]] <= #[[1]] <= tRange[[2]] && uRange[[1]] <= #[[2]] <= \
uRange[[2]] &], {{-1, -1}}];
  pTU = If[nPro > 0,
    Select[Transpose[{2*Pi*hDim/(VsLDim*proData[[All, 1]]), \
VsLDim*proData[[All, 4]]}],
      tRange[[1]] <= #[[1]] <= tRange[[2]] && uRange[[1]] <= #[[2]] <= \
uRange[[2]] &], {{-1, -1}}];
  
  rTUsc = If[Length[rTU] > 0 && rTU =!= {{-1, -1}}, {#[[1]], scaleU[#[[2]]]} \
& /@ rTU, {{-1, -1}}];
  pTUsc = If[Length[pTU] > 0 && pTU =!= {{-1, -1}}, {#[[1]], scaleU[#[[2]]]} \
& /@ pTU, {{-1, -1}}];
  
  ListLogLinearPlot[{rTHV, pTHV, rTUsc, pTUsc},
    PlotStyle -> {
      Directive[Black, AbsolutePointSize[2.5]],
      Directive[RGBColor[0.84, 0.15, 0.16], AbsolutePointSize[2.5]],
      Directive[RGBColor[0.12, 0.47, 0.71], AbsolutePointSize[2], \
Opacity[0.45]],
      Directive[RGBColor[0.55, 0, 0.55], AbsolutePointSize[2], Opacity[0.45]]},
    PlotRange -> {{tRange[[1]], tRange[[2]]}, hvRange},
    Frame -> True,
    FrameStyle -> Directive[Black, AbsoluteThickness[1.5], 13],
    FrameTicksStyle -> Directive[Black, 11],
    FrameTicks -> {{Automatic, rightTicks}, {Automatic, None}},
    FrameLabel -> {{Style[\"H/V Ratio\", 14, Bold], Style[\"Group Velocity, U \
(m/s)\", 14, Bold]},
      {Style[\"Period, T (s)\", 14, Bold], None}},
    Epilog -> Module[{sC = Darker[Green, 0.3], pC = RGBColor[0.85, 0.45, 0]},
      {(* S-wave fundamental: solid green *)
       {sC, AbsoluteThickness[2.5],
        Line[{{Log[TsDim], hvRange[[1]]}, {Log[TsDim], hvRange[[2]]}}],
        Text[Style[\"S-fund\\nTs=\" <> ToString[NumberForm[TsDim, {4, 3}]] <> \
\"s\",
             8, sC, Bold], {Log[TsDim], hvRange[[2]]*0.9}, {0, 0}]},
       (* P-wave fundamental: dashed orange *)
       {pC, AbsoluteThickness[2.5], Dashed,
        Line[{{Log[TpDim], hvRange[[1]]}, {Log[TpDim], hvRange[[2]]}}],
        Text[Style[\"P-fund\\nTp=\" <> ToString[NumberForm[TpDim, {4, 3}]] <> \
\"s\",
             8, pC, Bold], {Log[TpDim], hvRange[[2]]*0.7}, {0, 0}]}
      }],
    GridLines -> Automatic,
    GridLinesStyle -> Directive[GrayLevel[0.85], AbsoluteThickness[0.5]],
    PlotLabel -> Style[\"Dimensional H/V & Group Velocity vs Period\\n\" <> \
dimTitleStr <>
      \"\\nTs=\" <> ToString[NumberForm[TsDim, {4, 3}]] <> \" s, \" <>
      \"Tp=\" <> ToString[NumberForm[TpDim, {4, 3}]] <> \" s\", 9],
    PlotLegends -> Placed[PointLegend[
      {Black, RGBColor[0.84, 0.15, 0.16], Directive[RGBColor[0.12, 0.47, \
0.71], Opacity[0.45]],
       Directive[RGBColor[0.55, 0, 0.55], Opacity[0.45]]},
      {Style[\"Retro H/V\", 10], Style[\"Pro H/V\", 10], Style[\"Retro U\", \
10], Style[\"Pro U\", 10]},
      LegendMarkerSize -> 8, LegendLayout -> \"Column\"], {Right, Top}],
    ImageSize -> 750, ImagePadding -> {{70, 80}, {55, 65}}, Background -> \
White, AspectRatio -> 0.6
  ]
]];
showFig[figDim4];


\
\>", "Input",ExpressionUUID->"1949f46e-826e-6f43-9a1b-49b91283e1c1"],

Cell["\<\
(* ================================================================ *)\
\>", "Input",ExpressionUUID->"2232fa9c-2413-6446-bce7-bdb3692eefdc"],

Cell["\<\
(* 14. COMBINED GROUP VELOCITY + ELLIPTICITY (Dimensional)           *)
(*     Dual-panel: top = U(m/s), bottom = H/V, both vs frequency    *)
(*     Showing fundamental, 1st, and 2nd modes                      *)
(* ================================================================ *)

Print[\"\\n================================================================\"];
Print[\"  Combined Group Velocity + Ellipticity (Dimensional)\"];
Print[\"================================================================\\n\"];

(* ---- Dim Figure 5: Combined H/V + U vs Frequency (single plot, dual axes) \
---- *)
(* Left y-axis: H/V ratio (primary)                                           \
   *)
(* Right y-axis: Group velocity U (m/s) (secondary, rescaled)                 \
   *)
Print[\"Dim Fig 5: Combined H/V + U vs Frequency (dual y-axis, 0.1\[Dash]20 \
Hz)\"];

figDim5 = Quiet[Module[
  {fRange = {0.1, 20}, hvRange = {0, 30}, uRange = {0, 500},
   rFHV, pFHV, rFU, pFU, rFUsc, pFUsc,
   scaleU, rightTicks, hvColor, uColor},
  
  (* Distinct colors: solid for H/V, dashed-feel via opacity for U *)
  hvColor = RGBColor[0.0, 0.0, 0.0];        (* black for H/V *)
  uColor  = RGBColor[0.12, 0.47, 0.71];     (* blue for U *)
  
  (* Build {freq, H/V} arrays \[LongDash] primary axis, plotted directly *)
  rFHV = If[nRetro > 0,
    Select[
      Transpose[{VsLDim*retroData[[All, 1]]/(2*Pi*hDim), retroData[[All, 5]]}],
      fRange[[1]] <= #[[1]] <= fRange[[2]] && 0 < #[[2]] < hvRange[[2]] &], \
{{-1, -1}}];
  pFHV = If[nPro > 0,
    Select[
      Transpose[{VsLDim*proData[[All, 1]]/(2*Pi*hDim), proData[[All, 5]]}],
      fRange[[1]] <= #[[1]] <= fRange[[2]] && 0 < #[[2]] < hvRange[[2]] &], \
{{-1, -1}}];
  
  (* Build {freq, U} arrays *)
  rFU = If[Length[retroDataF] > 0,
    Select[
      Transpose[{VsLDim*retroDataF[[All, 1]]/(2*Pi*hDim), 
                 VsLDim*retroDataF[[All, 4]]}],
      fRange[[1]] <= #[[1]] <= fRange[[2]] &], {{-1, -1}}];
  pFU = If[Length[proDataF] > 0,
    Select[
      Transpose[{VsLDim*proDataF[[All, 1]]/(2*Pi*hDim), 
                 VsLDim*proDataF[[All, 4]]}],
      fRange[[1]] <= #[[1]] <= fRange[[2]] &], {{-1, -1}}];
  
  (* Rescale U to fit on H/V axis coordinate space *)
  scaleU[u_] := hvRange[[1]] + (u - uRange[[1]])/(uRange[[2]] - uRange[[1]]) \
* (hvRange[[2]] - hvRange[[1]]);
  rFUsc = If[Length[rFU] > 0 && rFU =!= {{-1, -1}}, 
    {#[[1]], scaleU[#[[2]]]} & /@ rFU, {{-1, -1}}];
  pFUsc = If[Length[pFU] > 0 && pFU =!= {{-1, -1}}, 
    {#[[1]], scaleU[#[[2]]]} & /@ pFU, {{-1, -1}}];
  
  (* Right axis ticks: U values at corresponding H/V-scale positions *)
  rightTicks = Table[{scaleU[v], v}, {v, 0, uRange[[2]], 100}];
  
  ListPlot[{rFHV, pFHV, rFUsc, pFUsc},
    PlotStyle -> {
      Directive[hvColor, AbsolutePointSize[4]],
      Directive[RGBColor[0.84, 0.15, 0.16], AbsolutePointSize[4]],
      Directive[uColor, AbsolutePointSize[3.5], Opacity[0.45]],
      Directive[RGBColor[0.55, 0.0, 0.55], AbsolutePointSize[3.5], \
Opacity[0.45]]},
    PlotRange -> {{fRange[[1]], fRange[[2]]}, hvRange},
    Frame -> True,
    FrameStyle -> Directive[Black, AbsoluteThickness[1.5], 13],
    FrameTicksStyle -> Directive[Black, 11],
    FrameTicks -> {{Automatic, rightTicks}, {Automatic, None}},
    FrameLabel -> {
      {Style[\"H/V Ratio\", 14, Bold], 
       Style[\"Group Velocity, U (m/s)\", 14, Bold]},
      {Style[\"Frequency, f (Hz)\", 14, Bold], None}},
    Epilog -> {

      (* Fundamental frequency fs = cs/(4h) *)
      {Darker[Green, 0.3], AbsoluteThickness[2], Dashing[{0.015, 0.008}],
       Line[{{fsDim, hvRange[[1]]}, {fsDim, hvRange[[2]]}}]},
      {Darker[Green, 0.3],
       Text[Style[\"fs\", 9, Bold], {fsDim, hvRange[[2]]*0.95}, {-1.2, 0}]},
      (* 2fs *)
      {RGBColor[0.6, 0.3, 0.0], AbsoluteThickness[1.5], Dashing[{0.01, 0.008}],
       Line[{{2*fsDim, hvRange[[1]]}, {2*fsDim, hvRange[[2]]}}]},
      {RGBColor[0.6, 0.3, 0.0],
       Text[Style[\"2fs\", 8], {2*fsDim, hvRange[[2]]*0.88}, {-1.2, 0}]},
      (* 3fs *)
      {RGBColor[0.6, 0.3, 0.0], AbsoluteThickness[1.5], Dashing[{0.01, 0.008}],
       Line[{{3*fsDim, hvRange[[1]]}, {3*fsDim, hvRange[[2]]}}]},
      {RGBColor[0.6, 0.3, 0.0],
       Text[Style[\"3fs\", 8], {3*fsDim, hvRange[[2]]*0.88}, {-1.2, 0}]}
    },
    GridLines -> Automatic,
    GridLinesStyle -> Directive[GrayLevel[0.85], AbsoluteThickness[0.5]],
    PlotLabel -> Style[
      \"H/V & Group Velocity \[Dash] h = \" <> ToString[hDim] <> 
      \" m, VsL = \" <> ToString[Round[VsLDim]] <> \" m/s\" <>
      \", \[Nu]L = \" <> ToString[\[Nu]L] <>
      \", \[Lambda]L = \" <> ToString[NumberForm[\[Lambda]L, {5, 3}]], 11],
    PlotLegends -> Placed[
      PointLegend[
        {hvColor, RGBColor[0.84, 0.15, 0.16], 
         Directive[uColor, Opacity[0.45]], 
         Directive[RGBColor[0.55, 0.0, 0.55], Opacity[0.45]]}, 
        {Style[\"Retro H/V\", 10], Style[\"Pro H/V\", 10],
         Style[\"Retro U\", 10], Style[\"Pro U\", 10]},
        LegendMarkerSize -> 8, LegendLayout -> \"Column\"],
      {Right, Top}],
    ImageSize -> 750,
    ImagePadding -> {{70, 80}, {55, 55}},
    Background -> White,
    AspectRatio -> 0.6
  ]
]];
If[MatchQ[figDim5, _Graphics | _Legended], Print[figDim5]];



(* ---- Dim Figure 6: Combined H/V + U vs Period (single plot, dual axes) \
---- *)
(* Left y-axis: H/V ratio (primary)                                           \
 *)
(* Right y-axis: Group velocity U (m/s) (secondary, rescaled)                 \
 *)
Print[\"\\nDim Fig 6: Combined H/V + U vs Period (dual y-axis, 0.1\[Dash]20 \
s)\"];

figDim6 = Quiet[Module[
  {tRange = {0.1, 20}, hvRange = {0, 30}, uRange = {0, 500},
   rTHV, pTHV, rTU, pTU, rTUsc, pTUsc,
   scaleU, rightTicks, hvColor, uColor},
  
  hvColor = RGBColor[0.0, 0.0, 0.0];
  uColor  = RGBColor[0.12, 0.47, 0.71];
  
  (* Build {period, H/V} arrays \[LongDash] primary axis *)
  rTHV = If[nRetro > 0,
    Select[
      Transpose[{2*Pi*hDim/(VsLDim*retroData[[All, 1]]), retroData[[All, 5]]}],
      tRange[[1]] <= #[[1]] <= tRange[[2]] && 0 < #[[2]] < hvRange[[2]] &], \
{{-1, -1}}];
  pTHV = If[nPro > 0,
    Select[
      Transpose[{2*Pi*hDim/(VsLDim*proData[[All, 1]]), proData[[All, 5]]}],
      tRange[[1]] <= #[[1]] <= tRange[[2]] && 0 < #[[2]] < hvRange[[2]] &], \
{{-1, -1}}];
  
  (* Build {period, U} arrays \[AHat]\.80\.94 SAME unfiltered source as H/V *)
  rTU = If[nRetro > 0,
    Select[
      Transpose[{2*Pi*hDim/(VsLDim*retroData[[All, 1]]), 
                 VsLDim*retroData[[All, 4]]}],
      tRange[[1]] <= #[[1]] <= tRange[[2]] && 
      uRange[[1]] <= #[[2]] <= uRange[[2]] &], {{-1, -1}}];
  pTU = If[nPro > 0,
    Select[
      Transpose[{2*Pi*hDim/(VsLDim*proData[[All, 1]]), 
                 VsLDim*proData[[All, 4]]}],
      tRange[[1]] <= #[[1]] <= tRange[[2]] && 
      uRange[[1]] <= #[[2]] <= uRange[[2]] &], {{-1, -1}}];
  
  (* Rescale U to fit on H/V axis coordinate space *)
  scaleU[u_] := hvRange[[1]] + (u - uRange[[1]])/(uRange[[2]] - uRange[[1]]) \
* (hvRange[[2]] - hvRange[[1]]);
  rTUsc = If[Length[rTU] > 0 && rTU =!= {{-1, -1}}, 
    {#[[1]], scaleU[#[[2]]]} & /@ rTU, {{-1, -1}}];
  pTUsc = If[Length[pTU] > 0 && pTU =!= {{-1, -1}}, 
    {#[[1]], scaleU[#[[2]]]} & /@ pTU, {{-1, -1}}];
  
  rightTicks = Table[{scaleU[v], v}, {v, 0, uRange[[2]], 100}];
  
  ListPlot[{rTHV, pTHV, rTUsc, pTUsc},
    PlotStyle -> {
      Directive[hvColor, AbsolutePointSize[4]],
      Directive[RGBColor[0.84, 0.15, 0.16], AbsolutePointSize[4]],
      Directive[uColor, AbsolutePointSize[3.5], Opacity[0.45]],
      Directive[RGBColor[0.55, 0.0, 0.55], AbsolutePointSize[3.5], \
Opacity[0.45]]},
    PlotRange -> {{tRange[[1]], tRange[[2]]}, hvRange},
    Frame -> True,
    FrameStyle -> Directive[Black, AbsoluteThickness[1.5], 13],
    FrameTicksStyle -> Directive[Black, 11],
    FrameTicks -> {{Automatic, rightTicks}, {Automatic, None}},
    FrameLabel -> {
      {Style[\"H/V Ratio\", 14, Bold], 
       Style[\"Group Velocity, U (m/s)\", 14, Bold]},
      {Style[\"Period, T (s)\", 14, Bold], None}},

    Epilog -> {

      (* Fundamental period Ts = 4h/cs *)
      {Darker[Green, 0.3], AbsoluteThickness[2], Dashing[{0.015, 0.008}],
       Line[{{TsDim, hvRange[[1]]}, {TsDim, hvRange[[2]]}}]},
      {Darker[Green, 0.3],
       Text[Style[\"Ts\", 9, Bold], {TsDim, hvRange[[2]]*0.95}, {-1.2, 0}]},
      (* P-wave fundamental Tp = 4h/cp *)
      {RGBColor[0.85, 0.45, 0], AbsoluteThickness[1.5], Dashing[{0.01, 0.008}],
       Line[{{TpDim, hvRange[[1]]}, {TpDim, hvRange[[2]]}}]},
      {RGBColor[0.85, 0.45, 0],
       Text[Style[\"Tp\", 8], {TpDim, hvRange[[2]]*0.88}, {-1.2, 0}]}
    },
    GridLines -> Automatic,
    GridLinesStyle -> Directive[GrayLevel[0.85], AbsoluteThickness[0.5]],
    PlotLabel -> Style[
      \"H/V & Group Velocity vs Period \[Dash] h = \" <> ToString[hDim] <> 
      \" m, VsL = \" <> ToString[Round[VsLDim]] <> \" m/s\" <>
      \", \[Nu]L = \" <> ToString[\[Nu]L] <>
      \", \[Lambda]L = \" <> ToString[NumberForm[\[Lambda]L, {5, 3}]], 11],
    PlotLegends -> Placed[
      PointLegend[
        {hvColor, RGBColor[0.84, 0.15, 0.16], 
         Directive[uColor, Opacity[0.45]], 
         Directive[RGBColor[0.55, 0.0, 0.55], Opacity[0.45]]}, 
        {Style[\"Retro H/V\", 10], Style[\"Pro H/V\", 10],
         Style[\"Retro U\", 10], Style[\"Pro U\", 10]},
        LegendMarkerSize -> 8, LegendLayout -> \"Column\"],
      {Right, Top}],
    ImageSize -> 750,
    ImagePadding -> {{70, 80}, {55, 75}},
    Background -> White,
    AspectRatio -> 0.6
  ]
]];
showFig[figDim6];


\
\>", "Input",ExpressionUUID->"fd921b61-6940-7945-9ade-0b9587cb0092"],

Cell["\<\
(* ================================================================ *)\
\>", "Input",ExpressionUUID->"8f6314cc-967b-334b-8feb-c51ecf22a8cb"],

Cell["\<\
(* 14b. ZOOMED H/V & GROUP VELOCITY: T = 0.05 \[Dash] 0.10 s       *)
(*      Magnification of the short-period / high-frequency region   *)
(*      Disentangles modal branches for presentation clarity        *)
(* ================================================================ *)

Print[\"\\n================================================================\"];
Print[\"  Zoomed H/V + U vs Period: T = 0.05 \[Dash] 0.10 s\"];
Print[\"================================================================\\n\"];

figDim6Z = Quiet[Module[
  {tZoomLo = 0.03, tZoomHi = 0.15,
   hvRange = {0, 30}, uRange = {0, 500},
   rTHV, pTHV, rTU, pTU, rTUsc, pTUsc,
   scaleU, rightTicks, hvColor, uColor,
   rTHVall, pTHVall, rTUall, pTUall,
   hvMaxInWindow, uMaxInWindow, uMinInWindow,
   hvRangeZ, uRangeZ, uTickStep,
   nRetroInWindow, nProInWindow, xTicks},
  
  hvColor = RGBColor[0.0, 0.0, 0.0];
  uColor  = RGBColor[0.12, 0.47, 0.71];
  
  (* === Gather ALL data in the zoom window (no y-clipping) === *)
  rTHVall = If[nRetro > 0,
    Select[
      Transpose[{2*Pi*hDim/(VsLDim*retroData[[All, 1]]), retroData[[All, 5]]}],
      tZoomLo <= #[[1]] <= tZoomHi && #[[2]] > 0 &], {}];
  pTHVall = If[nPro > 0,
    Select[
      Transpose[{2*Pi*hDim/(VsLDim*proData[[All, 1]]), proData[[All, 5]]}],
      tZoomLo <= #[[1]] <= tZoomHi && #[[2]] > 0 &], {}];
  
  rTUall = If[Length[retroDataF] > 0,
    Select[
      Transpose[{2*Pi*hDim/(VsLDim*retroDataF[[All, 1]]), 
                 VsLDim*retroDataF[[All, 4]]}],
      tZoomLo <= #[[1]] <= tZoomHi &], {}];
  pTUall = If[Length[proDataF] > 0,
    Select[
      Transpose[{2*Pi*hDim/(VsLDim*proDataF[[All, 1]]), 
                 VsLDim*proDataF[[All, 4]]}],
      tZoomLo <= #[[1]] <= tZoomHi &], {}];
  
  nRetroInWindow = Length[rTHVall];
  nProInWindow = Length[pTHVall];
  Print[\"  Points in zoom window [\", tZoomLo, \", \", tZoomHi, \"] s:\"];
  Print[\"    Retro H/V: \", nRetroInWindow, \"  Pro H/V: \", nProInWindow];
  Print[\"    Retro U: \", Length[rTUall], \"  Pro U: \", Length[pTUall]];
  
  (* === Determine Y-axis ranges from actual data in window === *)
  hvMaxInWindow = Max[
    If[Length[rTHVall] > 0, Max[rTHVall[[All, 2]]], 1],
    If[Length[pTHVall] > 0, Max[pTHVall[[All, 2]]], 1]];
  hvRangeZ = {0, Max[15, Ceiling[hvMaxInWindow * 1.1]]};
  
  uMaxInWindow = Max[
    If[Length[rTUall] > 0, Max[rTUall[[All, 2]]], 200],
    If[Length[pTUall] > 0, Max[pTUall[[All, 2]]], 200]];
  uMinInWindow = Min[
    If[Length[rTUall] > 0, Min[rTUall[[All, 2]]], 0],
    If[Length[pTUall] > 0, Min[pTUall[[All, 2]]], 0]];
  uRangeZ = {Floor[uMinInWindow/50]*50 - 50,
             Ceiling[uMaxInWindow/50]*50 + 50};
  
  Print[\"    H/V range in window: [0, \", hvRangeZ[[2]], \"]\"];
  Print[\"    U range in window: [\", uRangeZ[[1]], \", \", uRangeZ[[2]], \"] \
m/s\"];
  
  (* === Build plot data with adjusted ranges === *)
  rTHV = If[Length[rTHVall] > 0,
    Select[rTHVall, #[[2]] <= hvRangeZ[[2]] &], {{-1, -1}}];
  pTHV = If[Length[pTHVall] > 0,
    Select[pTHVall, #[[2]] <= hvRangeZ[[2]] &], {{-1, -1}}];
  rTU = If[Length[rTUall] > 0, rTUall, {{-1, -1}}];
  pTU = If[Length[pTUall] > 0, pTUall, {{-1, -1}}];
  
  (* Rescale U to fit on H/V axis *)
  scaleU[u_] := hvRangeZ[[1]] + 
    (u - uRangeZ[[1]])/(uRangeZ[[2]] - uRangeZ[[1]]) * 
    (hvRangeZ[[2]] - hvRangeZ[[1]]);
  rTUsc = If[Length[rTU] > 0 && rTU =!= {{-1, -1}}, 
    {#[[1]], scaleU[#[[2]]]} & /@ rTU, {{-1, -1}}];
  pTUsc = If[Length[pTU] > 0 && pTU =!= {{-1, -1}}, 
    {#[[1]], scaleU[#[[2]]]} & /@ pTU, {{-1, -1}}];
  
  (* Right axis ticks adapted to zoomed U range *)
  uTickStep = Max[50, Round[(uRangeZ[[2]] - uRangeZ[[1]])/6 / 50] * 50];
  rightTicks = Table[{scaleU[v], v}, 
    {v, Ceiling[uRangeZ[[1]]/uTickStep]*uTickStep, uRangeZ[[2]], uTickStep}];
  
  (* X-axis ticks every 0.01 s for the narrow range *)
  xTicks = Table[{t, NumberForm[t, {3, 2}]}, {t, tZoomLo, tZoomHi, 0.01}];
  
  ListPlot[{rTHV, pTHV, rTUsc, pTUsc},
    PlotStyle -> {
      Directive[hvColor, AbsolutePointSize[5]],
      Directive[RGBColor[0.84, 0.15, 0.16], AbsolutePointSize[5]],
      Directive[uColor, AbsolutePointSize[4.5], Opacity[0.45]],
      Directive[RGBColor[0.55, 0.0, 0.55], AbsolutePointSize[4.5], \
Opacity[0.45]]},
    PlotRange -> {{tZoomLo, tZoomHi}, hvRangeZ},
    Frame -> True,
    FrameStyle -> Directive[Black, AbsoluteThickness[1.5], 14],
    FrameTicksStyle -> Directive[Black, 12],
    FrameTicks -> {{Automatic, rightTicks}, {xTicks, None}},
    FrameLabel -> {
      {Style[\"H/V Ratio\", 15, Bold], 
       Style[\"Group Velocity, U (m/s)\", 15, Bold]},
      {Style[\"Period, T (s)\", 15, Bold], None}},
    Epilog -> {
      (* Zoom annotation *)
      Inset[Framed[Style[
        \"ZOOMED VIEW\\nT = \" <> ToString[tZoomLo] <> 
        \" \[Dash] \" <> ToString[tZoomHi] <> \" s\\n(f = \" <> 
        ToString[Round[1/tZoomHi]] <> \" \[Dash] \" <> 
        ToString[Round[1/tZoomLo]] <> \" Hz)\",
        9, GrayLevel[0.3], Bold],
        Background -> Directive[White, Opacity[0.9]],
        FrameStyle -> GrayLevel[0.5], RoundingRadius -> 4],
        {tZoomLo + 0.003, hvRangeZ[[2]] * 0.92}, {-1, 1}]
    },
    GridLines -> {Table[t, {t, tZoomLo, tZoomHi, 0.005}], Automatic},
    GridLinesStyle -> Directive[GrayLevel[0.85], AbsoluteThickness[0.5]],
    PlotLabel -> Style[
      \"H/V & Group Velocity (Zoomed) \[Dash] h = \" <> ToString[hDim] <> 
      \" m, Vs = \" <> ToString[Round[VsLDim]] <> \" m/s\\n\" <>
      \"Period range: \" <> ToString[tZoomLo] <> \" \[Dash] \" <> 
      ToString[tZoomHi] <> \" s (f = \" <> ToString[Round[1/tZoomHi]] <>
      \" \[Dash] \" <> ToString[Round[1/tZoomLo]] <> \" Hz)\", 11],
    PlotLegends -> Placed[
      PointLegend[
        {hvColor, RGBColor[0.84, 0.15, 0.16], 
         Directive[uColor, Opacity[0.45]], 
         Directive[RGBColor[0.55, 0.0, 0.55], Opacity[0.45]]}, 
        {Style[\"Retro H/V\", 11], Style[\"Pro H/V\", 11],
         Style[\"Retro U\", 11], Style[\"Pro U\", 11]},
        LegendMarkerSize -> 10, LegendLayout -> \"Column\"],
      {Right, Top}],
    ImageSize -> 900,
    ImagePadding -> {{80, 90}, {60, 70}},
    Background -> White,
    AspectRatio -> 0.65
  ]
]];
showFig[figDim6Z];
Export[\"FigDim6Z_zoomed_T005_010.pdf\", figDim6Z, ImageResolution -> 300];
Print[\"  Exported: FigDim6Z_zoomed_T005_010.pdf\"];

\
\>", "Input",ExpressionUUID->"9211f3b0-5447-4a49-b557-3ad698844e6c"],

Cell["\<\
(* ================================================================ *)\
\>", "Input",ExpressionUUID->"3b396c20-f9eb-2740-933a-d328b20ab466"],

Cell["\<\
(* 14d. KINETIC ENERGY DENSITY FLUX                                  *)
(*      Ek_h = (1/2) rho omega^2 |u_h|^2 U  (horizontal component) *)
(*      Ek_v = (1/2) rho omega^2 |u_v|^2 U  (vertical component)   *)
(*      Ek_total = Ek_h + Ek_v  (scalar energy sum)                *)
(*                                                                    *)
(*  retroDataF columns: {ksh, kh, c/csL, U/csL, H/V, T*, |u_h|^2, |u_v|^2} *)
(* ================================================================ *)

Print[\"\\n================================================================\"];
Print[\"  Kinetic Energy Density Flux\"];
Print[\"  Ek_h =\[Rho]\[Omega]^2|u_h|^2 U\"];
Print[\"  Ek_v =\[Rho]\[Omega]^2|u_v|^2 U\"];
Print[\"  Ek_total = Ek_h + Ek_v\"];
Print[\"================================================================\\n\"];

(* ---- FigEk1: Ek_total + U/csL vs kh (dimensionless) ---- *)
Print[\"FigEk1: Ek_total + U/csL vs kh (dimensionless)\"];

figEk1 = Quiet[Module[
  {khRange = {0, 8}, uLo = -1, uHi = 6, hvMax = 30,
   rKU, pKU, rKHV, pKHV, rKHVsc, pKHVsc,
   ekRetro, ekPro,
   rKEksc, pKEksc, scaleEk, scaleHV, rightTksEk,
   ekMax, ekHi, ekTickStep, uColor, ekColor},
  
  uColor = RGBColor[0.12, 0.47, 0.71];
  ekColor = RGBColor[0.8, 0.0, 0.0];
  
  rKU = If[Length[retroDataF] > 0,
    Select[Transpose[{retroDataF[[All, 2]], retroDataF[[All, 4]]}],
      khRange[[1]] < #[[1]] <= khRange[[2]] && uLo <= #[[2]] <= uHi &], \
{{-1,-1}}];
  pKU = If[Length[proDataF] > 0,
    Select[Transpose[{proDataF[[All, 2]], proDataF[[All, 4]]}],
      khRange[[1]] < #[[1]] <= khRange[[2]] && uLo <= #[[2]] <= uHi &], \
{{-1,-1}}];
  
  ekRetro = If[Length[retroDataF] > 0 && Length[retroDataF[[1]]] >= 8,
    Module[{pts},
      pts = Table[Module[{ksh = retroDataF[[k, 1]], kh = retroDataF[[k, 2]],
                          UocsL = retroDataF[[k, 4]],
                          uHsq = retroDataF[[k, 7]], uVsq = retroDataF[[k, \
8]]},
        {kh, Max[0, 0.5*ksh^2*uHsq*Abs[UocsL] + 0.5*ksh^2*uVsq*Abs[UocsL]]}
      ], {k, Length[retroDataF]}];
      Select[pts, khRange[[1]] < #[[1]] <= khRange[[2]] && #[[2]] > 0 &]], {}];
  ekPro = If[Length[proDataF] > 0 && Length[proDataF[[1]]] >= 8,
    Module[{pts},
      pts = Table[Module[{ksh = proDataF[[k, 1]], kh = proDataF[[k, 2]],
                          UocsL = proDataF[[k, 4]],
                          uHsq = proDataF[[k, 7]], uVsq = proDataF[[k, 8]]},
        {kh, Max[0, 0.5*ksh^2*uHsq*Abs[UocsL] + 0.5*ksh^2*uVsq*Abs[UocsL]]}
      ], {k, Length[proDataF]}];
      Select[pts, khRange[[1]] < #[[1]] <= khRange[[2]] && #[[2]] > 0 &]], {}];
  
  Print[\"  Ek points: Retro=\", Length[ekRetro], \" Pro=\", Length[ekPro]];
  (* Data validation: discard any Ek <= 0 *)
  If[Length[ekRetro] > 0, ekRetro = Select[ekRetro, #[[2]] > 0 &]];
  If[Length[ekPro] > 0, ekPro = Select[ekPro, #[[2]] > 0 &]];
  Print[\"  After validation (Ek>0): Retro=\", Length[ekRetro], \" Pro=\", \
Length[ekPro]];
  
  (* H/V overlay data *)
  rKHV = If[nRetro > 0,
    Select[Transpose[{retroData[[All, 2]], retroData[[All, 5]]}],
      khRange[[1]] < #[[1]] <= khRange[[2]] && 0 < #[[2]] < hvMax &], {}];
  pKHV = If[nPro > 0,
    Select[Transpose[{proData[[All, 2]], proData[[All, 5]]}],
      khRange[[1]] < #[[1]] <= khRange[[2]] && 0 < #[[2]] < hvMax &], {}];
  scaleHV[hv_] := uLo + (hv/hvMax) * (uHi - uLo);
  rKHVsc = If[Length[rKHV] > 0, {#[[1]], scaleHV[#[[2]]]} & /@ rKHV, \
{{-1,-1}}];
  pKHVsc = If[Length[pKHV] > 0, {#[[1]], scaleHV[#[[2]]]} & /@ pKHV, \
{{-1,-1}}];
  
  (* Ek range: use Log10 scale so peaks don't crush the rest *)
  ekAllVals = Join[
    If[Length[ekRetro] > 0, Select[ekRetro[[All, 2]], # > 0 &], {}],
    If[Length[ekPro] > 0, Select[ekPro[[All, 2]], # > 0 &], {}]];
  If[Length[ekAllVals] == 0, ekAllVals = {1}];
  ekMax = Max[ekAllVals];
  ekMin = Max[Min[ekAllVals], ekMax*10^-6];  (* floor at 6 decades below max *)
  logEkMin = Log10[ekMin];
  logEkMax = Log10[ekMax*1.1];
  Print[\"  Ek*_max = \", NumberForm[ekMax, {8, 4}],
        \"  Ek*_min = \", NumberForm[ekMin, {8, 4}],
        \"  log range: [\", NumberForm[logEkMin, {4, 1}], 
        \", \", NumberForm[logEkMax, {4, 1}], \"]\"];
  
  (* Map Log10[ek] to [uLo, uHi] *)
  scaleEk[ek_] := If[ek > 0, 
    uLo + (Log10[ek] - logEkMin)/(logEkMax - logEkMin)*(uHi - uLo),
    uLo];
  
  (* Log-spaced tick marks *)
  rightTksEk = Table[
    {scaleEk[10^p], Superscript[\"10\", ToString[p]]},
    {p, Ceiling[logEkMin], Floor[logEkMax]}];
  
  rKEksc = If[Length[ekRetro] > 0, 
    Select[{#[[1]], scaleEk[#[[2]]]} & /@ Select[ekRetro, #[[2]] > 0 &],
      uLo <= #[[2]] <= uHi &], {{-1,-1}}];
  pKEksc = If[Length[ekPro] > 0, 
    Select[{#[[1]], scaleEk[#[[2]]]} & /@ Select[ekPro, #[[2]] > 0 &],
      uLo <= #[[2]] <= uHi &], {{-1,-1}}];
  
  ListPlot[{rKU, pKU, rKEksc, pKEksc, rKHVsc, pKHVsc},
    PlotStyle -> {
      Directive[RGBColor[0.12, 0.47, 0.71], AbsolutePointSize[3]],
      Directive[RGBColor[0.0, 0.7, 0.7], AbsolutePointSize[3]],
      Directive[RGBColor[0.8, 0.0, 0.0], AbsolutePointSize[2], Opacity[0.6]],
      Directive[RGBColor[0.95, 0.55, 0.0], AbsolutePointSize[2], Opacity[0.6]],
      Directive[Black, AbsolutePointSize[4]],
      Directive[RGBColor[0.75, 0.0, 0.75], AbsolutePointSize[4]]},
    PlotRange -> {{khRange[[1]], khRange[[2]]}, {uLo, uHi}},
    Frame -> True,
    FrameStyle -> Directive[Black, AbsoluteThickness[1.5], 13],
    FrameTicksStyle -> Directive[Black, 11],
    FrameTicks -> {{Automatic, rightTksEk}, {Automatic, None}},
    FrameLabel -> {{Style[\"U / csL\", 14, Bold], Style[\"log\[ThinSpace]Ek* \
(dimensionless)\", 13, Bold]},
      {Style[\"kh\", 14, Bold], None}},
    GridLines -> Automatic,
    GridLinesStyle -> Directive[GrayLevel[0.85], AbsoluteThickness[0.5]],
    PlotLabel -> Style[\"U, Ek & H/V vs kh\\n\" <>
      \"\[Nu]L=\" <> ToString[\[Nu]L] <>
      \", \[Lambda]L=\" <> ToString[NumberForm[\[Lambda]L, {5, 3}]] <>
      \", \[Mu]L=\" <> ToString[\[Mu]L] <>
      \", \[Rho]L=\" <> ToString[\[Rho]L] <>
      \", h=\" <> ToString[h] <> \", Rigid Halfspace\", 11],
    PlotLegends -> Placed[PointLegend[
      {RGBColor[0.12, 0.47, 0.71], RGBColor[0.0, 0.7, 0.7],
       RGBColor[0.8, 0.0, 0.0], RGBColor[0.95, 0.55, 0.0],
       Black, RGBColor[0.75, 0.0, 0.75]},
      {Style[\"Retro U/csL\", 10], Style[\"Pro U/csL\", 10],
       Style[\"Retro Ek\", 10, Italic], Style[\"Pro Ek\", 10, Italic],
       Style[\"Retro H/V\", 10, Bold], Style[\"Pro H/V\", 10, Bold]},
      LegendMarkerSize -> 8, LegendLayout -> \"Column\"], {Right, Top}],
    ImageSize -> 750, ImagePadding -> {{70, 80}, {55, 55}},
    Background -> White, AspectRatio -> 0.6
  ]
]];
showFig[figEk1];
Export[\"FigEk1_U_Ek_vs_kh.pdf\", figEk1, ImageResolution -> 300];
Print[\"  Exported: FigEk1_U_Ek_vs_kh.pdf\"];


(* ---- FigEk2: Ek_total + U (m/s) vs Frequency (dimensional) ---- *)
Print[\"\\nFigEk2: Ek_total + U(m/s) vs Frequency (dimensional)\"];

figEk2 = Quiet[Module[
  {fRange = {0.1, 20}, uRange = {0, 500}, hvMax = 30,
   rFU, pFU, rFHV, pFHV, rFHVsc, pFHVsc,
   ekRetro, ekPro,
   rFEksc, pFEksc, scaleEk, scaleHV, rightTksEk,
   ekMax, ekHi, ekTickStep, uColor, ekColor},
  
  uColor = RGBColor[0.12, 0.47, 0.71];
  ekColor = RGBColor[0.8, 0.0, 0.0];
  
  rFU = If[Length[retroDataF] > 0,
    Select[Transpose[{VsLDim*retroDataF[[All, 1]]/(2*Pi*hDim),
                       VsLDim*retroDataF[[All, 4]]}],
      fRange[[1]] <= #[[1]] <= fRange[[2]] &], {{-1,-1}}];
  pFU = If[Length[proDataF] > 0,
    Select[Transpose[{VsLDim*proDataF[[All, 1]]/(2*Pi*hDim),
                       VsLDim*proDataF[[All, 4]]}],
      fRange[[1]] <= #[[1]] <= fRange[[2]] &], {{-1,-1}}];
  
  ekRetro = If[Length[retroDataF] > 0 && Length[retroDataF[[1]]] >= 8,
    Module[{pts},
      pts = Table[Module[{freq = VsLDim*retroDataF[[k, 1]]/(2*Pi*hDim),
                          uDim = VsLDim*retroDataF[[k, 4]],
                          uHsq = retroDataF[[k, 7]], uVsq = retroDataF[[k, \
8]], omega},
        omega = 2*Pi*freq;
        {freq, Max[0, 0.5*\[Rho]LDim*omega^2*uHsq*Abs[uDim] + 
               0.5*\[Rho]LDim*omega^2*uVsq*Abs[uDim]]}
      ], {k, Length[retroDataF]}];
      Select[pts, fRange[[1]] <= #[[1]] <= fRange[[2]] && #[[2]] > 0 &]], {}];
  ekPro = If[Length[proDataF] > 0 && Length[proDataF[[1]]] >= 8,
    Module[{pts},
      pts = Table[Module[{freq = VsLDim*proDataF[[k, 1]]/(2*Pi*hDim),
                          uDim = VsLDim*proDataF[[k, 4]],
                          uHsq = proDataF[[k, 7]], uVsq = proDataF[[k, 8]], \
omega},
        omega = 2*Pi*freq;
        {freq, Max[0, 0.5*\[Rho]LDim*omega^2*uHsq*Abs[uDim] + 
               0.5*\[Rho]LDim*omega^2*uVsq*Abs[uDim]]}
      ], {k, Length[proDataF]}];
      Select[pts, fRange[[1]] <= #[[1]] <= fRange[[2]] && #[[2]] > 0 &]], {}];
  
  Print[\"  Ek points: Retro=\", Length[ekRetro], \" Pro=\", Length[ekPro]];
  
  (* H/V data for this figure *)
  rFHV = If[nRetro > 0,
    Select[Transpose[{VsLDim*retroData[[All, 1]]/(2*Pi*hDim), retroData[[All, \
5]]}],
      fRange[[1]] <= #[[1]] <= fRange[[2]] && 0 < #[[2]] < hvMax &], {}];
  pFHV = If[nPro > 0,
    Select[Transpose[{VsLDim*proData[[All, 1]]/(2*Pi*hDim), proData[[All, \
5]]}],
      fRange[[1]] <= #[[1]] <= fRange[[2]] && 0 < #[[2]] < hvMax &], {}];
  (* Scale H/V to right axis *)
  scaleHV[hv_] := uRange[[1]] + hv/hvMax * (uRange[[2]] - uRange[[1]]);
  rFHVsc = If[Length[rFHV] > 0, {#[[1]], scaleHV[#[[2]]]} & /@ rFHV, \
{{-1,-1}}];
  pFHVsc = If[Length[pFHV] > 0, {#[[1]], scaleHV[#[[2]]]} & /@ pFHV, \
{{-1,-1}}];
  Print[\"  H/V points: Retro=\", Length[rFHV], \" Pro=\", Length[pFHV]];
  (* Data validation: discard any Ek <= 0 *)
  If[Length[ekRetro] > 0, ekRetro = Select[ekRetro, #[[2]] > 0 &]];
  If[Length[ekPro] > 0, ekPro = Select[ekPro, #[[2]] > 0 &]];
  Print[\"  After validation (Ek>0): Retro=\", Length[ekRetro], \" Pro=\", \
Length[ekPro]];
  ekAllVals2 = Join[
    If[Length[ekRetro] > 0, Select[ekRetro[[All, 2]], # > 0 &], {}],
    If[Length[ekPro] > 0, Select[ekPro[[All, 2]], # > 0 &], {}]];
  If[Length[ekAllVals2] == 0, ekAllVals2 = {1}];
  ekMax = Max[ekAllVals2];
  ekMin = Max[Min[ekAllVals2], ekMax*10^-6];
  logEkMin = Log10[ekMin];
  logEkMax = Log10[ekMax*1.1];
  Print[\"  Ek_max = \", NumberForm[ekMax, {10, 3}],
        \"  log range: [\", NumberForm[logEkMin, {4, 1}], 
        \", \", NumberForm[logEkMax, {4, 1}], \"]\"];
  
  scaleEk[ek_] := If[ek > 0,
    uRange[[1]] + (Log10[ek] - logEkMin)/(logEkMax - logEkMin)*(uRange[[2]] - \
uRange[[1]]),
    uRange[[1]]];
  rightTksEk = Table[
    {scaleEk[10^p], Superscript[\"10\", ToString[p]]},
    {p, Ceiling[logEkMin], Floor[logEkMax]}];
  rFEksc = If[Length[ekRetro] > 0,
    Select[{#[[1]], scaleEk[#[[2]]]} & /@ Select[ekRetro, #[[2]] > 0 &],
      uRange[[1]] <= #[[2]] <= uRange[[2]] &], {{-1,-1}}];
  pFEksc = If[Length[ekPro] > 0,
    Select[{#[[1]], scaleEk[#[[2]]]} & /@ Select[ekPro, #[[2]] > 0 &],
      uRange[[1]] <= #[[2]] <= uRange[[2]] &], {{-1,-1}}];
  
  ListPlot[{rFU, pFU, rFEksc, pFEksc, rFHVsc, pFHVsc},
    PlotStyle -> {
      Directive[RGBColor[0.12, 0.47, 0.71], AbsolutePointSize[3]],
      Directive[RGBColor[0.0, 0.7, 0.7], AbsolutePointSize[3]],
      Directive[RGBColor[0.8, 0.0, 0.0], AbsolutePointSize[2], Opacity[0.6]],
      Directive[RGBColor[0.95, 0.55, 0.0], AbsolutePointSize[2], Opacity[0.6]],
      Directive[Black, AbsolutePointSize[4]],
      Directive[RGBColor[0.75, 0.0, 0.75], AbsolutePointSize[4]]},
    PlotRange -> {{fRange[[1]], fRange[[2]]}, {uRange[[1]], uRange[[2]]}},
    Frame -> True,
    FrameStyle -> Directive[Black, AbsoluteThickness[1.5], 13],
    FrameTicksStyle -> Directive[Black, 11],
    FrameTicks -> {{Automatic, 
      Join[rightTksEk, 
        Table[{scaleHV[hv], Style[ToString[hv], 9, RGBColor[0.4, 0, 0.4]]}, 
          {hv, 0, hvMax, 5}]]}, {Automatic, None}},
    FrameLabel -> {{Style[\"Group Velocity, U (m/s)\", 14, Bold],
      Style[\"log Ek  |  H/V Ratio\", 13, Bold]},
      {Style[\"Frequency, f (Hz)\", 14, Bold], None}},
    Epilog -> {
      (* Fundamental frequency fs *)
      {Darker[Green, 0.3], AbsoluteThickness[2], Dashing[{0.015, 0.008}],
       Line[{{fsDim, uRange[[1]]}, {fsDim, uRange[[2]]}}]},
      {Darker[Green, 0.3],
       Text[Style[\"fs\", 9, Bold], {fsDim, uRange[[2]]*0.95}, {-1.2, 0}]},
      {RGBColor[0.6, 0.3, 0.0], AbsoluteThickness[1.5], Dashing[{0.01, 0.008}],
       Line[{{2*fsDim, uRange[[1]]}, {2*fsDim, uRange[[2]]}}]},
      {RGBColor[0.6, 0.3, 0.0],
       Text[Style[\"2fs\", 8], {2*fsDim, uRange[[2]]*0.88}, {-1.2, 0}]}
    },
    GridLines -> Automatic,
    GridLinesStyle -> Directive[GrayLevel[0.85], AbsoluteThickness[0.5]],
    PlotLabel -> Style[\"U, Ek & H/V vs Frequency \[Dash] h = \" <> \
ToString[hDim] <> \" m, VsL = \" <> ToString[Round[VsLDim]] <> \" m/s\\n\" <>
      \"\[Nu]L = \" <> ToString[\[Nu]L] <> \", \[Lambda]L = \" <> \
ToString[NumberForm[\[Lambda]L, {5, 3}]] <>
      \", \[Rho]L = \" <> ToString[\[Rho]LDim] <> \" kg/m^3\", 11],
    PlotLegends -> Placed[PointLegend[
      {RGBColor[0.12, 0.47, 0.71], RGBColor[0.0, 0.7, 0.7],
       RGBColor[0.8, 0.0, 0.0], RGBColor[0.95, 0.55, 0.0],
       Black, RGBColor[0.75, 0.0, 0.75]},
      {Style[\"Retro U\", 10], Style[\"Pro U\", 10],
       Style[\"Retro Ek\", 10, Italic], Style[\"Pro Ek\", 10, Italic],
       Style[\"Retro H/V\", 10, Bold], Style[\"Pro H/V\", 10, Bold]},
      LegendMarkerSize -> 10, LegendLayout -> \"Column\"], {Right, Top}],
    ImageSize -> 800, ImagePadding -> {{70, 90}, {55, 65}},
    Background -> White, AspectRatio -> 0.6
  ]
]];
showFig[figEk2];
Export[\"FigEk2_U_Ek_vs_freq.pdf\", figEk2, ImageResolution -> 300];
Print[\"  Exported: FigEk2_U_Ek_vs_freq.pdf\"];
(* ---- FigEk3: Ek_total + U (m/s) vs Period (dimensional) ---- *)
Print[\"\\nFigEk3: Ek_total + U(m/s) vs Period (dimensional)\"];

figEk3 = Quiet[Module[
  {tRange = {0.05, 5}, uRange = {0, 500}, hvMax = 30,
   rTU, pTU, rTHV, pTHV, rTHVsc, pTHVsc,
   ekRetroT, ekProT,
   rTEksc, pTEksc, scaleEk, scaleHV, rightTksEk,
   ekAllVals3, ekMax, ekMin, logEkMin, logEkMax,
   uColor, ekColor},
  
  uColor  = RGBColor[0.12, 0.47, 0.71];
  ekColor = RGBColor[0.8, 0.0, 0.0];
  
  (* U (m/s) vs period *)
  rTU = If[Length[retroDataF] > 0,
    Select[Transpose[{2*Pi*hDim/(VsLDim*retroDataF[[All, 1]]), 
                       VsLDim*retroDataF[[All, 4]]}],
      tRange[[1]] <= #[[1]] <= tRange[[2]] &], {{-1,-1}}];
  pTU = If[Length[proDataF] > 0,
    Select[Transpose[{2*Pi*hDim/(VsLDim*proDataF[[All, 1]]), 
                       VsLDim*proDataF[[All, 4]]}],
      tRange[[1]] <= #[[1]] <= tRange[[2]] &], {{-1,-1}}];
  
  (* Ek_total vs period *)
  ekRetroT = If[Length[retroDataF] > 0 && Length[retroDataF[[1]]] >= 8,
    Module[{pts},
      pts = Table[Module[{
          per = 2*Pi*hDim/(VsLDim*retroDataF[[k, 1]]),
          freq = VsLDim*retroDataF[[k, 1]]/(2*Pi*hDim),
          uDim = VsLDim*retroDataF[[k, 4]],
          uHsq = retroDataF[[k, 7]], uVsq = retroDataF[[k, 8]], omega},
        omega = 2*Pi*freq;
        {per, Max[0, 0.5*\[Rho]LDim*omega^2*uHsq*Abs[uDim] + 
              0.5*\[Rho]LDim*omega^2*uVsq*Abs[uDim]]}
      ], {k, Length[retroDataF]}];
      Select[pts, tRange[[1]] <= #[[1]] <= tRange[[2]] && #[[2]] > 0 &]], {}];
  ekProT = If[Length[proDataF] > 0 && Length[proDataF[[1]]] >= 8,
    Module[{pts},
      pts = Table[Module[{
          per = 2*Pi*hDim/(VsLDim*proDataF[[k, 1]]),
          freq = VsLDim*proDataF[[k, 1]]/(2*Pi*hDim),
          uDim = VsLDim*proDataF[[k, 4]],
          uHsq = proDataF[[k, 7]], uVsq = proDataF[[k, 8]], omega},
        omega = 2*Pi*freq;
        {per, Max[0, 0.5*\[Rho]LDim*omega^2*uHsq*Abs[uDim] + 
              0.5*\[Rho]LDim*omega^2*uVsq*Abs[uDim]]}
      ], {k, Length[proDataF]}];
      Select[pts, tRange[[1]] <= #[[1]] <= tRange[[2]] && #[[2]] > 0 &]], {}];
  
  Print[\"  Ek points (period): Retro=\", Length[ekRetroT], \" Pro=\", \
Length[ekProT]];
  If[Length[ekRetroT] > 0, ekRetroT = Select[ekRetroT, #[[2]] > 0 &]];
  If[Length[ekProT] > 0, ekProT = Select[ekProT, #[[2]] > 0 &]];
  Print[\"  After validation (Ek>0): Retro=\", Length[ekRetroT], \" Pro=\", \
Length[ekProT]];
  
  ekAllVals3 = Join[
    If[Length[ekRetroT] > 0, Select[ekRetroT[[All, 2]], # > 0 &], {}],
    If[Length[ekProT] > 0, Select[ekProT[[All, 2]], # > 0 &], {}]];
  If[Length[ekAllVals3] == 0, ekAllVals3 = {1}];
  ekMax = Max[ekAllVals3];
  ekMin = Max[Min[ekAllVals3], ekMax*10^-6];
  logEkMin = Log10[ekMin];
  logEkMax = Log10[ekMax*1.1];
  
  scaleEk[ek_] := If[ek > 0,
    uRange[[1]] + (Log10[ek] - logEkMin)/(logEkMax - logEkMin)*(uRange[[2]] - \
uRange[[1]]),
    uRange[[1]]];
  rightTksEk = Table[
    {scaleEk[10^p], Superscript[\"10\", ToString[p]]},
    {p, Ceiling[logEkMin], Floor[logEkMax]}];
  
  rTEksc = If[Length[ekRetroT] > 0,
    Select[{#[[1]], scaleEk[#[[2]]]} & /@ Select[ekRetroT, #[[2]] > 0 &],
      uRange[[1]] <= #[[2]] <= uRange[[2]] &], {{-1,-1}}];
  pTEksc = If[Length[ekProT] > 0,
    Select[{#[[1]], scaleEk[#[[2]]]} & /@ Select[ekProT, #[[2]] > 0 &],
      uRange[[1]] <= #[[2]] <= uRange[[2]] &], {{-1,-1}}];
  
  (* H/V overlay data *)
  rTHV = If[nRetro > 0,
    Select[Transpose[{2*Pi*hDim/(VsLDim*retroData[[All, 1]]), retroData[[All, \
5]]}],
      tRange[[1]] <= #[[1]] <= tRange[[2]] && 0 < #[[2]] < hvMax &], {}];
  pTHV = If[nPro > 0,
    Select[Transpose[{2*Pi*hDim/(VsLDim*proData[[All, 1]]), proData[[All, \
5]]}],
      tRange[[1]] <= #[[1]] <= tRange[[2]] && 0 < #[[2]] < hvMax &], {}];
  scaleHV[hv_] := uRange[[1]] + hv/hvMax * (uRange[[2]] - uRange[[1]]);
  rTHVsc = If[Length[rTHV] > 0, {#[[1]], scaleHV[#[[2]]]} & /@ rTHV, \
{{-1,-1}}];
  pTHVsc = If[Length[pTHV] > 0, {#[[1]], scaleHV[#[[2]]]} & /@ pTHV, \
{{-1,-1}}];
  
  ListLogLinearPlot[{rTU, pTU, rTEksc, pTEksc, rTHVsc, pTHVsc},
    PlotStyle -> {
      Directive[RGBColor[0.12, 0.47, 0.71], AbsolutePointSize[3]],
      Directive[RGBColor[0.0, 0.7, 0.7], AbsolutePointSize[3]],
      Directive[RGBColor[0.8, 0.0, 0.0], AbsolutePointSize[2], Opacity[0.6]],
      Directive[RGBColor[0.95, 0.55, 0.0], AbsolutePointSize[2], Opacity[0.6]],
      Directive[Black, AbsolutePointSize[4]],
      Directive[RGBColor[0.75, 0.0, 0.75], AbsolutePointSize[4]]},
    PlotRange -> {{tRange[[1]], tRange[[2]]}, {uRange[[1]], uRange[[2]]}},
    Frame -> True,
    FrameStyle -> Directive[Black, AbsoluteThickness[1.5], 13],
    FrameTicksStyle -> Directive[Black, 11],
    FrameTicks -> {{Automatic, rightTksEk}, {Automatic, None}},
    FrameLabel -> {
      {Style[\"Group Velocity, U (m/s)\", 14, Bold], 
       Style[\"log\[ThinSpace]Ek (J/m\[CenterDot]s)\", 13, Bold]},
      {Style[\"Period, T (s)\", 14, Bold], None}},
    Epilog -> {
      (* Fundamental period Ts = 4h/cs *)
      {Darker[Green, 0.3], AbsoluteThickness[2], Dashing[{0.015, 0.008}],
       Line[{{TsDim, uRange[[1]]}, {TsDim, uRange[[2]]}}]},
      {Darker[Green, 0.3],
       Text[Style[\"Ts\", 9, Bold], {TsDim, uRange[[2]]*0.95}, {-1.2, 0}]},
      (* P-wave fundamental Tp *)
      {RGBColor[0.85, 0.45, 0], AbsoluteThickness[1.5], Dashing[{0.01, 0.008}],
       Line[{{TpDim, uRange[[1]]}, {TpDim, uRange[[2]]}}]},
      {RGBColor[0.85, 0.45, 0],
       Text[Style[\"Tp\", 8], {TpDim, uRange[[2]]*0.88}, {-1.2, 0}]}
    },
    GridLines -> Automatic,
    GridLinesStyle -> Directive[GrayLevel[0.85], AbsoluteThickness[0.5]],
    PlotLabel -> Style[
      \"U, Ek & H/V vs Period \[Dash] h = \" <> ToString[hDim] <> \" m, VsL = \
\" <> ToString[Round[VsLDim]] <> \" m/s\\n\" <>
      \"\[Nu]L = \" <> ToString[\[Nu]L] <> \", \[Lambda]L = \" <> \
ToString[NumberForm[\[Lambda]L, {5, 3}]] <>
      \", \[Rho]L = \" <> ToString[\[Rho]LDim] <> \" kg/m^3\", 10],
    PlotLegends -> Placed[PointLegend[
      {RGBColor[0.12, 0.47, 0.71], RGBColor[0.0, 0.7, 0.7],
       RGBColor[0.8, 0.0, 0.0], RGBColor[0.95, 0.55, 0.0],
       Black, RGBColor[0.75, 0.0, 0.75]},
      {Style[\"Retro U\", 10], Style[\"Pro U\", 10],
       Style[\"Retro Ek\", 10, Italic], Style[\"Pro Ek\", 10, Italic],
       Style[\"Retro H/V\", 10, Bold], Style[\"Pro H/V\", 10, Bold]},
      LegendMarkerSize -> 8, LegendLayout -> \"Column\"], {Right, Top}],
    ImageSize -> 750,
    ImagePadding -> {{70, 80}, {55, 55}},
    Background -> White, AspectRatio -> 0.6
  ]
]];
If[MatchQ[figEk3, _Graphics | _Legended], Print[figEk3]];
Export[\"FigEk3_U_Ek_vs_period.pdf\", figEk3, ImageResolution -> 300];
Print[\"  Exported: FigEk3_U_Ek_vs_period.pdf\"];



\
\>", "Input",ExpressionUUID->"3dac1ddf-bdca-9f40-9339-72c836231de5"],

Cell["\<\
(* ================================================================ *)
(* ================================================================ *)
(*                                                                    *)



(* ================================================================ *)
(* ================================================================ *)
(*                                                                    *)
(* PARAMETRIC STUDY: DIMENSIONAL SCALING                             *)
(*                                                                    *)
(*   The dimensionless dispersion relation depends only on material  *)
(*   ratios (\[Nu]L, \[Mu]H/\[Mu]L, \[Rho]H/\[Rho]L).       *)
(*   Different shear-wave velocities Vs and layer thicknesses h     *)
(*   simply RESCALE the dimensional axes:                            *)
(*                                                                    *)
(*     f_dim  = Vs * ksh / (2\[Pi] * h)                             *)
(*     c_dim  = Vs * (c/csL)                                         *)
(*     U_dim  = Vs * (U/csL)                                         *)
(*     T_dim  = 2\[Pi] * h / (Vs * ksh)                             *)
(*                                                                    *)
(*   Therefore, ONE dimensionless root-finding sweep serves ALL      *)
(*   combinations of (Vs, h).  Only \[Nu]L requires re-running     *)
(*   the full sweep (change \[Nu]L in Section 1 and re-evaluate).  *)
(*                                                                    *)
(* ================================================================ *)
(* ================================================================ *)

Print[\"\\n================================================================\"];
Print[\"  PARAMETRIC STUDY\"];

(* Set directory for parametric PDF exports *)
Print[\"================================================================\"];

\
\>", "Input",ExpressionUUID->"42fb062d-3d51-e644-9b8c-2c11ee4b9584"],

Cell["\<\
(* ================================================================ *)
(* KEY PHYSICS ANALYSIS: H/V_max + U_min correlation                *)
(*                                                                    *)
(* Advisor's thesis contribution:                                     *)
(*   \"H/V is a measure of the horizontal displacement component       *)
(*    over the vertical displacement component at the free surface.   *)
(*    The group velocity U carries the energy. When U goes to a       *)
(*    minimum, the seismic energy is traveling very slowly at a        *)
(*    particular period or frequency. If H/V goes to infinity or      *)
(*    becomes very large at the same period, this means the           *)
(*    horizontal component is much larger than the vertical component *)
(*    at the time when all the energy is moving slowly.               *)
(*    The worst scenario would be that the fundamental period of      *)
(*    the structure is also close to the shaking period.\"             *)
(* ================================================================ *)

Print[\"\\n  KEY PHYSICS: H/V_max and U_min Analysis\"];
Print[\"  ================================================================\"];

Module[{retroHVdata, retroUdata, hvMax, hvMaxT, uMinRetro, uMinT,
        retroHVdataF, retroUdataF, hvMaxF, hvMaxTF, uMinRetroF, uMinTF},

  (* Dimensionless analysis *)
  retroHVdata = If[nRetro > 0,
    Select[Transpose[{retroData[[All, 6]], retroData[[All, 5]]}],
      0.3 < #[[1]] < 10 && NumericQ[#[[2]]] && #[[2]] > 0 &], {}];
  retroUdata = If[nRetro > 0,
    Select[Transpose[{retroData[[All, 6]], Re[retroData[[All, 4]]]}],
      0.3 < #[[1]] < 10 && NumericQ[#[[2]]] && #[[2]] > 0 &], {}];
  
  If[Length[retroHVdata] > 10,
    hvMax = Max[retroHVdata[[All, 2]]];
    hvMaxT = retroHVdata[[First[Ordering[retroHVdata[[All, 2]], -1]]]][[1]];
    Print[\"  Dimensionless (retrograde only):\"];
    Print[\"    H/V_max  = \", NumberForm[hvMax, {6, 2}], \" at T = \", \
NumberForm[hvMaxT, {5, 3}]];
  ];
  
  If[Length[retroUdata] > 10,
    uMinRetro = Min[retroUdata[[All, 2]]];
    uMinT = retroUdata[[First[Ordering[retroUdata[[All, 2]], 1]]]][[1]];
    Print[\"    U_min    = \", NumberForm[uMinRetro, {5, 3}], \" csL at T = \
\", NumberForm[uMinT, {5, 3}]];
  ];
  
  Print[\"    Ts (S-wave quarter-\[Lambda]) = \", NumberForm[N[Ts], {5, 3}]];
  Print[\"    Tp (P-wave quarter-\[Lambda]) = \", NumberForm[N[Tp], {5, 3}]];
  Print[\"\"];
  
  (* Dimensional analysis *)
  retroHVdataF = If[nRetro > 0,
    Select[Transpose[{VsLDim*retroData[[All, 1]]/(2*Pi*hDim), retroData[[All, \
5]]}],
      0.1 < #[[1]] < 20 && NumericQ[#[[2]]] && #[[2]] > 0 &], {}];
  retroUdataF = If[nRetro > 0,
    Select[Transpose[{VsLDim*retroData[[All, 1]]/(2*Pi*hDim), \
VsLDim*Re[retroData[[All, 4]]]}],
      0.1 < #[[1]] < 20 && NumericQ[#[[2]]] && #[[2]] > 0 &], {}];

  If[Length[retroHVdataF] > 10,
    hvMaxF = Max[retroHVdataF[[All, 2]]];
    hvMaxTF = retroHVdataF[[First[Ordering[retroHVdataF[[All, 2]], -1]]]][[1]];
    Print[\"  Dimensional (h = \", hDim, \" m, Vs = \", VsLDim, \" m/s):\"];
    Print[\"    H/V_max  = \", NumberForm[hvMaxF, {6, 2}], \" at f = \", 
      NumberForm[hvMaxTF, {5, 2}], \" Hz (T = \", NumberForm[1/hvMaxTF, {5, \
4}], \" s)\"];
  ];
  
  If[Length[retroUdataF] > 10,
    uMinRetroF = Min[retroUdataF[[All, 2]]];
    uMinTF = retroUdataF[[First[Ordering[retroUdataF[[All, 2]], 1]]]][[1]];
    Print[\"    U_min    = \", NumberForm[uMinRetroF, {5, 1}], \" m/s at f = \
\", 
      NumberForm[uMinTF, {5, 2}], \" Hz (T = \", NumberForm[1/uMinTF, {5, \
4}], \" s)\"];
  ];
  
  Print[\"    fs (S-wave) = \", NumberForm[fsDim, {5, 2}], \" Hz\"];
  Print[\"    fp (P-wave) = \", NumberForm[fpDim, {5, 2}], \" Hz\"];
  Print[\"\"];
  Print[\"  INTERPRETATION:\"];
  Print[\"    When U_min and H/V_max coincide at the same period:\"];
  Print[\"    \[RightArrow] Maximum horizontal shaking occurs while seismic \
energy\"];
  Print[\"      travels at minimum velocity (energy pileup).\"];
  Print[\"    \[RightArrow] Any structure with fundamental period near this \
value\"];
  Print[\"      is at greatest risk of collapse.\"];
  Print[\"  \
================================================================\"];
];

\
\>", "Input",ExpressionUUID->"fdfdad63-ed0f-9441-8b07-57838a5666a5"],

Cell["\<\
(* ================================================================ *)
(* AIRY PHASE CORRELATION: ANNOTATED FIGURE                         *)
(*                                                                    *)
(* ================================================================ *)
(* GOAL FIGURE: H/V + U + Ek \[AHat]\.80\.94 Three-Panel Correlation          \
     *)
(*                                                                    *)
(* Shows the thesis contribution:                                     *)
(*   Panel 1 (top):    H/V ratio \[AHat]\.80\.94 singularity at resonance     \
      *)
(*   Panel 2 (middle): Group velocity U \[AHat]\.80\.94 minimum (Airy phase)  \
      *)
(*   Panel 3 (bottom): Kinetic energy Ek \[AHat]\.80\.94 maximum              \
      *)
(*   All panels share the same x-axis (frequency or period)           *)
(*   Vertical markers at fs show the correlation                      *)
(*   Retrograde \[AHat]\.86\.92 Prograde transition visible at the \
singularity      *)
(* ================================================================ *)

Print[\"\\n  GOAL FIGURE: H/V + U + Ek Three-Panel Correlation\"];
Print[\"  ================================================================\"];

(* ---------- VERSION 1: DIMENSIONAL (vs Frequency) ---------- *)
Module[{fLo = 0.1, fHi = 20, hvHi = 30,
  uLo = -50, uHi = 500, ekFloor,
  rFHV, pFHV, rFU, pFU, rFEkH, rFEkV, pFEkH, pFEkV,
  rFEk, pFEk,
  panelHV, panelU, panelEk, figGoalDim,
  retroC1 = Black, proC1 = Red,
  retroC2 = RGBColor[0.12, 0.47, 0.71], proC2 = RGBColor[0.0, 0.7, 0.7],
  retroC3 = RGBColor[0.6, 0.0, 0.0], proC3 = RGBColor[0.95, 0.55, 0.0],
  fsEpilog, commonOpts},

  (* Resonance markers *)
  fsEpilog[yLo_, yHi_] := {
    {Darker[Green, 0.3], AbsoluteThickness[2], Dashing[{0.015, 0.008}],
     Line[{{fsDim, yLo}, {fsDim, yHi}}]},
    {Darker[Green, 0.3],
     Text[Style[\"fs\", 9, Bold], {fsDim, yHi*0.92}, {-1.2, 0}]},
    {RGBColor[0.6, 0.3, 0], AbsoluteThickness[1.5], Dashing[{0.01, 0.008}],
     Line[{{2*fsDim, yLo}, {2*fsDim, yHi}}]},
    {RGBColor[0.6, 0.3, 0],
     Text[Style[\"2fs\", 8], {2*fsDim, yHi*0.85}, {-1.2, 0}]}
  };

  (* --- Panel 1: H/V ratio --- *)
  rFHV = If[nRetro > 0,
    Select[Transpose[{VsLDim*retroData[[All, 1]]/(2*Pi*hDim), retroData[[All, \
5]]}],
      fLo < #[[1]] < fHi && 0 < #[[2]] <= hvHi &], {}];
  pFHV = If[nPro > 0,
    Select[Transpose[{VsLDim*proData[[All, 1]]/(2*Pi*hDim), proData[[All, \
5]]}],
      fLo < #[[1]] < fHi && 0 < #[[2]] <= hvHi &], {}];

  panelHV = ListPlot[
    Select[{rFHV, pFHV}, Length[#] > 0 &],
    PlotStyle -> {
      Directive[retroC1, AbsolutePointSize[4]],
      Directive[proC1, AbsolutePointSize[4]]},
    PlotRange -> {{fLo, fHi}, {0, hvHi}},
    Frame -> True,
    FrameStyle -> Directive[Black, AbsoluteThickness[1.2], 12],
    FrameLabel -> {{Style[\"H/V Ratio\", 13, Bold], None}, {None, None}},
    FrameTicksStyle -> Directive[Black, 10],
    Epilog -> Join[fsEpilog[0, hvHi], {
      Text[Style[\"Retrograde\", 9, retroC1], Scaled[{0.85, 0.9}]],
      Text[Style[\"Prograde\", 9, proC1], Scaled[{0.85, 0.82}]]
    }],
    GridLines -> Automatic,
    GridLinesStyle -> Directive[GrayLevel[0.9], AbsoluteThickness[0.3]],
    ImageSize -> {700, 180}, ImagePadding -> {{60, 20}, {5, 35}},
    Background -> White
  ];

  (* --- Panel 2: Group Velocity U --- *)
  rFU = If[Length[retroDataF] > 0,
    Select[Transpose[{VsLDim*retroDataF[[All, 1]]/(2*Pi*hDim),
                       VsLDim*retroDataF[[All, 4]]}],
      fLo < #[[1]] < fHi && uLo <= #[[2]] <= uHi &], {}];
  pFU = If[Length[proDataF] > 0,
    Select[Transpose[{VsLDim*proDataF[[All, 1]]/(2*Pi*hDim),
                       VsLDim*proDataF[[All, 4]]}],
      fLo < #[[1]] < fHi && uLo <= #[[2]] <= uHi &], {}];

  panelU = ListPlot[
    Select[{rFU, pFU}, Length[#] > 0 &],
    PlotStyle -> {
      Directive[retroC2, AbsolutePointSize[3.5]],
      Directive[proC2, AbsolutePointSize[3.5]]},
    PlotRange -> {{fLo, fHi}, {uLo, uHi}},
    Frame -> True,
    FrameStyle -> Directive[Black, AbsoluteThickness[1.2], 12],
    FrameLabel -> {{Style[\"U (m/s)\", 13, Bold], None}, {None, None}},
    FrameTicksStyle -> Directive[Black, 10],
    Epilog -> fsEpilog[uLo, uHi],
    GridLines -> Automatic,
    GridLinesStyle -> Directive[GrayLevel[0.9], AbsoluteThickness[0.3]],
    ImageSize -> {700, 160}, ImagePadding -> {{60, 20}, {5, 15}},
    Background -> White
  ];

  (* --- Panel 3: Kinetic Energy Ek --- *)
  rFEk = If[Length[retroDataF] > 0 && Length[retroDataF[[1]]] >= 8,
    Module[{pts},
      pts = Table[Module[{freq = VsLDim*retroDataF[[k, 1]]/(2*Pi*hDim),
                          uDim = VsLDim*retroDataF[[k, 4]],
                          uHsq = retroDataF[[k, 7]], uVsq = retroDataF[[k, \
8]], omega},
        omega = 2*Pi*freq;
        {freq, Max[0, 0.5*\[Rho]LDim*omega^2*uHsq*Abs[uDim] +
               0.5*\[Rho]LDim*omega^2*uVsq*Abs[uDim]]}
      ], {k, Length[retroDataF]}];
      Select[pts, fLo < #[[1]] < fHi && #[[2]] > 0 &]], {}];
  pFEk = If[Length[proDataF] > 0 && Length[proDataF[[1]]] >= 8,
    Module[{pts},
      pts = Table[Module[{freq = VsLDim*proDataF[[k, 1]]/(2*Pi*hDim),
                          uDim = VsLDim*proDataF[[k, 4]],
                          uHsq = proDataF[[k, 7]], uVsq = proDataF[[k, 8]], \
omega},
        omega = 2*Pi*freq;
        {freq, Max[0, 0.5*\[Rho]LDim*omega^2*uHsq*Abs[uDim] +
               0.5*\[Rho]LDim*omega^2*uVsq*Abs[uDim]]}
      ], {k, Length[proDataF]}];
      Select[pts, fLo < #[[1]] < fHi && #[[2]] > 0 &]], {}];

  Print[\"  Ek points: Retro=\", Length[rFEk], \" Pro=\", Length[pFEk]];

  panelEk = ListLogPlot[
    Select[{rFEk, pFEk}, Length[#] > 0 &],
    PlotStyle -> {
      Directive[retroC3, AbsolutePointSize[3]],
      Directive[proC3, AbsolutePointSize[3]]},
    PlotRange -> {{fLo, fHi}, All},
    Frame -> True,
    FrameStyle -> Directive[Black, AbsoluteThickness[1.2], 12],
    FrameLabel -> {{Style[\"Ek (log)\", 13, Bold], None},
                   {Style[\"Frequency, f (Hz)\", 13, Bold], None}},
    FrameTicksStyle -> Directive[Black, 10],
    GridLines -> Automatic,
    GridLinesStyle -> Directive[GrayLevel[0.9], AbsoluteThickness[0.3]],
    ImageSize -> {700, 180}, ImagePadding -> {{60, 20}, {40, 5}},
    Background -> White
  ];

  (* --- Combine three panels --- *)
  figGoalDim = GraphicsColumn[{panelHV, panelU, panelEk},
    Spacings -> 0,
    PlotLabel -> Style[
      \"H/V, U & Ek vs Frequency \[Dash] h = \" <> ToString[hDim] <>
      \" m, VsL = \" <> ToString[Round[VsLDim]] <> \" m/s, \[Nu]L = \" <>
      ToString[\[Nu]L] <> \", \[Lambda]L = \" <>
      ToString[NumberForm[\[Lambda]L, {5, 3}]] <>
      \"\\nRigid Halfspace | fs = \" <> ToString[NumberForm[fsDim, {5, 3}]] <>
      \" Hz | \[Rho]L = \" <> ToString[\[Rho]LDim] <> \" kg/m^3\", 11, Bold],
    ImageSize -> 750
  ];

  Print[figGoalDim];
  Export[\"FigGoal_HV_U_Ek_freq.pdf\", figGoalDim, ImageResolution -> 300];
  Print[\"  Exported: FigGoal_HV_U_Ek_freq.pdf\"];
];


(* ---------- VERSION 2: DIMENSIONLESS (vs T*) ---------- *)
Module[{tLo = 0.2, tHi = 15, hvHi = 30,
  uLo = -1, uHi = 6,
  rTHV, pTHV, rTU, pTU, rTEk, pTEk,
  panelHV, panelU, panelEk, figGoalDimless,
  retroC1 = Black, proC1 = Red,
  retroC2 = RGBColor[0.12, 0.47, 0.71], proC2 = RGBColor[0.0, 0.7, 0.7],
  retroC3 = RGBColor[0.6, 0.0, 0.0], proC3 = RGBColor[0.95, 0.55, 0.0],
  tsEpilog},

  tsEpilog[yLo_, yHi_] := {
    {Darker[Green, 0.3], AbsoluteThickness[2],
     Line[{{Log[Ts], yLo}, {Log[Ts], yHi}}]},
    {Darker[Green, 0.3],
     Text[Style[\"Ts\", 9, Bold], {Log[Ts], yHi*0.92}, {-1.2, 0}]},
    {RGBColor[0.85, 0.45, 0], AbsoluteThickness[1.5], Dashed,
     Line[{{Log[Tp], yLo}, {Log[Tp], yHi}}]},
    {RGBColor[0.85, 0.45, 0],
     Text[Style[\"Tp\", 8], {Log[Tp], yHi*0.85}, {-1.2, 0}]}
  };

  rTHV = If[nRetro > 0,
    Select[Transpose[{retroData[[All, 6]], retroData[[All, 5]]}],
      tLo < #[[1]] < tHi && 0 < #[[2]] <= hvHi &], {}];
  pTHV = If[nPro > 0,
    Select[Transpose[{proData[[All, 6]], proData[[All, 5]]}],
      tLo < #[[1]] < tHi && 0 < #[[2]] <= hvHi &], {}];

  panelHV = ListLogLinearPlot[
    Select[{rTHV, pTHV}, Length[#] > 0 &],
    PlotStyle -> {
      Directive[retroC1, AbsolutePointSize[4]],
      Directive[proC1, AbsolutePointSize[4]]},
    PlotRange -> {{tLo, tHi}, {0, hvHi}},
    Frame -> True,
    FrameStyle -> Directive[Black, AbsoluteThickness[1.2], 12],
    FrameLabel -> {{Style[\"H/V Ratio\", 13, Bold], None}, {None, None}},
    FrameTicksStyle -> Directive[Black, 10],
    Epilog -> Join[tsEpilog[0, hvHi], {
      Text[Style[\"Retrograde\", 9, retroC1], Scaled[{0.85, 0.9}]],
      Text[Style[\"Prograde\", 9, proC1], Scaled[{0.85, 0.82}]]
    }],
    GridLines -> Automatic,
    GridLinesStyle -> Directive[GrayLevel[0.9], AbsoluteThickness[0.3]],
    ImageSize -> {700, 180}, ImagePadding -> {{60, 20}, {5, 35}},
    Background -> White
  ];

  rTU = If[nRetro > 0,
    Select[Transpose[{retroData[[All, 6]], Re[retroData[[All, 4]]]}],
      tLo < #[[1]] < tHi && uLo <= #[[2]] <= uHi &], {}];
  pTU = If[nPro > 0,
    Select[Transpose[{proData[[All, 6]], Re[proData[[All, 4]]]}],
      tLo < #[[1]] < tHi && uLo <= #[[2]] <= uHi &], {}];

  panelU = ListLogLinearPlot[
    Select[{rTU, pTU}, Length[#] > 0 &],
    PlotStyle -> {
      Directive[retroC2, AbsolutePointSize[3.5]],
      Directive[proC2, AbsolutePointSize[3.5]]},
    PlotRange -> {{tLo, tHi}, {uLo, uHi}},
    Frame -> True,
    FrameStyle -> Directive[Black, AbsoluteThickness[1.2], 12],
    FrameLabel -> {{Style[\"U / csL\", 13, Bold], None}, {None, None}},
    FrameTicksStyle -> Directive[Black, 10],
    Epilog -> tsEpilog[uLo, uHi],
    GridLines -> Automatic,
    GridLinesStyle -> Directive[GrayLevel[0.9], AbsoluteThickness[0.3]],
    ImageSize -> {700, 160}, ImagePadding -> {{60, 20}, {5, 15}},
    Background -> White
  ];

  rTEk = If[nRetro > 0,
    Module[{pts},
      pts = Table[Module[{tStar = retroData[[k, 6]],
        uocsL = Re[retroData[[k, 4]]],
        uHsq = If[Length[retroData[[k]]] >= 8, retroData[[k, 7]], 0],
        uVsq = If[Length[retroData[[k]]] >= 8, retroData[[k, 8]], 0], kshVal},
        kshVal = retroData[[k, 1]];
        {tStar, Max[0, 0.5*kshVal^2*(uHsq + uVsq)*Abs[uocsL]]}
      ], {k, Length[retroData]}];
      Select[pts, tLo < #[[1]] < tHi && #[[2]] > 0 &]], {}];
  pTEk = If[nPro > 0,
    Module[{pts},
      pts = Table[Module[{tStar = proData[[k, 6]],
        uocsL = Re[proData[[k, 4]]],
        uHsq = If[Length[proData[[k]]] >= 8, proData[[k, 7]], 0],
        uVsq = If[Length[proData[[k]]] >= 8, proData[[k, 8]], 0], kshVal},
        kshVal = proData[[k, 1]];
        {tStar, Max[0, 0.5*kshVal^2*(uHsq + uVsq)*Abs[uocsL]]}
      ], {k, Length[proData]}];
      Select[pts, tLo < #[[1]] < tHi && #[[2]] > 0 &]], {}];

  Print[\"  Ek* points: Retro=\", Length[rTEk], \" Pro=\", Length[pTEk]];

  panelEk = ListLogPlot[
    Select[{rTEk, pTEk}, Length[#] > 0 &],
    PlotStyle -> {
      Directive[retroC3, AbsolutePointSize[3]],
      Directive[proC3, AbsolutePointSize[3]]},
    PlotRange -> {{tLo, tHi}, All},
    ScalingFunctions -> {\"Log\", \"Log\"},
    Frame -> True,
    FrameStyle -> Directive[Black, AbsoluteThickness[1.2], 12],
    FrameLabel -> {{Style[\"Ek* (log)\", 13, Bold], None},
                   {Style[\"T* (dimensionless period)\", 13, Bold], None}},
    FrameTicksStyle -> Directive[Black, 10],
    GridLines -> Automatic,
    GridLinesStyle -> Directive[GrayLevel[0.9], AbsoluteThickness[0.3]],
    ImageSize -> {700, 180}, ImagePadding -> {{60, 20}, {40, 5}},
    Background -> White
  ];

  figGoalDimless = GraphicsColumn[{panelHV, panelU, panelEk},
    Spacings -> 0,
    PlotLabel -> Style[
      \"H/V, U & Ek vs Period \[Dash] Dimensionless\\n\" <> titleStr, 11, \
Bold],
    ImageSize -> 750
  ];

  Print[figGoalDimless];
  Export[\"FigGoal_HV_U_Ek_period.pdf\", figGoalDimless, ImageResolution -> \
300];
  Print[\"  Exported: FigGoal_HV_U_Ek_period.pdf\"];
];

\
\>", "Input",ExpressionUUID->"3150f533-d138-cb49-8ab8-24be04368679"],

Cell["\<\
(* ================================================================ *)
(* DIMENSIONLESS BASELINE FOR PARTS B & C                           *)
(*                                                                    *)
(* The dimensionless dispersion relation depends ONLY on material     *)
(* ratios (\[Nu]L, halfspace properties). Changing Vs and h merely   *)
(* rescales the dimensional axes. Therefore this single figure is     *)
(* the common dimensionless baseline for ALL Vs and h combinations.  *)
(* ================================================================ *)

Print[\"\\n  DIMENSIONLESS BASELINE (common to all Vs, h)\"];
Print[\"  ================================================================\"];
Print[\"  Note: Dimensionless dispersion is independent of Vs and h.\"];
Print[\"  Parts B and C are dimensional rescalings of this single curve.\"];

Module[{rTHVbl, pTHVbl, rTUbl, pTUbl, rTUscBL, pTUscBL,
        tLo = 0.2, tHi = 15, hvLo = 0, hvHi = 30,
        uLo = -1, uHi = 6, scaleU, rightTicks, figBaseline},

  scaleU[u_] := hvLo + (u - uLo)/(uHi - uLo)*(hvHi - hvLo);
  rightTicks = Table[{scaleU[v], v}, {v, 0, uHi, 1}];

  rTHVbl = If[nRetro > 0,
    Select[Transpose[{retroData[[All, 6]], retroData[[All, 5]]}],
      tLo < #[[1]] < tHi && 0 < #[[2]] < hvHi &], {{-1, -1}}];
  pTHVbl = If[nPro > 0,
    Select[Transpose[{proData[[All, 6]], proData[[All, 5]]}],
      tLo < #[[1]] < tHi && 0 < #[[2]] < hvHi &], {{-1, -1}}];
  rTUbl = If[nRetro > 0,
    Select[Transpose[{retroData[[All, 6]], retroData[[All, 4]]}],
      tLo < #[[1]] < tHi && uLo <= #[[2]] <= uHi &], {{-1, -1}}];
  pTUbl = If[nPro > 0,
    Select[Transpose[{proData[[All, 6]], proData[[All, 4]]}],
      tLo < #[[1]] < tHi && uLo <= #[[2]] <= uHi &], {{-1, -1}}];
  rTUscBL = If[Length[rTUbl] > 0 && rTUbl =!= {{-1, -1}},
    {#[[1]], scaleU[#[[2]]]} & /@ rTUbl, {{-1, -1}}];
  pTUscBL = If[Length[pTUbl] > 0 && pTUbl =!= {{-1, -1}},
    {#[[1]], scaleU[#[[2]]]} & /@ pTUbl, {{-1, -1}}];

  figBaseline = Quiet[ListLogLinearPlot[{rTHVbl, pTHVbl, rTUscBL, pTUscBL},
    PlotStyle -> {
      Directive[Black, AbsolutePointSize[2.5]],
      Directive[Red, AbsolutePointSize[2.5]],
      Directive[RGBColor[0.12, 0.47, 0.71], AbsolutePointSize[2], \
Opacity[0.45]],
      Directive[RGBColor[0.55, 0, 0.55], AbsolutePointSize[2], Opacity[0.45]]},
    PlotRange -> {{tLo, tHi}, {hvLo, hvHi}},
    Frame -> True,
    FrameStyle -> Directive[Black, AbsoluteThickness[1.5], 13],
    FrameTicksStyle -> Directive[Black, 11],
    FrameTicks -> {{Automatic, rightTicks}, {Automatic, None}},
    FrameLabel -> {
      {Style[\"H/V Ratio\", 14, Bold], Style[\"Group Velocity, U/csL\", 14, \
Bold]},
      {Style[\"T* (dimensionless period)\", 14, Bold], None}},
    Epilog -> Module[{sC = Darker[Green, 0.3], pC = RGBColor[0.85, 0.45, 0]},
      {{sC, AbsoluteThickness[2.5],
        Line[{{Log[Ts], hvLo}, {Log[Ts], hvHi}}],
        Inset[Framed[Style[\"Ts*=\" <> ToString[NumberForm[N[Ts], {4, 2}]],
          8, sC, Bold], Background -> Directive[White, Opacity[0.85]],
          FrameStyle -> sC, RoundingRadius -> 3],
          {Log[Ts], hvHi * 0.7}, {0, 0}]},
       {pC, AbsoluteThickness[2.5], Dashed,
        Line[{{Log[Tp], hvLo}, {Log[Tp], hvHi}}],
        Inset[Framed[Style[\"Tp*=\" <> ToString[NumberForm[N[Tp], {4, 2}]],
          8, pC, Bold], Background -> Directive[White, Opacity[0.85]],
          FrameStyle -> pC, RoundingRadius -> 3],
          {Log[Tp], hvHi * 0.85}, {0, 0}]},
       (* Note about invariance *)
       Inset[Framed[Style[
         \"Dimensionless\\n\[Nu]L = \" <> ToString[\[Nu]L] <>
         \"\\nInvariant under Vs, h scaling\",
         9, Black, Bold],
         Background -> Directive[LightYellow, Opacity[0.95]],
         FrameStyle -> Directive[GrayLevel[0.4], AbsoluteThickness[1.5]],
         RoundingRadius -> 5],
         {Log[tHi * 0.6], hvHi * 0.3}, {0, 0}]
      }],
    GridLines -> Automatic,
    GridLinesStyle -> Directive[GrayLevel[0.85], AbsoluteThickness[0.5]],
    PlotLabel -> Style[\"Dimensionless: H/V & U/csL vs T*\\n\[Nu]L=\" <>
      ToString[\[Nu]L] <> \" (common to all Parts B & C)\", 10, Bold],
    PlotLegends -> Placed[PointLegend[
      {Black, Red, Directive[RGBColor[0.12, 0.47, 0.71], Opacity[0.45]],
       Directive[RGBColor[0.55, 0, 0.55], Opacity[0.45]]},
      {Style[\"Retro H/V\", 10], Style[\"Pro H/V\", 10],
       Style[\"Retro U/csL\", 10], Style[\"Pro U/csL\", 10]},
      LegendMarkerSize -> 8, LegendLayout -> \"Column\"], {Right, Top}],
    ImageSize -> 750, ImagePadding -> {{70, 80}, {55, 65}},
    Background -> White, AspectRatio -> 0.6
  ]];

  showFig[figBaseline];
  Export[\"FigBaseline_C1_Dimensionless_HV_U.pdf\", figBaseline, \
ImageResolution -> 300];
  Print[\"  Exported: FigBaseline_C1_Dimensionless_HV_U.pdf\"];
];


\
\>", "Input",ExpressionUUID->"4991f49b-76ee-1943-9997-b7d01d0b06cb"],

Cell["\<\
(* ================================================================ *)\
\>", "Input",ExpressionUUID->"4d81e387-97d2-b44a-8568-769087da2b38"],

Cell["\<\
(* 18. PARAMETRIC STUDY: THREE-VARIABLE SWEEP                       *)
(* ================================================================ *)
(*                                                                    *)
(*  LAYER (identical in Case 1 and Case 2):                          *)
(*    \[Mu]L  = 1, \[Rho]L = 1, h = 1  (dimensionless)             *)
(*    \[Nu]L  swept over nuStudy                                     *)
(*                                                                    *)
(*  HALFSPACE: Rigid (u=0 at base)                                            \
*)
(*                                                                    *)
(*  ---- VARIABLES (modify these lists to change the sweep) ----     *)
(*                                                                    *)
(*    nuStudy : Poisson ratio values for the LAYER                   *)
(*              Each value requires FULL root-finding (~15-30 min)   *)
(*              because \[Nu]L changes the boundary condition matrix *)
(*                                                                    *)
(*    csStudy : Layer shear-wave velocity values (m/s)               *)
(*              Only rescales frequency axis (instant)               *)
(*              f(Hz) = cs * ksh / (2\[Pi] * h)                     *)
(*                                                                    *)
(*    hStudy  : Layer thickness values (m)                           *)
(*              Only rescales frequency axis (instant)               *)
(*              f(Hz) = cs * ksh / (2\[Pi] * h)                     *)
(*                                                                    *)
(*    Total combinations: len(nu) * len(cs) * len(h)                *)
(*    Total expensive sweeps: len(nu) only                           *)
(*                                                                    *)
(*  NOTE: cs and h appear only in the dimensional conversion.       *)
(*  The dimensionless dispersion (c/csL, U/csL, H/V vs kh) is      *)
(*  IDENTICAL for all cs and h. Therefore varying cs or h produces  *)
(*  the same curve shape shifted along the frequency axis.          *)
(*  This is correct and expected.                                    *)\
\>", "Input",ExpressionUUID->"a1c6b9e5-c140-4a47-945d-23c1ec3df340"],

Cell["\<\
(* ================================================================ *)

nuStudy = {0.25, 0.35, 0.49};
csStudy = {50, 250, 450};
hStudy  = {10, 30, 100};
\[Rho]LDimParam = 1800.0;

Print[\"\\n================================================================\"];
Print[\"  PARAMETRIC STUDY: 3-Variable Sweep\"];
Print[\"  LAYER (same in both cases): \[Mu]L=1, \[Rho]L=1, h=1\"];
Print[\"  \[Nu]L = \", nuStudy];
Print[\"  cs  = \", csStudy, \" m/s\"];
Print[\"  h   = \", hStudy, \" m\"];
Print[\"  HALFSPACE: Rigid (u=0 at base)\"];
Print[\"  Total combinations: \", \
Length[nuStudy]*Length[csStudy]*Length[hStudy]];
Print[\"================================================================\\n\"];

(* Save original parameters *)
origNuL  = \[Nu]L;
origLamL = \[Lambda]L;
origCpL  = cpL;
origCsL  = csL;
origTs   = Ts;
origTp   = Tp;
origDetCompiled = detCompiled;


Do[Module[{nuVal = nuStudy[[inu]], tNuStart,
    retroDataNu, proDataNu, retroDataFNu, proDataFNu,
    nRetroNu, nProNu, nDispNu},
  
  Print[\"\\n  ================================================\"];
  Print[\"  \[Nu]L = \", nuVal, \" (\", inu, \"/\", Length[nuStudy], \")\"];
  Print[\"  ================================================\"];
  tNuStart = AbsoluteTime[];
  
  (* ---- Recompute material for this \[Nu] ---- *)
  \[Nu]L = nuVal;
  \[Lambda]L = 2*\[Nu]L*\[Mu]L/(1 - 2*\[Nu]L);
  cpL = Sqrt[(\[Lambda]L + 2*\[Mu]L)/\[Rho]L];
  Ts = 4*h/csL;
  Tp = 4*h/cpL;
  
  Print[\"    \[Lambda]L = \", NumberForm[\[Lambda]L, {6, 3}],
        \"  cpL/csL = \", NumberForm[cpL/csL, {5, 3}]];
  
  (* ---- Recompile 4\[Times]4 determinant for this \[Nu] ---- *)
  Print[\"    Recompiling 4\[Times]4 determinant...\"];
  Module[{symDetA},
    symDetA = Block[{c, cocpL, cocsL, pL, qL, pLkh, qLkh, mat},
      c = N[csL]*ksVar/kiVar;
      cocpL = c/N[cpL]; cocsL = c/N[csL];
      pL = Sqrt[1 - cocpL^2]; qL = Sqrt[1 - cocsL^2];
      pLkh = pL*kiVar; qLkh = qL*kiVar;
      mat = {
        {Sinh[pLkh], Cosh[pLkh], -I*Cosh[qLkh], -I*Sinh[qLkh]},
        {pL*Cosh[pLkh], pL*Sinh[pLkh], I*qL*Sinh[qLkh], I*qL*Cosh[qLkh]},
        {(N[\[Lambda]L/\[Mu]L]*(pL^2 - 1) + 2*pL^2)*Cosh[pLkh],
         (N[\[Lambda]L/\[Mu]L]*(pL^2 - 1) + 2*pL^2)*Sinh[pLkh],
         -2*I*qL*Sinh[qLkh], -2*I*qL*Cosh[qLkh]},
        {2*I*pL*Sinh[pLkh], 2*I*pL*Cosh[pLkh],
         (1 + qL^2)*Cosh[qLkh], (1 + qL^2)*Sinh[qLkh]}
      };
      Det[mat]
    ];
    detCompiled = Compile[{{ksVar, _Complex}, {kiVar, _Complex}},
      Evaluate[symDetA], RuntimeOptions -> \"Speed\"];
  ];
  
  (* ---- Root-finding sweep ---- *)
  Print[\"    Root-finding (\", ni, \"\[Times]\", nj, \")...\"];
  
  {rawNU, {dispTagNU, shearTagNU, pressTagNU,
           retroTagNU, proTagNU, zeroTagNU, mixTagNU}} = Reap[
    Do[Module[{khI = khVec[[i]]},
      Do[Module[{kshJ0 = kshVec[[j]], sol, x, cocsLTest, cocpLTest, f, pp},
        sol = Quiet[Check[
          FindRoot[detEval[ksh, kh], {{ksh, kshJ0}, {kh, khI}},
            Method -> \"Newton\", WorkingPrecision -> MachinePrecision,
            AccuracyGoal -> 6, PrecisionGoal -> 6, MaxIterations -> 100],
          $Failed, {FindRoot::cvmit, FindRoot::lstol, FindRoot::jsing}],
          {FindRoot::cvmit, FindRoot::lstol, FindRoot::jsing,
           Power::infy, Infinity::indet}];
        If[sol =!= $Failed && ListQ[sol] && FreeQ[sol, FindRoot | $Failed],
          x = {ksh, kh} /. sol;
          If[And[NumericQ[x[[1]]], NumericQ[x[[2]]],
                 Re[x[[1]]] > 0, Re[x[[2]]] > 0,
                 Abs[Im[x[[1]]]] < 10^-10, Abs[Im[x[[2]]]] < 10^-10],
            x = Re[x];
            f = detEval[x[[1]], x[[2]]];
            If[Sqrt[f[[1]]^2 + f[[2]]^2] > 10^-6, Continue[]];
            cocsLTest = x[[1]]/x[[2]];
            cocpLTest = csL*x[[1]]/(x[[2]]*cpL);
            If[cocsLTest < 0.5 || cocsLTest > 4.0, Continue[]];
            Which[
              Abs[cocsLTest - 1] < 10^-4,
              Sow[{x[[1]], x[[2]], cocsLTest}, \"shear\"],
              Abs[cocpLTest - 1] < 10^-4,
              Sow[{x[[1]], x[[2]], cocsLTest}, \"press\"],
              True,
              pp = Quiet[postProcess[x[[1]], x[[2]]]];
              If[pp =!= $Failed && AssociationQ[pp],
                Which[
                  pp[\"iretro\"] > 0.5,
                  Sow[{pp[\"ksh\"], pp[\"kh\"], pp[\"cocsL\"], pp[\"UocsL\"],
                       pp[\"HoV\"], pp[\"T\"], pp[\"uHsq\"], pp[\"uVsq\"],
                       pp[\"delta\"], pp[\"theta\"]}, \"retro\"],
                  pp[\"iretro\"] < -0.5,
                  Sow[{pp[\"ksh\"], pp[\"kh\"], pp[\"cocsL\"], pp[\"UocsL\"],
                       pp[\"HoV\"], pp[\"T\"], pp[\"uHsq\"], pp[\"uVsq\"],
                       pp[\"delta\"], pp[\"theta\"]}, \"pro\"],
                  True,
                  Sow[{pp[\"ksh\"], pp[\"kh\"], pp[\"cocsL\"], pp[\"UocsL\"],
                       pp[\"HoV\"], pp[\"T\"], pp[\"uHsq\"], pp[\"uVsq\"],
                       pp[\"delta\"], pp[\"theta\"]}, \"zero\"]
                ];
              ];
            ];
          ];
        ];
      ], {j, 1, nj}];
    ], {i, 1, ni}],
    {\"disp\", \"shear\", \"press\", \"retro\", \"pro\", \"zero\", \"mix\"}
  ];
  
  getData[tag_] := If[Length[tag] > 0, tag[[1]], {}];
  retroDataNu = getData[retroTagNU];
  proDataNu   = getData[proTagNU];
  nRetroNu = Length[retroDataNu];
  nProNu   = Length[proDataNu];
  nDispNu  = nRetroNu + nProNu;
  
  retroDataFNu = Select[retroDataNu, -2.0 < #[[4]] < 6.0 &];
  proDataFNu   = Select[proDataNu, -2.0 < #[[4]] < 6.0 &];
  
  Print[\"    Roots: Retro=\", nRetroNu, \" Pro=\", nProNu,
        \" (filtered: \", Length[retroDataFNu], \"/\", Length[proDataFNu], \
\")\"];
  Print[\"    Time: \", NumberForm[(AbsoluteTime[] - tNuStart)/60, {4, 1}], \
\" min\"];
  
  (* ---- Store for combined overlay plots ---- *)
  paramCdata[inu] = If[Length[retroDataFNu] > 0,
    Transpose[{retroDataFNu[[All, 2]], retroDataFNu[[All, 3]]}], {}];
  paramUdata[inu] = If[Length[retroDataFNu] > 0,
    Transpose[{retroDataFNu[[All, 2]], retroDataFNu[[All, 4]]}], {}];
  paramRetroAll[inu] = retroDataNu;
  paramRetroFAll[inu] = retroDataFNu;
  paramNRetro[inu] = nRetroNu;

  (* ==== cs \[CapitalATilde]\.97 h loop: dimensional rescaling ==== *)
  Do[Do[Module[{csVal = csStudy[[ics]], hVal = hStudy[[ih]],
      vpVal, fsVal, fpVal, lamLdim,
      rFHV, pFHV, rFU, pFU, rFUsc, pFUsc,
      rTHV, pTHV, rTU, pTU, rTUsc, pTUsc,
      fMax, uMax, tMax,
      scaleU, rightTks,
      paramStr, titleStr, figPf, figPt},
    
    (* Skip physically unrealistic combinations *)
    If[nuVal >= 0.49 && csVal > 50,
      Print[\"    Skipping cs=\", csVal, \" for nu=\", nuVal, \" \
(unrealistic)\"];
      Return[]];
    
    vpVal = csVal * (cpL/csL);
    fsVal = csVal/(4*hVal);
    fpVal = vpVal/(4*hVal);
    (* Dimensional lambda for title *)
    lamLdim = \[Lambda]L;  (* dimensionless, shows effect of nu *)
    
    (* Auto-scale axes to cs and h values *)
    fMax = Max[12*fsVal, 5];
    uMax = Max[3*csVal, 50];
    tMax = Min[5/fsVal, 10];
    fRng = {0.01, fMax};
    tRng = {0.01, tMax};
    hvRng = {0, 30};
    uRng = {0, uMax};
    
    Print[\"      cs=\", csVal, \" m/s, h=\", hVal, \" m  (fs=\", 
          NumberForm[fsVal, {5, 2}], \" Hz, fMax=\", 
          NumberForm[fMax, {4, 1}], \", uMax=\", 
          NumberForm[uMax, {5, 0}], \")\"];
    
    (* ---- Build frequency-domain data ---- *)
    (* f(Hz) = cs * ksh / (2 Pi h) *)
    (* T(s) = 2 Pi h / (cs * ksh) *)
    rFHV = If[nRetroNu > 0,
      Select[Transpose[{csVal*retroDataNu[[All, 1]]/(2*Pi*hVal), 
                         retroDataNu[[All, 5]]}],
        fRng[[1]] <= #[[1]] <= fRng[[2]] && 0 < #[[2]] < hvRng[[2]] &], \
{{-1,-1}}];
    pFHV = If[nProNu > 0,
      Select[Transpose[{csVal*proDataNu[[All, 1]]/(2*Pi*hVal), 
                         proDataNu[[All, 5]]}],
        fRng[[1]] <= #[[1]] <= fRng[[2]] && 0 < #[[2]] < hvRng[[2]] &], \
{{-1,-1}}];
    
    rFU = If[Length[retroDataFNu] > 0,
      Select[Transpose[{csVal*retroDataFNu[[All, 1]]/(2*Pi*hVal), 
                         csVal*retroDataFNu[[All, 4]]}],
        fRng[[1]] <= #[[1]] <= fRng[[2]] &], {{-1,-1}}];
    pFU = If[Length[proDataFNu] > 0,
      Select[Transpose[{csVal*proDataFNu[[All, 1]]/(2*Pi*hVal), 
                         csVal*proDataFNu[[All, 4]]}],
        fRng[[1]] <= #[[1]] <= fRng[[2]] &], {{-1,-1}}];
    
    scaleU[u_] := hvRng[[1]] + (u - uRng[[1]])/(uRng[[2]] - uRng[[1]]) * \
(hvRng[[2]] - hvRng[[1]]);
    rFUsc = If[Length[rFU] > 0 && rFU =!= {{-1,-1}}, 
      {#[[1]], scaleU[#[[2]]]} & /@ rFU, {{-1,-1}}];
    pFUsc = If[Length[pFU] > 0 && pFU =!= {{-1,-1}}, 
      {#[[1]], scaleU[#[[2]]]} & /@ pFU, {{-1,-1}}];
    rightTks = Table[{scaleU[v], v}, {v, 0, uRng[[2]], \
Max[Round[uRng[[2]]/5], 10]}];
    
    paramStr = \"\[Nu]L=\" <> ToString[nuVal] <> 
      \", cs=\" <> ToString[csVal] <> \" m/s\" <>
      \", h=\" <> ToString[hVal] <> \" m\";
    titleStr = \"H/V & U vs Frequency \[Dash] h = \" <> ToString[hVal] <> \" \
m, VsL = \" <> ToString[Round[csVal]] <> \" m/s\\n\" <>
      \"\[Nu]L=\" <> ToString[nuVal] <> \", \[Lambda]L=\" <> \
ToString[NumberForm[lamLdim, {5, 3}]] <>
      \", fs=\" <> ToString[NumberForm[fsVal, {4, 2}]] <> \" Hz\" <>
      \", Ts=\" <> ToString[NumberForm[1/fsVal, {4, 3}]] <> \" s\";
    
    (* ---- FIGURE vs FREQUENCY ---- *)
    figPf = Quiet[ListPlot[{rFHV, pFHV, rFUsc, pFUsc},
      PlotStyle -> {
        Directive[Black, AbsolutePointSize[4]],
        Directive[RGBColor[0.84, 0.15, 0.16], AbsolutePointSize[4]],
        Directive[RGBColor[0.12, 0.47, 0.71], AbsolutePointSize[3.5], \
Opacity[0.45]],
        Directive[RGBColor[0.55, 0.0, 0.55], AbsolutePointSize[3.5], \
Opacity[0.45]]},
      PlotRange -> {{fRng[[1]], fRng[[2]]}, hvRng},
      Frame -> True,
      FrameStyle -> Directive[Black, AbsoluteThickness[1.5], 13],
      FrameTicksStyle -> Directive[Black, 11],
      FrameTicks -> {{Automatic, rightTks}, {Automatic, None}},
      FrameLabel -> {
        {Style[\"H/V Ratio\", 14, Bold], Style[\"Group Velocity, U (m/s)\", \
14, Bold]},
        {Style[\"Frequency, f (Hz)\", 14, Bold], None}},
      Epilog -> {},
      GridLines -> Automatic,
      GridLinesStyle -> Directive[GrayLevel[0.85], AbsoluteThickness[0.5]],
      PlotLabel -> Style[titleStr, 10],
      PlotLegends -> Placed[PointLegend[
        {Black, RGBColor[0.84, 0.15, 0.16], 
         RGBColor[0.12, 0.47, 0.71], RGBColor[0.0, 0.6, 0.0]}, 
        {Style[\"Retro H/V\", 9], Style[\"Pro H/V\", 9],
         Style[\"Retro U\", 9], Style[\"Pro U\", 9]},
        LegendMarkerSize -> 7, LegendLayout -> \"Column\"], {Right, Top}],
      ImageSize -> 750, ImagePadding -> {{70, 80}, {55, 65}},
      Background -> White, AspectRatio -> 0.6
    ]];
    If[MatchQ[figPf, _Graphics | _Legended], Print[figPf]];
    Export[\"FigParam_nu\" <> ToString[nuVal] <> 
      \"_cs\" <> ToString[csVal] <> \"_h\" <> ToString[hVal] <> \"_freq.pdf\", 
      figPf, ImageResolution -> 300];
    
    (* ---- FIGURE vs PERIOD ---- *)
    (* T = 2*Pi*h / (cs * ksh) *)
    rTHV = If[nRetroNu > 0,
      Select[Transpose[{2*Pi*hVal/(csVal*retroDataNu[[All, 1]]), \
retroDataNu[[All, 5]]}],
        tRng[[1]] <= #[[1]] <= tRng[[2]] && 0 < #[[2]] < hvRng[[2]] &], \
{{-1,-1}}];
    pTHV = If[nProNu > 0,
      Select[Transpose[{2*Pi*hVal/(csVal*proDataNu[[All, 1]]), \
proDataNu[[All, 5]]}],
        tRng[[1]] <= #[[1]] <= tRng[[2]] && 0 < #[[2]] < hvRng[[2]] &], \
{{-1,-1}}];
    rTU = If[Length[retroDataFNu] > 0,
      Select[Transpose[{2*Pi*hVal/(csVal*retroDataFNu[[All, 1]]), \
csVal*retroDataFNu[[All, 4]]}],
        tRng[[1]] <= #[[1]] <= tRng[[2]] &], {{-1,-1}}];
    pTU = If[Length[proDataFNu] > 0,
      Select[Transpose[{2*Pi*hVal/(csVal*proDataFNu[[All, 1]]), \
csVal*proDataFNu[[All, 4]]}],
        tRng[[1]] <= #[[1]] <= tRng[[2]] &], {{-1,-1}}];
    rTUsc = If[Length[rTU] > 0 && rTU =!= {{-1,-1}}, 
      {#[[1]], scaleU[#[[2]]]} & /@ rTU, {{-1,-1}}];
    pTUsc = If[Length[pTU] > 0 && pTU =!= {{-1,-1}}, 
      {#[[1]], scaleU[#[[2]]]} & /@ pTU, {{-1,-1}}];
    
    figPt = Quiet[ListPlot[{rTHV, pTHV, rTUsc, pTUsc},
      PlotStyle -> {
        Directive[Black, AbsolutePointSize[4]],
        Directive[RGBColor[0.84, 0.15, 0.16], AbsolutePointSize[4]],
        Directive[RGBColor[0.12, 0.47, 0.71], AbsolutePointSize[3.5], \
Opacity[0.45]],
        Directive[RGBColor[0.55, 0.0, 0.55], AbsolutePointSize[3.5], \
Opacity[0.45]]},
      PlotRange -> {{tRng[[1]], tRng[[2]]}, hvRng},
      Frame -> True,
      FrameStyle -> Directive[Black, AbsoluteThickness[1.5], 13],
      FrameTicksStyle -> Directive[Black, 11],
      FrameTicks -> {{Automatic, rightTks}, {Automatic, None}},
      FrameLabel -> {
        {Style[\"H/V Ratio\", 14, Bold], Style[\"Group Velocity, U (m/s)\", \
14, Bold]},
        {Style[\"Period, T (s)\", 14, Bold], None}},
      Epilog -> {},
      GridLines -> Automatic,
      GridLinesStyle -> Directive[GrayLevel[0.85], AbsoluteThickness[0.5]],
      PlotLabel -> Style[\"H/V & U vs Period \[Dash] h = \" <> ToString[hVal] \
<> \" m, VsL = \" <> ToString[Round[csVal]] <> \" m/s\\n\" <>
        \"\[Nu]L=\" <> ToString[nuVal] <> \", \[Lambda]L=\" <> \
ToString[NumberForm[lamLdim, {5, 3}]] <>
        \", Ts=\" <> ToString[NumberForm[1/fsVal, {4, 3}]] <> \" s\" <>
        \", fs=\" <> ToString[NumberForm[fsVal, {4, 2}]] <> \" Hz\", 10],
      PlotLegends -> Placed[PointLegend[
        {Black, RGBColor[0.84, 0.15, 0.16], 
         RGBColor[0.12, 0.47, 0.71], RGBColor[0.0, 0.6, 0.0]}, 
        {Style[\"Retro H/V\", 9], Style[\"Pro H/V\", 9],
         Style[\"Retro U\", 9], Style[\"Pro U\", 9]},
        LegendMarkerSize -> 7, LegendLayout -> \"Column\"], {Right, Top}],
      ImageSize -> 750, ImagePadding -> {{70, 80}, {55, 65}},
      Background -> White, AspectRatio -> 0.6
    ]];
    If[MatchQ[figPt, _Graphics | _Legended], Print[figPt]];
    Export[\"FigParam_nu\" <> ToString[nuVal] <> 
      \"_cs\" <> ToString[csVal] <> \"_h\" <> ToString[hVal] <> \"_period.pdf\
\", 
      figPt, ImageResolution -> 300];
    
  ], {ih, Length[hStudy]}], {ics, Length[csStudy]}];


  Print[\"    \[Nu]L=\", nuVal, \" complete.\"];
], {inu, Length[nuStudy]}];

(* ---- Restore original parameters ---- *)
\[Nu]L = origNuL;
\[Lambda]L = origLamL;
cpL = origCpL;
csL = origCsL;
Ts = origTs;
Tp = origTp;
detCompiled = origDetCompiled;

Print[\"  Original parameters restored.\"];
Print[\"  Parametric study complete: \", \
Length[nuStudy]*Length[csStudy]*Length[hStudy], \" combinations.\\n\"];

\
\>", "Input",ExpressionUUID->"a1e3dc8a-0781-9344-b488-d0a022472066"],

Cell["\<\
(* ================================================================ *)\
\>", "Input",ExpressionUUID->"5ef37c26-7f28-424a-8e97-a0e00546eb22"],

Cell["\<\
(* 19. COMBINED PARAMETRIC OVERLAY PLOTS                             *)
(*     Show[] overlays: vary ONE variable, fix the other two        *)
(*     Each curve LABELED with its parameter value                  *)
(*                                                                    *)
(*  19a. Vary \[Nu]L: c/csL, U/csL vs kh (dimensionless)           *)
(*  19b. Vary cs:     H/V + U vs frequency                          *)
(*  19c. Vary h:      H/V + U vs frequency                          *)
(*                                                                    *)
(*  NOTE on self-similarity: Changing cs or h only rescales the     *)
(*  frequency axis (f = cs*ksh/(2*Pi*h)). The dimensionless curves  *)
(*  are identical because ksh and c/csL, U/csL, H/V do not depend  *)
(*  on cs or h. Therefore the combined plots show the SAME curve    *)
(*  shape shifted horizontally. This is correct physics.            *)
(* ================================================================ *)

Print[\"\\n================================================================\"];
Print[\"  COMBINED OVERLAY PLOTS (Rigid (u=0 at base))\"];
Print[\"================================================================\\n\"];

Module[{nuColors, csColors, hColors},
  
  nuColors = {RGBColor[0.12, 0.47, 0.71], RGBColor[0.84, 0.15, 0.16], \
RGBColor[0.0, 0.6, 0.0]};
  csColors = {RGBColor[0.8, 0.4, 0.0], RGBColor[0.12, 0.47, 0.71], \
RGBColor[0.55, 0.0, 0.55]};
  hColors  = {RGBColor[0.0, 0.6, 0.0], RGBColor[0.12, 0.47, 0.71], \
RGBColor[0.84, 0.15, 0.16]};
  
  (* ---- 19a: Vary nu (dimensionless) ---- *)
  Print[\"  19a: Vary \[Nu]L\"];
  
  Module[{figVC},
    figVC = Show[
      Table[If[Length[paramCdata[i]] > 0,
        ListPlot[Select[paramCdata[i], 0 < #[[1]] <= 8 && 0 < #[[2]] <= 4 &],
          PlotStyle -> Directive[nuColors[[i]], AbsolutePointSize[1.5]]],
        Graphics[]], {i, Length[nuStudy]}],
      Frame -> True,
      FrameStyle -> Directive[Black, AbsoluteThickness[1.5], 13],
      FrameLabel -> {Style[\"kh\", 14, Bold], Style[\"c / csL\", 14, Bold]},
      PlotLabel -> Style[\"Phase Velocity c/csL vs kh \[LongDash] Effect of \
\[Nu]L\\nRigid Halfspace, \[Mu]L=\" <> ToString[\[Mu]L] <> \", \[Rho]L=\" <> \
ToString[\[Rho]L] <> \", h=\" <> ToString[h], 11],
      PlotRange -> {{0, 8}, {0.5, 4}},
      GridLines -> Automatic,
      GridLinesStyle -> Directive[GrayLevel[0.85], AbsoluteThickness[0.5]],
      PlotLegends -> Placed[SwatchLegend[nuColors[[;;Length[nuStudy]]],
        Style[\"\[Nu]=\" <> ToString[#], 11] & /@ nuStudy, LegendMarkerSize \
-> 12], {Right, Top}],
      ImageSize -> 750, ImagePadding -> {{60, 120}, {55, 55}},
      Background -> White, AspectRatio -> 0.65];
    If[MatchQ[figVC, _Graphics | _Legended], Print[figVC]];
    Export[\"FigComb_vary_nu_c_vs_kh.pdf\", figVC, ImageResolution -> 300];
  ];
  
  Module[{figVU},
    figVU = Show[
      Table[If[Length[paramUdata[i]] > 0,
        ListPlot[Select[paramUdata[i], 0 < #[[1]] <= 8 && -1 <= #[[2]] <= 6 &],
          PlotStyle -> Directive[nuColors[[i]], AbsolutePointSize[1.5]]],
        Graphics[]], {i, Length[nuStudy]}],
      Frame -> True,
      FrameStyle -> Directive[Black, AbsoluteThickness[1.5], 13],
      FrameLabel -> {Style[\"kh\", 14, Bold], Style[\"U / csL\", 14, Bold]},
      PlotLabel -> Style[\"Group Velocity U/csL vs kh \[LongDash] Effect of \
\[Nu]L\\nRigid Halfspace, \[Mu]L=\" <> ToString[\[Mu]L] <> \", \[Rho]L=\" <> \
ToString[\[Rho]L] <> \", h=\" <> ToString[h], 11],
      PlotRange -> {{0, 8}, {-1, 6}},
      GridLines -> Automatic,
      GridLinesStyle -> Directive[GrayLevel[0.85], AbsoluteThickness[0.5]],
      PlotLegends -> Placed[SwatchLegend[nuColors[[;;Length[nuStudy]]],
        Style[\"\[Nu]=\" <> ToString[#], 11] & /@ nuStudy, LegendMarkerSize \
-> 12], {Right, Top}],
      ImageSize -> 750, ImagePadding -> {{60, 120}, {55, 55}},
      Background -> White, AspectRatio -> 0.65];
    If[MatchQ[figVU, _Graphics | _Legended], Print[figVU]];
    Export[\"FigComb_vary_nu_U_vs_kh.pdf\", figVU, ImageResolution -> 300];
  ];
  
  Print[\"  Exported: 2 combined nu-overlay figures\\n\"];
  
  (* ---- 19b: Vary cs (fix nu=nuStudy[[1]], h=hStudy[[2]]) ---- *)
  Module[{inu0 = 1, ih0 = 2, hFix, nuFix, 
          fRng, hvRng = {0, 30}, uRng, scaleU, rightTks,
          hvPlots, uPlots, figVcs},
    nuFix = nuStudy[[inu0]]; hFix = hStudy[[ih0]];
    (* Auto-scale to largest cs *)
    fRng = {0.01, Max[12*Max[csStudy]/(4*hFix), 5]};
    uRng = {0, Max[csStudy]*3};
    Print[\"  19b: Vary cs (fix \[Nu]=\", nuFix, \", h=\", hFix, \" m)\"];
    scaleU[u_] := hvRng[[1]] + (u - uRng[[1]])/(uRng[[2]] - uRng[[1]]) * \
(hvRng[[2]] - hvRng[[1]]);
    rightTks = Table[{scaleU[v], v}, {v, 0, uRng[[2]], \
Max[Round[uRng[[2]]/5], 10]}];
    
    hvPlots = Table[Module[{csV = csStudy[[ics]], rFHV},
      rFHV = If[paramNRetro[inu0] > 0,
        Select[Transpose[{csV*paramRetroAll[inu0][[All, 1]]/(2*Pi*hFix), 
                           paramRetroAll[inu0][[All, 5]]}],
          fRng[[1]] <= #[[1]] <= fRng[[2]] && 0 < #[[2]] < hvRng[[2]] &], {}];
      If[Length[rFHV] > 0,
        ListPlot[rFHV, PlotStyle -> Directive[csColors[[ics]], \
AbsolutePointSize[1.5]]],
        Graphics[]]
    ], {ics, Length[csStudy]}];
    
    uPlots = Table[Module[{csV = csStudy[[ics]], rFU, rFUsc},
      rFU = If[Length[paramRetroFAll[inu0]] > 0,
        Select[Transpose[{csV*paramRetroFAll[inu0][[All, 1]]/(2*Pi*hFix), 
                           csV*paramRetroFAll[inu0][[All, 4]]}],
          fRng[[1]] <= #[[1]] <= fRng[[2]] &], {}];
      rFUsc = If[Length[rFU] > 0, {#[[1]], scaleU[#[[2]]]} & /@ rFU, {}];
      If[Length[rFUsc] > 0,
        ListPlot[rFUsc, PlotStyle -> Directive[csColors[[ics]], \
AbsolutePointSize[1.5], Dashing[{0.01}]]],
        Graphics[]]
    ], {ics, Length[csStudy]}];
    
    figVcs = Show[Join[hvPlots, uPlots],
      Frame -> True, FrameStyle -> Directive[Black, AbsoluteThickness[1.5], \
13],
      FrameTicksStyle -> Directive[Black, 11],
      FrameTicks -> {{Automatic, rightTks}, {Automatic, None}},
      FrameLabel -> {{Style[\"H/V Ratio\", 14, Bold], Style[\"U (m/s)\", 14, \
Bold]},
        {Style[\"Frequency, f (Hz)\", 14, Bold], None}},
      PlotLabel -> Style[\"Effect of VsL on H/V & U \[Dash] Rigid \
Halfspace\\n\[Nu]L=\" <> ToString[nuFix] <>
        \", \[Lambda]L=\" <> ToString[NumberForm[\[Lambda]L, {5, 3}]] <>
        \", \[Mu]L=\" <> ToString[\[Mu]L] <>
        \", h=\" <> ToString[hFix] <> \" m\\n(solid = H/V, dashed = U)\", 11],
      PlotRange -> {{fRng[[1]], fRng[[2]]}, hvRng},
      GridLines -> Automatic, GridLinesStyle -> Directive[GrayLevel[0.85], \
AbsoluteThickness[0.5]],
      Epilog -> {},
      PlotLegends -> Placed[SwatchLegend[csColors[[;;Length[csStudy]]],
        Style[\"cs=\" <> ToString[#] <> \" m/s\", 11] & /@ csStudy, \
LegendMarkerSize -> 12], {Right, Top}],
      ImageSize -> 800, ImagePadding -> {{70, 120}, {55, 60}},
      Background -> White, AspectRatio -> 0.6];
    If[MatchQ[figVcs, _Graphics | _Legended], Print[figVcs]];
    Export[\"FigComb_vary_cs_HV_U_freq.pdf\", figVcs, ImageResolution -> 300];
  ];
  
  (* ---- 19c: Vary h (fix nu=nuStudy[[1]], cs=csStudy[[2]]) ---- *)
  Module[{inu0 = 1, ics0 = 2, csFix, nuFix,
          fRng, hvRng = {0, 30}, uRng, scaleU, rightTks,
          hvPlots, uPlots, figVh},
    nuFix = nuStudy[[inu0]]; csFix = csStudy[[ics0]];
    (* Auto-scale to smallest h for widest range *)
    fRng = {0.01, Max[12*csFix/(4*Min[hStudy]), 5]};
    uRng = {0, csFix*3};
    Print[\"  19c: Vary h (fix \[Nu]=\", nuFix, \", cs=\", csFix, \" m/s)\"];
    scaleU[u_] := hvRng[[1]] + (u - uRng[[1]])/(uRng[[2]] - uRng[[1]]) * \
(hvRng[[2]] - hvRng[[1]]);
    rightTks = Table[{scaleU[v], v}, {v, 0, uRng[[2]], \
Max[Round[uRng[[2]]/5], 10]}];
    
    hvPlots = Table[Module[{hV = hStudy[[ih]], rFHV},
      rFHV = If[paramNRetro[inu0] > 0,
        Select[Transpose[{csFix*paramRetroAll[inu0][[All, 1]]/(2*Pi*hV), 
                           paramRetroAll[inu0][[All, 5]]}],
          fRng[[1]] <= #[[1]] <= fRng[[2]] && 0 < #[[2]] < hvRng[[2]] &], {}];
      If[Length[rFHV] > 0,
        ListPlot[rFHV, PlotStyle -> Directive[hColors[[ih]], \
AbsolutePointSize[1.5]]],
        Graphics[]]
    ], {ih, Length[hStudy]}];
    
    uPlots = Table[Module[{hV = hStudy[[ih]], rFU, rFUsc},
      rFU = If[Length[paramRetroFAll[inu0]] > 0,
        Select[Transpose[{csFix*paramRetroFAll[inu0][[All, 1]]/(2*Pi*hV), 
                           csFix*paramRetroFAll[inu0][[All, 4]]}],
          fRng[[1]] <= #[[1]] <= fRng[[2]] &], {}];
      rFUsc = If[Length[rFU] > 0, {#[[1]], scaleU[#[[2]]]} & /@ rFU, {}];
      If[Length[rFUsc] > 0,
        ListPlot[rFUsc, PlotStyle -> Directive[hColors[[ih]], \
AbsolutePointSize[1.5], Dashing[{0.01}]]],
        Graphics[]]
    ], {ih, Length[hStudy]}];
    
    figVh = Show[Join[hvPlots, uPlots],
      Frame -> True, FrameStyle -> Directive[Black, AbsoluteThickness[1.5], \
13],
      FrameTicksStyle -> Directive[Black, 11],
      FrameTicks -> {{Automatic, rightTks}, {Automatic, None}},
      FrameLabel -> {{Style[\"H/V Ratio\", 14, Bold], Style[\"U (m/s)\", 14, \
Bold]},
        {Style[\"Frequency, f (Hz)\", 14, Bold], None}},
      PlotLabel -> Style[\"Effect of h on H/V & U \[Dash] Rigid Halfspace\\n\
\[Nu]L=\" <> ToString[nuFix] <>
        \", \[Lambda]L=\" <> ToString[NumberForm[\[Lambda]L, {5, 3}]] <>
        \", VsL=\" <> ToString[csFix] <> \" m/s\\n(solid = H/V, dashed = \
U)\", 11],
      PlotRange -> {{fRng[[1]], fRng[[2]]}, hvRng},
      GridLines -> Automatic, GridLinesStyle -> Directive[GrayLevel[0.85], \
AbsoluteThickness[0.5]],
      Epilog -> {},
      PlotLegends -> Placed[SwatchLegend[hColors[[;;Length[hStudy]]],
        Style[\"h=\" <> ToString[#] <> \" m\", 11] & /@ hStudy, \
LegendMarkerSize -> 12], {Right, Top}],
      ImageSize -> 800, ImagePadding -> {{70, 120}, {55, 60}},
      Background -> White, AspectRatio -> 0.6];
    If[MatchQ[figVh, _Graphics | _Legended], Print[figVh]];
    Export[\"FigComb_vary_h_HV_U_freq.pdf\", figVh, ImageResolution -> 300];
  ];
];

Print[\"  All combined overlay plots complete.\\n\"];

\
\>", "Input",ExpressionUUID->"440ec171-4353-854f-9641-5d155fda7f55"],

Cell["\<\
(* ================================================================ *)\
\>", "Input",ExpressionUUID->"afe176c9-bd8e-ca4f-9982-c00b24b411fc"],

Cell["\<\
(* 15. EXPORT DATA TO EXCEL                                          *)
(* Set directory for Excel export *)
(* ================================================================ *)

Print[\"\\n================================================================\"];
Print[\"  Exporting Data to Excel\"];
Print[\"================================================================\\n\"];

Module[{dispHeader, retroHeader, shearHeader, xlsxFile,
        dispSheet, retroSheet, proSheet, zeroSheet, mixSheet,
        shearSheet, pressSheet, dimRetroSheet, dimProSheet},
  
  dispHeader = {\"ksh\", \"kh\", \"c/csL\", \"U/csL\", \"U/c\", 
                \"iretro\", \"H/V\", \"T*\", \"ivh\", \"idom\", \"areaE\", \
\"|u_h|^2\", \"|u_v|^2\"};
  retroHeader = {\"ksh\", \"kh\", \"c/csL\", \"U/csL\", \"H/V\", \"T*\", \
\"|u_h|^2\", \"|u_v|^2\", \"delta\", \"theta\"};
  shearHeader = {\"ksh\", \"kh\", \"c/csL\"};
  
  dispSheet  = If[nDisp > 0,  Prepend[dispData, dispHeader],   {dispHeader}];
  retroSheet = If[nRetro > 0, Prepend[retroData, retroHeader], {retroHeader}];
  proSheet   = If[nPro > 0,   Prepend[proData, retroHeader],   {retroHeader}];
  zeroSheet  = If[nZero > 0,  Prepend[zeroData, retroHeader],  {retroHeader}];
  mixSheet   = If[nMix > 0,   Prepend[mixData, retroHeader],   {retroHeader}];
  shearSheet = If[nShear > 0, Prepend[shearData, shearHeader], {shearHeader}];
  pressSheet = If[nPress > 0, Prepend[pressData, shearHeader], {shearHeader}];
  
  dimRetroSheet = If[nRetro > 0,
    Prepend[
      Table[{retroData[[k, 1]], retroData[[k, 2]],
        VsLDim * retroData[[k, 3]], VsLDim * retroData[[k, 4]],
        VsLDim * retroData[[k, 1]] / (2*Pi*hDim),
        2*Pi*hDim / (VsLDim * retroData[[k, 1]]),
        retroData[[k, 5]], retroData[[k, 3]]
      }, {k, Length[retroData]}],
      {\"ksh\", \"kh\", \"c (m/s)\", \"U (m/s)\", \"f (Hz)\", \"T (s)\", \
\"H/V\", \"c/csL\"}],
    {{\"ksh\", \"kh\", \"c (m/s)\", \"U (m/s)\", \"f (Hz)\", \"T (s)\", \"H/V\
\", \"c/csL\"}}];
  
  dimProSheet = If[nPro > 0,
    Prepend[
      Table[{proData[[k, 1]], proData[[k, 2]],
        VsLDim * proData[[k, 3]], VsLDim * proData[[k, 4]],
        VsLDim * proData[[k, 1]] / (2*Pi*hDim),
        2*Pi*hDim / (VsLDim * proData[[k, 1]]),
        proData[[k, 5]], proData[[k, 3]]
      }, {k, Length[proData]}],
      {\"ksh\", \"kh\", \"c (m/s)\", \"U (m/s)\", \"f (Hz)\", \"T (s)\", \
\"H/V\", \"c/csL\"}],
    {{\"ksh\", \"kh\", \"c (m/s)\", \"U (m/s)\", \"f (Hz)\", \"T (s)\", \"H/V\
\", \"c/csL\"}}];
  
  xlsxFile = \"ProgressiveWaves_Case1_Data.xlsx\";
  
  (* Export multi-sheet Excel workbook *)
  (* Method: Export each sheet as a list-of-lists with headers *)
  Export[xlsxFile, 
    {dispSheet, retroSheet, proSheet, zeroSheet, mixSheet,
     shearSheet, pressSheet, dimRetroSheet, dimProSheet},
    {{\"Sheets\", {\"Dispersive\", \"Retrograde\", \"Prograde\", 
      \"Indeterminate\", \"Mixed\", \"ShearWave\", \"PressureWave\",
      \"DimRetrograde\", \"DimPrograde\"}}}
  ];
  
  Print[\"  Exported: \", xlsxFile];
  Print[\"  Sheets: Dispersive (\", nDisp, \"), Retrograde (\", nRetro, 
        \"), Prograde (\", nPro, \"), Shear (\", nShear, 
        \"), Pressure (\", nPress, \")\"];
];

Print[\"\"];

\
\>", "Input",ExpressionUUID->"a4f30999-4084-9e46-8b7a-2a615f3740f2"],

Cell["\<\
(* ================================================================ *)\
\>", "Input",ExpressionUUID->"6eb20583-8aca-d543-8ce1-550d944946f1"],

Cell["\<\
