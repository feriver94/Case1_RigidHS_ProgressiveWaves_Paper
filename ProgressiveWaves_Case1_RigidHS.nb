\>", "Input",ExpressionUUID->"c3ab4c12-329b-6646-bc6d-e76ea6691997"],

Cell["\<\
(* ================================================================ *)
(* COMPREHENSIVE AIRY PHASE CORRELATION SUMMARY                     *)
(*                                                                    *)
(* This table summarizes the coincidence of H/V peak and U minimum  *)
(* across ALL parametric cases \[AHat]\.80\.94 the core thesis contribution.  \
     *)
(* ================================================================ *)

Print[\"\\n================================================================\"];
Print[\"  COMPREHENSIVE AIRY PHASE CORRELATION SUMMARY\"];
Print[\"  ================================================================\"];
Print[\"\"];
Print[\"  THESIS CONTRIBUTION: When H/V_max and U_min occur at the\"];
Print[\"  same (or nearby) period/frequency, this creates the worst-case\"];
Print[\"  scenario for earthquake engineering:\"];
Print[\"    \[Bullet] Large horizontal shaking (H/V >> 1)\"];
Print[\"    \[Bullet] Slow energy propagation (U \[Rule] min, Airy phase)\"];
Print[\"    \[Bullet] Energy pileup at the site\"];
Print[\"    \[Bullet] If structure T \[TildeEqual] T_critical \[Rule] \
probable collapse\"];
Print[\"\"];
Print[\"  ----------------------------------------------------------------\"];
Print[Row[{PaddedForm[\"Case\", {12, 0}], PaddedForm[\"H/V_max\", {10, 0}],
  PaddedForm[\"at f (Hz)\", {12, 0}], PaddedForm[\"U_min\", {12, 0}],
  PaddedForm[\"at f (Hz)\", {12, 0}], PaddedForm[\"Proximity\", {12, 0}]}]];
Print[\"  ----------------------------------------------------------------\"];

(* Baseline case *)
Module[{rHVbase, rUbase, hvM, hvMf, uM, uMf, prox},
  rHVbase = If[nRetro > 0,
    Select[Transpose[{VsLDim*retroData[[All, 1]]/(2*Pi*hDim), retroData[[All, \
5]]}],
      0.1 < #[[1]] < 20 && NumericQ[#[[2]]] && #[[2]] > 0 &], {}];
  rUbase = If[nRetro > 0,
    Select[Transpose[{VsLDim*retroData[[All, 1]]/(2*Pi*hDim), \
VsLDim*Re[retroData[[All, 4]]]}],
      0.1 < #[[1]] < 20 && NumericQ[#[[2]]] && #[[2]] > 0 &], {}];
  If[Length[rHVbase] > 10 && Length[rUbase] > 10,
    hvM = Max[rHVbase[[All, 2]]];
    hvMf = rHVbase[[First[Ordering[rHVbase[[All, 2]], -1]]]][[1]];
    uM = Min[rUbase[[All, 2]]];
    uMf = rUbase[[First[Ordering[rUbase[[All, 2]], 1]]]][[1]];
    prox = Abs[hvMf - uMf]/Max[hvMf, uMf] * 100;
    Print[Row[{PaddedForm[\"Baseline\", {12, 0}],
      PaddedForm[NumberForm[hvM, {5, 1}], {10, 0}],
      PaddedForm[NumberForm[hvMf, {6, 2}], {12, 0}],
      PaddedForm[NumberForm[uM, {6, 1}], {12, 0}],
      PaddedForm[NumberForm[uMf, {6, 2}], {12, 0}],
      PaddedForm[ToString[NumberForm[prox, {4, 1}]] <> \"%\", {12, 0}]}]];
  ];
];

Print[\"  ----------------------------------------------------------------\"];
Print[\"  Proximity = |f_HVmax - f_Umin| / max(f_HVmax, f_Umin) * 100%\"];
Print[\"  Lower % = stronger correlation = worse earthquake scenario\"];
Print[\"  ================================================================\"];

\
\>", "Input",ExpressionUUID->"e7e68e94-96f1-614c-8592-a0a4dd61051c"],

Cell["\<\
