Print[Style[\"================================================================\
\", Bold]];
Print[Style[\"  SUMMARY\", Bold, 14]];
Print[Style[\"================================================================\
\", Bold]];
Print[\"\"];
Print[\"  Elastic Layer on Rigid Halfspace (4\\\[Times]4)\"];
Print[\"  \[Nu]L = \", \[Nu]L, \", \[Mu]L = \", \[Mu]L, 
      \", \[Lambda]L = \", NumberForm[\[Lambda]L, {6, 1}], 
      \", \[Rho]L = \", \[Rho]L];
Print[\"  h = \", h, \", csL = \", NumberForm[csL, {6, 4}], 
      \", cpL = \", NumberForm[cpL, {6, 4}]];
Print[\"  cpL/csL = \", NumberForm[cpL/csL, {5, 2}]];
Print[\"\"];
Print[\"  Resonance: T_s = 4h/csL = \", NumberForm[Ts, {5, 3}],
      \", T_p = 4h/cpL = \", NumberForm[Tp, {5, 4}]];
Print[\"\"];
Print[\"  Grid: \", ni, \" \[Times] \", nj, \" (ksh=[0,\", kshMax, \"], \
kh=[0,\", khMax, \"])\"];
Print[\"  Dispersive roots: \", nDisp, \" unique\"];
Print[\"    Retrograde: \", nRetro, \", Prograde: \", nPro];
Print[\"    Indeterminate: \", nZero, \", Mixed: \", nMix];
Print[\"  Body waves: Shear \", nShear, \", Pressure \", nPress];
Print[\"\"];
Print[\"  Figures: 21 PDFs exported\"];
Print[\"  Excel: ProgressiveWaves_Case1_Data.xlsx\"];
Print[\"\"];
Print[\"\\nAll files saved to: \", Directory[]];
Print[Style[\"================================================================\
\", Bold]];\
