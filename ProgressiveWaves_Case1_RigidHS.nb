\>", "Input",ExpressionUUID->"b0f0ad03-f714-904f-bf8c-76dc29422976"],

Cell["\<\
(* 11. GROUP VELOCITY FILTERING                                      *)
(*     Remove numerical outliers from finite-difference artifacts    *)
(*     Filter: |U/csL| < 6 and |U/csL| > -2                        *)
(* ================================================================ *)

Print[\"Filtering group velocity outliers...\"];

filterU[data_] := Select[data, 
  -5.0 < Re[#[[4]]] < 30.0 &   (* Wide range: advisor uses cocsL up to 24 *)
];

retroDataF  = filterU[retroData];
proDataF    = filterU[proData];
zeroDataF   = filterU[zeroData];
mixDataF    = filterU[mixData];
dispDataF   = Select[dispData, -5.0 < Re[#[[4]]] < 30.0 &];

Print[\"  After filtering: Retro \", Length[retroDataF], 
      \" (was \", nRetro, \"), Pro \", Length[proDataF],
      \" (was \", nPro, \")\"];
Print[\"\"];

(* ---- Numerical Summary Table: Root Counts ---- *)
Print[Style[\"\\n  ROOT-FINDING RESULTS\", Bold, 14]];
Print[Grid[{
    {Style[\"Category\", Bold], Style[\"Count\", Bold], Style[\"Percentage\", \
Bold]},
    {\"Dispersive (total)\", nDisp, 
     If[ni*nj > 0, NumberForm[100.0*nDisp/(ni*nj), {4, 1}] <> \"%\", \"\"]},
    {\"  Retrograde\", nRetro, 
     If[nDisp > 0, NumberForm[100.0*nRetro/nDisp, {4, 1}] <> \"%\", \"\"]},
    {\"  Prograde\", nPro, 
     If[nDisp > 0, NumberForm[100.0*nPro/nDisp, {4, 1}] <> \"%\", \"\"]},
    {\"  Indeterminate\", nZero, 
     If[nDisp > 0, NumberForm[100.0*nZero/nDisp, {4, 1}] <> \"%\", \"\"]},
    {\"  Mixed\", nMix, 
     If[nDisp > 0, NumberForm[100.0*nMix/nDisp, {4, 1}] <> \"%\", \"\"]},
    {\"Shear wave\", nShear, \"\"},
    {\"Pressure wave\", nPress, \"\"}
  },
  Frame -> All, Alignment -> Left, Spacings -> {2, 0.8},
  Background -> {{LightBlue, None, None}, {LightGray, None}}
]];

(* Sample data table hidden - use Excel export for data *)

\
\>", "Input",ExpressionUUID->"734a47d9-6298-9846-8cb9-ca092fef9f1d"],

Cell["\<\
(* ================================================================ *)\
\>", "Input",ExpressionUUID->"682da8f7-fd92-3442-a83b-64a03b4b7b70"],

Cell["\<\
(* 12. PHASE 1 FIGURES (Advisor Validation, Dimensionless)           *)
(*     All normalizations by csL only                                *)
(* ================================================================ *)

Print[\"================================================================\"];
Print[\"  Generating Phase 1 Figures (Advisor Validation)\"];
Print[\"================================================================\\n\"];

titleStr = \"Elastic Layer on Rigid Halfspace\\n\" <>
  \"\[Lambda]L=\" <> ToString[NumberForm[\[Lambda]L, {5, 3}]] <>
  \", \[Mu]L=\" <> ToString[\[Mu]L] <>
  \", \[Rho]L=\" <> ToString[\[Rho]L] <>
  \", \[Nu]L=\" <> ToString[\[Nu]L] <> \", h=\" <> ToString[h] <>
  \"\\ncsL=\" <> ToString[NumberForm[csL, {4, 2}]] <>
  \", cpL=\" <> ToString[NumberForm[cpL, {4, 2}]] <>
  \", cpL/csL=\" <> ToString[NumberForm[cpL/csL, {4, 2}]];



(* Safe figure display: prevents raw ListPlot data dumps *)
(* Display figure if valid graphic; suppress raw data dumps *)
showFig[fig_] := If[MatchQ[fig, _Graphics | _Legended],
  Print[fig],
  Print[\"  [Figure not rendered]\"]
];

commonOpts = Sequence[
  Frame -> True,
  FrameStyle -> Directive[Black, AbsoluteThickness[1.5], 13],
  FrameTicksStyle -> Directive[Black, 11],
  GridLines -> Automatic,
  GridLinesStyle -> Directive[GrayLevel[0.85], AbsoluteThickness[0.5]],
  ImageSize -> 650,
  ImagePadding -> {{60, 140}, {55, 65}},
  Background -> White,
  AspectRatio -> 0.65
];

(* Colors *)
retroC  = RGBColor[0.12, 0.47, 0.71];    (* blue *)
proC    = RGBColor[0.84, 0.15, 0.16];     (* red *)
indetC  = GrayLevel[0.0];                  (* black for indeterminate *)
mixC    = RGBColor[0.55, 0.0, 0.55];      (* magenta for mixed *)
dispC   = RGBColor[0.12, 0.47, 0.71];     (* blue *)
groupC  = RGBColor[0.55, 0.0, 0.55];      (* magenta for group vel *)
shearC  = RGBColor[0.84, 0.15, 0.16];     (* red *)
pressC  = GrayLevel[0.0];                  (* black *)

(* ---- Figure 1001: kh vs ksh, retrograde/prograde/indeterminate ---- *)
Print[\"Fig 1001: kh vs ksh (retrograde/prograde)\"];

fig1001 = Quiet[ListPlot[{
    If[nRetro > 0, Transpose[{retroData[[All, 2]], retroData[[All, 1]]}], \
{{-1, -1}}],
    If[nPro > 0,   Transpose[{proData[[All, 2]], proData[[All, 1]]}], {{-1, \
-1}}],
    If[nZero > 0,  Transpose[{zeroData[[All, 2]], zeroData[[All, 1]]}], {{-1, \
-1}}],
    If[nMix > 0,   Transpose[{mixData[[All, 2]], mixData[[All, 1]]}], {{-1, \
-1}}],
    If[nShear > 0, Transpose[{shearData[[All, 2]], shearData[[All, 1]]}], \
{{-1, -1}}],
    If[nPress > 0, Transpose[{pressData[[All, 2]], pressData[[All, 1]]}], \
{{-1, -1}}]
  },
  PlotStyle -> {
    Directive[retroC, AbsolutePointSize[2]], 
    Directive[proC, AbsolutePointSize[2]],
    Directive[indetC, AbsolutePointSize[2.5]],
    Directive[mixC, AbsolutePointSize[2]],
    Directive[shearC, AbsolutePointSize[2]],
    Directive[pressC, AbsolutePointSize[2]]},
