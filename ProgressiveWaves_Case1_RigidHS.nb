Export[\"Fig1003_kh_omega.pdf\", fig1003, ImageResolution -> 300];
Export[\"Fig1004_kh_ksh_wave_type.pdf\", fig1004, ImageResolution -> 300];
Export[\"Fig1005_ksh_c_U.pdf\", fig1005, ImageResolution -> 300];
Export[\"Fig1007_kh_c_U_motion.pdf\", fig1007, ImageResolution -> 300];
Export[\"Fig1008_kh_U.pdf\", fig1008, ImageResolution -> 300];
