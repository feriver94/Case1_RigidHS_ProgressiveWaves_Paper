Cell[CellGroupData[{

Cell["\<\
(* ================================================================ *)
(* QUARTER-WAVELENGTH RESONANCE PERIODS                              *)
(*   T_s = 4h/csL   (S-wave fundamental site period)                *)
(*   T_p = 4h/cpL   (P-wave fundamental site period)                *)
(*   Higher harmonics: T_n = T_1/(2n-1), n=1,2,3,...               *)
(*                                                                    *)
(*   Physical significance:                                           *)
(*   - At T_s: layer is quarter-wavelength for shear waves           *)
(*     \[Rule] phase velocity c \[Rule] \[Infinity] at mode cutoff *)
(*     \[Rule] H/V peaks expected near T_s                           *)
(*   - At T_p: layer is quarter-wavelength for P-waves               *)
(*     \[Rule] possible secondary resonance in H/V                   *)
(*   - Airy phase (U stationary) may or may not coincide with        *)
(*     quarter-wavelength resonance depending on mode coupling        *)
(* ================================================================ *)

Ts = 4*h/csL;          (* S-wave fundamental site period *)
Tp = 4*h/cpL;          (* P-wave fundamental site period *)
Ts2 = Ts/3;            (* S-wave 2nd harmonic *)
Tp2 = Tp/3;            (* P-wave 2nd harmonic *)
Ts3 = Ts/5;            (* S-wave 3rd harmonic *)
Tp3 = Tp/5;            (* P-wave 3rd harmonic *)

Print[\"\\n  THEORETICAL RESONANCE PERIODS\"];
Print[\"  ================================================================\"];
Print[\"  Quarter-wavelength condition: T_n = 4h / (c \[CenterDot] (2n-1))\"];
Print[\"\"];
Print[\"  S-wave (using csL = \", NumberForm[csL, {6, 4}], \"):\"];
Print[\"    Fundamental (n=1): T_1^(s) = 4h/csL = 4\[Times]\", h, \"/\", 
      NumberForm[csL, {6, 4}], \" = \", NumberForm[N[Ts], {6, 3}]];
Print[\"    2nd mode    (n=2): T_2^(s) = 4h/(3\[CenterDot]csL) = \", 
      NumberForm[N[Ts/3], {6, 4}], \"  (higher freq, shorter period)\"];
Print[\"    3rd mode    (n=3): T_3^(s) = 4h/(5\[CenterDot]csL) = \", 
      NumberForm[N[Ts/5], {6, 4}]];
Print[\"\"];
Print[\"  P-wave (using cpL = \", NumberForm[cpL, {6, 4}], \"):\"];
Print[\"    Fundamental (n=1): T_1^(p) = 4h/cpL = 4\[Times]\", h, \"/\", 
      NumberForm[cpL, {6, 4}], \" = \", NumberForm[N[Tp], {6, 3}]];
Print[\"    2nd mode    (n=2): T_2^(p) = 4h/(3\[CenterDot]cpL) = \", 
      NumberForm[N[Tp/3], {6, 4}]];
Print[\"\"];
Print[\"  VISIBLE in plot range [0.4, 4]:\"];
Print[\"    T_1^(s) = \", NumberForm[N[Ts], {6, 3}], \"  \[LongLeftArrow] \
S-wave fundamental\"];
Print[\"    T_1^(p) = \", NumberForm[N[Tp], {6, 3}], \"  \[LongLeftArrow] \
P-wave fundamental\"];
Print[\"  ================================================================\"];
Print[\"    S-wave: T_s  = 4h/csL = \", NumberForm[Ts, {6, 4}],
      \"   (f_s = \", NumberForm[1/Ts, {6, 4}], \")\"];
Print[\"    P-wave: T_p  = 4h/cpL = \", NumberForm[Tp, {6, 4}],
      \"   (f_p = \", NumberForm[1/Tp, {6, 4}], \")\"];
Print[\"    Ratio:  T_p/T_s = csL/cpL = \", NumberForm[Tp/Ts, {5, 4}]];
Print[\"    Higher harmonics: T_s/3 = \", NumberForm[Ts2, {5, 4}],
      \",  T_s/5 = \", NumberForm[Ts3, {5, 4}]];
Print[\"\"];

(* Resonance reference lines for Epilog in all period-axis plots *)
(* resonanceEpilog: vertical reference lines at quarter-wavelength     *)
(* resonance periods with explicitly computed values.                  *)
(*                                                                      *)
(* COORDINATE MODES for Mathematica Epilog:                            *)
(*   \"linear\"  : both axes linear (ListPlot)                          *)
(*   \"loglog\"  : both axes log    (ListLogLogPlot) -> {Log[x],Log[y]} *)
(*   \"loglin\"  : x-axis log only  (ListLogLinearPlot) -> {Log[x], y}  *)
(*                                                                      *)
(* Colors: S-wave = solid dark green, P-wave = dashed dark orange      *)
(* ------------------------------------------------------------------- *)

(* Print explicit computation *)
Print[\"\"];
Print[\"  THEORETICAL RESONANCE PERIODS\"];
Print[\"  ================================================================\"];
Print[\"  Quarter-wavelength: T_n = 4h / [c \[CenterDot] (2n-1)]\"];
Print[\"\"];
Print[\"  S-wave fundamental: Ts = 4h/csL = 4\[Times]\", h, \"/\",
      NumberForm[csL, {6, 4}], \" = \", NumberForm[N[Ts], {6, 3}]];
Print[\"  P-wave fundamental: Tp = 4h/cpL = 4\[Times]\", h, \"/\",
      NumberForm[cpL, {6, 4}], \" = \", NumberForm[N[Tp], {6, 3}]];
Print[\"  ================================================================\"];
Print[\"\"];

resonanceEpilog[yLo_, yHi_, mode_:\"linear\"] := Module[
  {sCol = Darker[Green, 0.3],
   pCol = RGBColor[0.85, 0.45, 0],
   sVal = ToString[NumberForm[N[Ts], {6, 3}]],
   pVal = ToString[NumberForm[N[Tp], {6, 3}]],
   xS, xP, yL, yH, sLabelY, pLabelY},
  
  (* Transform coordinates based on plot type *)
  xS = If[mode === \"loglog\" || mode === \"loglin\", Log[Ts], Ts];
  xP = If[mode === \"loglog\" || mode === \"loglin\", Log[Tp], Tp];
  yL = If[mode === \"loglog\", Log[yLo], yLo];
  yH = If[mode === \"loglog\", Log[yHi], yHi];
  
  (* Labels positioned at ~70% height to avoid top clipping *)
  sLabelY = If[mode === \"loglog\", 
    Log[yLo] + 0.7*(Log[yHi] - Log[yLo]),
    yLo + 0.7*(yHi - yLo)];
  pLabelY = If[mode === \"loglog\", 
    Log[yLo] + 0.85*(Log[yHi] - Log[yLo]),
    yLo + 0.85*(yHi - yLo)];
  
  {
   (* S-wave fundamental: T_s = 4h/csL \[AHat]\.80\.94 SOLID green line *)
   {sCol, AbsoluteThickness[2.5],
    Line[{{xS, yL}, {xS, yH}}]},
   Inset[
     Framed[Style[\"S-fund\\n4h/cs=\" <> sVal, 9, sCol, Bold],
       Background -> Directive[White, Opacity[0.85]],
       FrameStyle -> sCol, RoundingRadius -> 3],
     {xS, sLabelY}, {0, 0}],
   (* P-wave fundamental: T_p = 4h/cpL \[AHat]\.80\.94 DASHED orange line *)
   {pCol, AbsoluteThickness[2.5], Dashed,
    Line[{{xP, yL}, {xP, yH}}]},
   Inset[
     Framed[Style[\"P-fund\\n4h/cp=\" <> pVal, 9, pCol, Bold],
       Background -> Directive[White, Opacity[0.85]],
       FrameStyle -> pCol, RoundingRadius -> 3],
     {xP, pLabelY}, {0, 0}]
  }
];

\
\>", "Input",
 CellLabel->"In[74]:=",ExpressionUUID->"7fd25051-f12e-bc49-8f9c-99717d111cfb"],

