Cell[CellGroupData[{

Cell["\<\
(* 1. MATERIAL AND GEOMETRIC PROPERTIES                              *)
(* ================================================================ *)

(* IMPLEMENTATION NOTE: All governing equations, boundary conditions,    *)
(* nondimensionalization, wavefield expressions, and root-finding method  *)
(* are direct translations of the advisor MATLAB code:                    *)
(*   layer_on_halfspace_260123_retro_prograde_v11_HoV.m                  *)
(* No independent reformulation. Same csL, same nu, same density norm.   *)

h = 1;

(* Layer \[Dash] Advisor MATLAB v11_HoV default (advisor MATLAB v11_HoV) *)
\[Mu]L  = 1;          (* DO NOT CHANGE muL: normalization constant *)
\[Nu]L  = 0.25;   (* Advisor baseline: Poisson ratio *)
EL     = 2*(1 + \[Nu]L)*\[Mu]L;
\[Lambda]L = EL*\[Nu]L/(1 + \[Nu]L)/(1 - 2*\[Nu]L);
\[Rho]L = 1;         (* DO NOT CHANGE rhoL: normalization constant *)

csL = Sqrt[\[Mu]L/\[Rho]L];
cpL = Sqrt[(\[Lambda]L + 2*\[Mu]L)/\[Rho]L];
(* Vp = Vs * Sqrt[2*(1-\[Nu])/(1-2*\[Nu])] \[AHat]\.80\.94 same as MATLAB *)


(* No halfspace properties: rigid base (infinite stiffness) *)


Print[\"================================================================\"];
Print[\"  Elastic Layer on Rigid Halfspace (4\[Times]4 system)\"];
Print[\"================================================================\"];
Print[\"  Layer:     \[Mu]L = \", \[Mu]L, \"  \[Lambda]L = \", NumberForm[\
\[Lambda]L, {6, 3}], 
      \"  \[Rho]L = \", \[Rho]L, \"  \[Nu]L = \", \[Nu]L];
Print[\"             csL = \", NumberForm[csL, {6, 4}], 
      \"  cpL = \", NumberForm[cpL, {6, 4}],
      \"  cpL/csL = \", NumberForm[cpL/csL, {5, 3}]];
Print[\"  Halfspace: Rigid (infinite stiffness)\"];
Print[\"  h = \", h];

\
\>", "Input",
 CellLabel->"In[39]:=",ExpressionUUID->"6ae95bd5-fe01-4e4a-96f9-3be94d2e1315"],

