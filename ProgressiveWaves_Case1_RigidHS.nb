Cell["\<\
(* ================================================================ *)\
\>", "Input",
 CellLabel->
  "In[146]:=",ExpressionUUID->"94dba782-d0f7-1943-8cf1-5b789b7a0074"],

Cell[CellGroupData[{

Cell["\<\
(* 2. SEARCH GRID                                                    *)
(*    240\[Times]240 matching advisor MATLAB grid resolution.        *)
(*    Grid matches advisor MATLAB (ksh=[0,8], kh=[0,8]).             *)
(* ================================================================ *)

kshMin = 0;  kshMax = 8;
khMin  = 0;  khMax  = 8;

ni = 360;
nj = 360;

khVec  = N @ Subdivide[khMin + khMax/ni, khMax, ni - 1];
kshVec = N @ Subdivide[kshMin + kshMax/nj, kshMax, nj - 1];

Print[\"  Grid: \", ni, \" \[Times] \", nj, \" = \", ni*nj, \" points\"];
Print[\"\"];


(* ================================================================ *)\
\>", "Input",
 CellLabel->
  "In[147]:=",ExpressionUUID->"5d19bde9-d721-fd46-8633-10a0116e6f65"],

Cell[CellGroupData[{

Cell[BoxData[
 InterpretationBox[
  RowBox[{"\<\"  Grid: \"\>", "\[InvisibleSpace]", "360", 
   "\[InvisibleSpace]", "\<\" \[Times] \"\>", "\[InvisibleSpace]", "360", 
   "\[InvisibleSpace]", "\<\" = \"\>", "\[InvisibleSpace]", "129600", 
   "\[InvisibleSpace]", "\<\" points\"\>"}],
  SequenceForm["  Grid: ", 360, " \[Times] ", 360, " = ", 129600, " points"],
  Editable->False]], "Print",
 CellChangeTimes->{3.9899930892958603`*^9},
 CellLabel->
  "During evaluation of \
In[147]:=",ExpressionUUID->"c1fe1b75-e7af-3a40-8a0b-5d6916d48a07"],

Cell[BoxData["\<\"\"\>"], "Print",
 CellChangeTimes->{3.9899930892958603`*^9},
 CellLabel->
  "During evaluation of \
In[147]:=",ExpressionUUID->"e4bc299d-4e87-1147-b8fa-18065afc0212"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
(* 3. COMPILED DETERMINANT (4\[Times]4)                             *)
(*    Boundary conditions:                                            *)
(*      Rows 1-2: Rigid base (z=0), displacement = 0                 *)
(*      Rows 3-4: Free surface (z=h), traction = 0                   *)
(*    Only layer properties appear (no halfspace).                    *)
(* ================================================================ *)

Print[\"Compiling 4\[Times]4 boundary condition determinant...\"];
tPrecomp = AbsoluteTime[];

ClearAll[ksVar, kiVar];

symDetExpr = Block[
  {c, cocpL, cocsL, pL, qL, pLkh, qLkh, mat},
  
  c     = N[csL]*ksVar/kiVar;
  cocpL = c/N[cpL];
  cocsL = c/N[csL];
  pL    = Sqrt[1 - cocpL^2];
  qL    = Sqrt[1 - cocsL^2];
  pLkh  = pL*kiVar;
  qLkh  = qL*kiVar;
  
  mat = {
    {I, 0, 0, qL},
    {0, pL, -I, 0},
    {2*I*pL*Sinh[pLkh], 2*I*pL*Cosh[pLkh], 
     (1 + qL^2)*Cosh[qLkh], (1 + qL^2)*Sinh[qLkh]},
    {(N[\[Lambda]L/\[Mu]L]*(pL^2 - 1) + 2*pL^2)*Cosh[pLkh],
     (N[\[Lambda]L/\[Mu]L]*(pL^2 - 1) + 2*pL^2)*Sinh[pLkh],
     -2*I*qL*Sinh[qLkh], -2*I*qL*Cosh[qLkh]}
  };
  
  Det[mat]
];

detCompiled = Compile[{{ksVar, _Complex}, {kiVar, _Complex}},
  Evaluate[symDetExpr],
  RuntimeOptions -> \"Speed\"
];

detEval[kshVal_?NumericQ, khVal_?NumericQ] := Module[{res},
  res = detCompiled[kshVal + 0.*I, khVal + 0.*I];
  {Re[res], Im[res]}
];

Print[\"  Compiled in \", NumberForm[AbsoluteTime[] - tPrecomp, {5, 2}], \" s\
\"];
Print[\"\"];

\
\>", "Input",
 CellLabel->
  "In[166]:=",ExpressionUUID->"cf73c2e6-0a77-2340-850d-caeb4423c65b"],

Cell[CellGroupData[{

Cell[BoxData["\<\"Compiling 4\[Times]4 boundary condition \
determinant...\"\>"], "Print",
 CellChangeTimes->{3.989993089309597*^9},
 CellLabel->
  "During evaluation of \
In[166]:=",ExpressionUUID->"71259ac4-c788-3843-b6e6-55deebd0659c"],

Cell[BoxData[
 InterpretationBox[
  RowBox[{"\<\"  Compiled in \"\>", "\[InvisibleSpace]", 
   TagBox[
    InterpretationBox[
     StyleBox["\<\"0.01\"\>",
      ShowStringCharacters->False],
     0.0107351`5.482351087843081,
     AutoDelete->True],
    NumberForm[#, {5, 2}]& ], "\[InvisibleSpace]", "\<\" s\"\>"}],
  SequenceForm["  Compiled in ", 
   NumberForm[0.0107351`5.482351087843081, {5, 2}], " s"],
  Editable->False]], "Print",
 CellChangeTimes->{3.989993089309597*^9},
 CellLabel->
  "During evaluation of \
In[166]:=",ExpressionUUID->"756db038-c8f8-5441-8c98-6fbd3b788199"],

Cell[BoxData["\<\"\"\>"], "Print",
 CellChangeTimes->{3.989993089309597*^9},
 CellLabel->
  "During evaluation of \
In[166]:=",ExpressionUUID->"8ea7f73c-fd51-c14e-8364-b16fb496146b"]
}, Open  ]]
}, Open  ]],

Cell["\<\
(* ================================================================ *)\
\>", "Input",
 CellLabel->
  "In[188]:=",ExpressionUUID->"07f56e19-ae0e-0741-bc36-019789930e29"],

Cell["\<\
(* 4. NUMERICAL MATRIX BUILDER (4\[Times]4, for eigenvector)        *)
(* ================================================================ *)

buildA[cVal_, khiVal_] := Module[
  {cocpL, cocsL, pL, qL, pL2, qL2, pLkh, qLkh},
  
  cocpL = cVal/cpL;  cocsL = cVal/csL;
  pL = Sqrt[1 - cocpL^2 + 0.*I];  qL = Sqrt[1 - cocsL^2 + 0.*I];
  pL2 = pL*pL;  qL2 = qL*qL;
  pLkh = pL*khiVal;  qLkh = qL*khiVal;
  
  N[{
    {I, 0, 0, qL},
    {0, pL, -I, 0},
    {2*I*pL*Sinh[pLkh], 2*I*pL*Cosh[pLkh], 
     (1 + qL2)*Cosh[qLkh], (1 + qL2)*Sinh[qLkh]},
    {(\[Lambda]L/\[Mu]L*(pL2 - 1) + 2*pL2)*Cosh[pLkh],
     (\[Lambda]L/\[Mu]L*(pL2 - 1) + 2*pL2)*Sinh[pLkh],
     -2*I*qL*Sinh[qLkh], -2*I*qL*Cosh[qLkh]}
  }]
];


(* ================================================================ *)\
\>", "Input",
 CellLabel->
  "In[189]:=",ExpressionUUID->"3d3649dc-467a-6f4b-a917-db124d45e255"],

Cell["\<\
(* 5. SURFACE DISPLACEMENT MATRIX U0 (2\[Times]4)                   *)
(*    Maps 4-component layer amplitude vector to 2-component         *)
(*    surface displacement at z = h (free surface).                   *)
(* ================================================================ *)

buildU0[cVal_, khiVal_] := Module[
  {pL, qL, pLkh, qLkh, ku},
  
  pL   = Sqrt[1 - (cVal/cpL)^2 + 0.*I];
  qL   = Sqrt[1 - (cVal/csL)^2 + 0.*I];
  pLkh = pL*khiVal;
  qLkh = qL*khiVal;
  ku   = khiVal/h;
  
  ku * N[{
    {I*Cosh[pLkh], I*Sinh[pLkh], qL*Sinh[qLkh], qL*Cosh[qLkh]},
    {pL*Sinh[pLkh], pL*Cosh[pLkh], -I*Cosh[qLkh], -I*Sinh[qLkh]}
  }]
];


(* ================================================================ *)\
\>", "Input",
 CellLabel->
  "In[196]:=",ExpressionUUID->"5785f7fc-020c-6a48-8c60-c96b3d39e57a"],

Cell["\<\
(* 6. GROUP VELOCITY (Finite Differences on Compiled Determinant)    *)
(* F = Det[B(ksh, kh)] is the determinant of the boundary-condition  *)
(* matrix. The dispersion relation is F(ksh, kh) = 0.               *)
(* Group velocity: U/csL = -(\[PartialD]F/\[PartialD]ksh) / (\[PartialD]F/\
\[PartialD]kh)           *)
(* computed via centered finite differences at \[Epsilon] = 10^-6.            \
  *)
(*                                                                    *)
(*    \[Omega] = c \[CenterDot] kh / h   where  c = csL ksh / kh   *)
(*    U/csL = c/csL - kh \[CenterDot]                               *)
(*            (\[PartialD]det/\[PartialD]kh)|c /                     *)
(*            (\[PartialD]det/\[PartialD]c)|kh                       *)
(* ================================================================ *)

computeGroupVelocity[kshRoot_, khRoot_] := Module[
  {cRoot, cocsLVal, cocpLVal, cocsHVal, cocpHVal,
   pLbar, qLbar, pLbar2, qLbar2, pLkh, qLkh,
   pHbar, qHbar, pHbar2, qHbar2,
   cocpL2, cocsL2, cocpH2, cocsH2,
   AA, dAdc, dAdk, fact1, fact2, UocsL},
  
  cRoot = csL * kshRoot / khRoot;
  cocsLVal = cRoot / csL;
  cocpLVal = cRoot / cpL;
  cocpL2 = cocpLVal / cpL;
  cocsL2 = cocsLVal / csL;
  
  pLbar = Sqrt[1 - cocpLVal^2];
  qLbar = Sqrt[1 - cocsLVal^2];
  pLbar2 = pLbar^2;
  qLbar2 = qLbar^2;
  pLkh = pLbar * khRoot;
  qLkh = qLbar * khRoot;
  
  AA = buildA[cRoot, khRoot];
  
  (* Case 1: 4x4 analytical dA/dc and dA/dk \[AHat]\.80\.94 matches MATLAB \
exactly *)
  dAdc = N[{{0, 0, 0, -cocsL2/qLbar},
            {0, -cocpL2/pLbar, 0, 0},
            {-2*I*cocpL2*(Sinh[pLkh]/pLbar + khRoot*Cosh[pLkh]),
             -2*I*cocpL2*(Cosh[pLkh]/pLbar + khRoot*Sinh[pLkh]),
             -cocsL2*(2*Cosh[qLkh] + (1 + qLbar2)*khRoot*Sinh[qLkh]/qLbar),
             -cocsL2*(2*Sinh[qLkh] + (1 + qLbar2)*khRoot*Cosh[qLkh]/qLbar)},
            {-((\[Lambda]L/\[Mu]L)*2 + 4)*cocpL2*Cosh[pLkh]
             - ((\[Lambda]L/\[Mu]L)*(pLbar2-1) + \
2*pLbar2)*cocpL2*khRoot*Sinh[pLkh]/pLbar,
             -((\[Lambda]L/\[Mu]L)*2 + 4)*cocpL2*Sinh[pLkh]
             - ((\[Lambda]L/\[Mu]L)*(pLbar2-1) + \
2*pLbar2)*cocpL2*khRoot*Cosh[pLkh]/pLbar,
             2*I*cocsL2*Sinh[qLkh]/qLbar + 2*I*cocsL2*khRoot*Cosh[qLkh],
             2*I*cocsL2*Cosh[qLkh]/qLbar + 2*I*cocsL2*khRoot*Sinh[qLkh]}}];
  
  dAdk = N[{{0, 0, 0, 0},
            {0, 0, 0, 0},
            {2*I*pLbar2*h*Cosh[pLkh], 2*I*pLbar2*h*Sinh[pLkh],
             (1 + qLbar2)*qLbar*h*Sinh[qLkh], (1 + qLbar2)*qLbar*h*Cosh[qLkh]},
            {((\[Lambda]L/\[Mu]L)*(pLbar2-1) + 2*pLbar2)*pLbar*h*Sinh[pLkh],
             ((\[Lambda]L/\[Mu]L)*(pLbar2-1) + 2*pLbar2)*pLbar*h*Cosh[pLkh],
             -2*I*qLbar2*h*Cosh[qLkh],
             -2*I*qLbar2*h*Sinh[qLkh]}}];
  
  (* Jacobi formula: U/csL = c/csL - kh/h * Tr(adj(A)*dAdk) / Tr(adj(A)*dAdc) \
*)
  (* adjoint = classical adjugate = cofactor matrix transpose *)
  Module[{adjA = Inverse[AA] * Det[AA]},
    fact1 = Tr[adjA . Normal[dAdk]];
    fact2 = Tr[adjA . Normal[dAdc]];
  ];
  
  If[Abs[fact2] < 1.0*^-30,
    UocsL = cocsLVal,
    UocsL = cocsLVal - khRoot/h * Re[fact1/fact2]
  ];
  
  UocsL
];

\
\>", "Input",
 CellLabel->
  "In[205]:=",ExpressionUUID->"32859009-4e3e-df42-8d4f-e13fa9862c5b"],

Cell["\<\
(* ================================================================ *)\
\>", "Input",
 CellLabel->
  "In[220]:=",ExpressionUUID->"8e6c5a6e-98a7-e541-a68e-656296ebae03"],

Cell["\<\
(* 7. RETROGRADE / PROGRADE CLASSIFICATION                           *)
(*    Cross-product test with N=8 phases. +1 = retrograde,          *)
(*    -1 = prograde, 0 = indeterminate                               *)
(* ================================================================ *)

classifyMotion[u_, omega_] := Module[
  {nSamp = 8, iretro = 0, ur, u3, v3, w3},
  
  Do[
    ur = u*Exp[-2*I*Pi*j/nSamp];
    u3 = {Re[ur[[1]]], Re[ur[[2]]], 0};
    v3 = omega*{Im[ur[[1]]], Im[ur[[2]]], 0};
    w3 = Cross[u3, v3];
    If[Abs[w3[[3]]] < 1.0*^-4, w3[[3]] = 0];
    iretro += Sign[w3[[3]]],
    {j, 0, nSamp - 1}
  ];
  
  iretro/nSamp
];


(* ================================================================ *)\
\>", "Input",
 CellLabel->
  "In[221]:=",ExpressionUUID->"6749adf5-2af7-8340-b2a7-6e422115a68d"],

Cell["\<\
(* 8. ELLIPTICITY (H/V) via SVD                                     *)
(* ================================================================ *)

computeEllipticity[u_] := Module[
  {eMat, svdU, svdS, svals, absPdr, vh, ivh, idom, HoV, areaE},
  
  eMat = N[{{Re[u[[1]]], Re[u[[2]]]}, 
            {Im[u[[1]]], Im[u[[2]]]}}];
  
  {svdU, svdS} = Take[SingularValueDecomposition[eMat], 2];
  svals = Diagonal[svdS];
  
  absPdr = Abs[svdU];
  vh = Abs[Det[absPdr]];
  ivh = If[vh < 0.995, 0, 1];
  
  (* H/V via SVD ellipse decomposition \[AHat]\.80\.94 matches advisor MATLAB \
exactly.   *)
  (* SVD of 2x2 displacement matrix gives semi-axes of particle ellipse.  *)
  (* eps protection on denominator prevents Infinity without altering     *)
  (* the physical H/V ratio for all well-conditioned roots.               *)
  Module[{eps = 1.0*^-8},
    Which[
      svals[[2]] < eps,
        (* Degenerate: near-linear motion, one axis vanishes *)
        idom = -1; HoV = svals[[1]] / Max[svals[[2]], eps],
      svals[[2]]/svals[[1]] > 0.95,
        (* Near-circular: H and V nearly equal *)
        idom = 0; HoV = 1.0,
      Abs[svdU[[1, 1]]] > Abs[svdU[[2, 1]]],
        (* Horizontal-dominant ellipse *)
        idom = 1; HoV = svals[[1]] / Max[svals[[2]], eps],
      True,
        (* Vertical-dominant ellipse *)
        idom = 2; HoV = svals[[2]] / Max[svals[[1]], eps]
    ];
  ];
  
  areaE = Pi*svals[[1]]*svals[[2]];
  
  <|\"HoV\" -> HoV, \"ivh\" -> ivh, \"idom\" -> idom, \"areaE\" -> areaE|>
];

(* Ellipse inclination angle from complex displacements               *)
(*   \[Delta] = Arg(u_h) - Arg(u_v) = phase difference               *)
(*   When \[Delta] = \[Pi]/2: ellipse axes aligned with H/V (upright) *)
(*   When Re(u_h \[CenterDot] Conj(u_v)) \[NotEqual] 0: tilted       *)
(*   tan(2\[Theta]) = 2|u_h||u_v| cos(\[Delta]) / (|u_h|^2 - |u_v|^2) *)
computeEllipseInclination[uH_, uV_] := Module[
  {delta, cosD, absH, absV, numer, denom, theta},
  delta = Arg[uH] - Arg[uV];
  cosD = Cos[delta];
  absH = Abs[uH];
  absV = Abs[uV];
  numer = 2*absH*absV*cosD;
  denom = absH^2 - absV^2;
  theta = If[Abs[denom] > 1.0*^-15,
    0.5*ArcTan[numer/denom],
    If[Abs[numer] > 1.0*^-15, Pi/4*Sign[numer], 0.]];
  {delta, theta}
];

\
\>", "Input",
 CellLabel->
  "In[230]:=",ExpressionUUID->"6d7a5bdc-5b86-9d40-a385-bc5916b19fe7"],

Cell["\<\
(* ================================================================ *)\
\>", "Input",
 CellLabel->
  "In[243]:=",ExpressionUUID->"004a0d73-5987-e846-b4c5-04764584ae67"],

Cell["\<\
(* 9. FULL POST-PROCESSING AT ONE ROOT                               *)
(* ================================================================ *)

postProcess[kshRoot_, khRoot_] := Module[
  {cVal, cocsLVal, omega, T,
   A, uSVD, sSVD, vSVD, ephi, U0, u,
   UocsL, iretro, ellip, HoV},
  
  cVal     = csL * kshRoot / khRoot;
  cocsLVal = cVal / csL;
  omega    = cVal * khRoot / h;
  T        = If[Abs[omega] > 1.0*^-15, 2*Pi/omega, Infinity];
  
  (* No leaky mode filter for rigid halfspace: all modes are trapped *)
  
  A = buildA[cVal, khRoot];
  (* Match MATLAB: [Phi,Lambda] = eig(A); pick eigenvector for smallest \
|eigenvalue| *)
  Module[{evalues, evectors, idx},
    {evalues, evectors} = Eigensystem[N[A]];
    idx = First[Ordering[Abs[evalues], 1]];  (* index of smallest \
|eigenvalue| *)
    ephi = evectors[[idx]];
  ];
  
  U0 = buildU0[cVal, khRoot];
  u = U0 . ephi;
  
  UocsL = computeGroupVelocity[kshRoot, khRoot];
  iretro = classifyMotion[u, omega];
  ellip = computeEllipticity[u];
  HoV = ellip[\"HoV\"];
  
  (* ---- Surface displacement and particle velocity ----              *)
  (* u[[1]] = u_h = horizontal (x) displacement at free surface       *)
  (* u[[2]] = u_v = vertical   (z) displacement at free surface       *)
  (*                                                                    *)
  (* Particle velocity (for kinetic energy):                           *)
  (*   v = du/dt = -i omega u   (harmonic motion)                     *)
  (*   |v_h|^2 = omega^2 |u_h|^2                                     *)
  (*   |v_v|^2 = omega^2 |u_v|^2                                     *)
  (*                                                                    *)
  (* Kinetic energy density flux (computed SEPARATELY, summed):        *)
  (*   Ek_h = (1/2) rho |v_h|^2 U = (1/2) rho omega^2 |u_h|^2 U *)
  (*   Ek_v = (1/2) rho |v_v|^2 U = (1/2) rho omega^2 |u_v|^2 U *)
  (*   Ek_total = Ek_h + Ek_v                                          *)
  (*                                                                    *)
  (* Ellipse inclination:                                               *)
  (*   delta = Arg(u_h) - Arg(u_v)   (phase difference)               *)
  (*   theta = inclination angle of ellipse major axis from vertical  *)
  Module[{uHsq = Abs[u[[1]]]^2, uVsq = Abs[u[[2]]]^2,
          ellInc, delta, theta},
    ellInc = computeEllipseInclination[u[[1]], u[[2]]];
    delta = ellInc[[1]];
    theta = ellInc[[2]];
    <|\"ksh\" -> kshRoot, \"kh\" -> khRoot,
      \"cocsL\" -> cocsLVal, \"UocsL\" -> UocsL,
      \"Uoc\" -> If[Abs[cocsLVal] > 1.0*^-10, UocsL/cocsLVal, 0.],
      \"iretro\" -> iretro, \"HoV\" -> HoV, \"T\" -> T,
      \"omega\" -> omega, \"ivh\" -> ellip[\"ivh\"], 
      \"idom\" -> ellip[\"idom\"], \"areaE\" -> ellip[\"areaE\"],
      \"uHsq\" -> uHsq, \"uVsq\" -> uVsq,
      \"delta\" -> delta, \"theta\" -> theta|>
  ]
];
\
\>", "Input",
 CellLabel->
  "In[244]:=",ExpressionUUID->"1e4a16f3-01c7-3c49-ab28-bd7b78b35db8"],

Cell[CellGroupData[{

Cell["\<\
(* 10. ROOT-FINDING SWEEP WITH FULL POST-PROCESSING                 *)
(* ================================================================ *)

Print[\"Starting root-finding sweep with post-processing...\"];
tComp = AbsoluteTime[];

tolShear = 10^-4;
tolPress = 10^-4;
cocsLFilterMin = 0.5;
cocsLFilterMax = 30.0;  (* Extended to capture H/V right branch near \
resonance *)

count = 0;
progressStep = Max[1, Floor[ni*nj/10]];

{rawResults, {dispTag, shearTag, pressTag,
              retroTag, proTag, zeroTag, mixTag}} = Reap[
  Do[
    Module[{khI = khVec[[i]]},
      Do[
        Module[{kshJ0 = kshVec[[j]], sol, x, cocsLTest, cocpLTest, f, pp},
          count++;
          If[Mod[count, progressStep] == 0,
            Print[\"  Progress: \", Floor[100.0*count/(ni*nj)], \"%\"]
          ];
          
          sol = Quiet[
            Check[
              FindRoot[
                detEval[ksh, kh],
                {{ksh, kshJ0}, {kh, khI}},
                Method -> \"Newton\",
                WorkingPrecision -> MachinePrecision,
                AccuracyGoal -> 8, PrecisionGoal -> 8,
                MaxIterations -> 100
              ],
              $Failed,
              {FindRoot::cvmit, FindRoot::lstol, FindRoot::jsing}
            ],
            {FindRoot::cvmit, FindRoot::lstol, FindRoot::jsing,
             Power::infy, Infinity::indet}
          ];
          
          If[sol =!= $Failed && ListQ[sol] && FreeQ[sol, FindRoot | $Failed],
            x = {ksh, kh} /. sol;
            
            If[And[NumericQ[x[[1]]], NumericQ[x[[2]]],
                   Re[x[[1]]] > 0, Re[x[[2]]] > 0,
                   Abs[Im[x[[1]]]] < 10^-10, Abs[Im[x[[2]]]] < 10^-10],
              
              x = Re[x];
              f = detEval[x[[1]], x[[2]]];
              If[Sqrt[f[[1]]^2 + f[[2]]^2] > 10^-8, Continue[]];
              
              cocsLTest = x[[1]]/x[[2]];
              cocpLTest = csL*x[[1]]/(x[[2]]*cpL);
              
              If[cocsLTest < cocsLFilterMin || cocsLTest > cocsLFilterMax,
                Continue[]];
              
              (* Classify by wave type first *)
              Which[
                Abs[cocsLTest - 1] < tolShear,
                Sow[{x[[1]], x[[2]], cocsLTest}, \"shear\"],
                
                Abs[cocpLTest - 1] < tolPress,
                Sow[{x[[1]], x[[2]], cocsLTest}, \"press\"],
                
                True,
                (* Dispersive root: full post-processing *)
                pp = Quiet[postProcess[x[[1]], x[[2]]]];
                If[pp =!= $Failed && AssociationQ[pp],
                  Sow[{pp[\"ksh\"], pp[\"kh\"], pp[\"cocsL\"], pp[\"UocsL\"], 
                       pp[\"Uoc\"], pp[\"iretro\"], pp[\"HoV\"], pp[\"T\"],
                       pp[\"ivh\"], pp[\"idom\"], pp[\"areaE\"],
                       pp[\"uHsq\"], pp[\"uVsq\"]}, \"disp\"];
                  
                  Which[
                    pp[\"iretro\"] > 0.5,
                    Sow[{pp[\"ksh\"], pp[\"kh\"], pp[\"cocsL\"], pp[\"UocsL\"],
                         pp[\"HoV\"], pp[\"T\"], pp[\"uHsq\"], pp[\"uVsq\"]}, \
\"retro\"],
                    pp[\"iretro\"] < -0.5,
                    Sow[{pp[\"ksh\"], pp[\"kh\"], pp[\"cocsL\"], pp[\"UocsL\"],
                         pp[\"HoV\"], pp[\"T\"], pp[\"uHsq\"], pp[\"uVsq\"]}, \
\"pro\"],
                    pp[\"iretro\"] == 0,
                    Sow[{pp[\"ksh\"], pp[\"kh\"], pp[\"cocsL\"], pp[\"UocsL\"],
                         pp[\"HoV\"], pp[\"T\"], pp[\"uHsq\"], pp[\"uVsq\"]}, \
\"zero\"],
                    True,
                    Sow[{pp[\"ksh\"], pp[\"kh\"], pp[\"cocsL\"], pp[\"UocsL\"],
                         pp[\"HoV\"], pp[\"T\"], pp[\"uHsq\"], pp[\"uVsq\"],
                       pp[\"delta\"], pp[\"theta\"]}, \"mix\"]
                  ];
                ];
              ];
            ];
          ];
        ],
        {j, 1, nj}
      ];
    ],
    {i, 1, ni}
  ],
  {\"disp\", \"shear\", \"press\", \"retro\", \"pro\", \"zero\", \"mix\"}
];

(* Extract all result arrays \[Dash] semicolons suppress output *)
getData[tag_] := If[Length[tag] > 0, tag[[1]], {}];

dispData   = getData[dispTag];
shearData  = getData[shearTag];
pressData  = getData[pressTag];
retroData  = getData[retroTag];
proData    = getData[proTag];
zeroData   = getData[zeroTag];
mixData    = getData[mixTag];

(* Raw counts before dedup *)
nDisp  = Length[dispData];   nRetro = Length[retroData];
nPro   = Length[proData];    nShear = Length[shearData];
nPress = Length[pressData];  nZero  = Length[zeroData];
nMix   = Length[mixData];

Print[\"  Raw roots: Dispersive \", nDisp, 
      \" (Retro \", nRetro, \", Pro \", nPro, \")\"];
Print[\"  Body waves: Shear \", nShear, \", Pressure \", nPress];

(* Sort all arrays by (kh, ksh) for deterministic ordering.           *)
(* Without sorting, SVD eigenvector sign or ordering differences      *)
(* between sessions could cause borderline points to land in          *)
(* different classification bins, changing the visual output.          *)
sortByKhKsh[data_] := If[Length[data] > 0, SortBy[data, {#[[2]] &, #[[1]] \
&}], data];

(* Remove duplicate roots: many starting points converge to the same  *)
(* physical root. Round (ksh, kh) to 4 decimal places and keep only  *)
(* the first occurrence. Without this, plots show thousands of        *)
(* overlapping points that create visual scatter and hide the         *)
(* smooth dispersion curve structure.                                  *)
removeDuplicateRoots[data_] := If[Length[data] > 0,
  DeleteDuplicatesBy[data, {Round[#[[1]], 10^-4], Round[#[[2]], 10^-4]} &],
  data
];

Print[\"  Removing duplicate roots...\"];

nDispRaw  = nDisp;  nRetroRaw = nRetro;  nProRaw = nPro;

dispData  = removeDuplicateRoots[sortByKhKsh[dispData]];
shearData = removeDuplicateRoots[sortByKhKsh[shearData]];
pressData = removeDuplicateRoots[sortByKhKsh[pressData]];
retroData = removeDuplicateRoots[sortByKhKsh[retroData]];
proData   = removeDuplicateRoots[sortByKhKsh[proData]];
zeroData  = removeDuplicateRoots[sortByKhKsh[zeroData]];
mixData   = removeDuplicateRoots[sortByKhKsh[mixData]];

nDisp   = Length[dispData];
nShear  = Length[shearData];
nPress  = Length[pressData];
nRetro  = Length[retroData];
nPro    = Length[proData];
nZero   = Length[zeroData];
nMix    = Length[mixData];

Print[\"  Dedup: Dispersive \", nDispRaw, \" \[Rule] \", nDisp, 
      \" (removed \", nDispRaw - nDisp, \" duplicates)\"];
Print[\"         Retro \", nRetroRaw, \" \[Rule] \", nRetro, 
      \", Pro \", nProRaw, \" \[Rule] \", nPro];

tCompElapsed = AbsoluteTime[] - tComp;
Print[\"\\nRoot-finding completed in \", NumberForm[tCompElapsed/60, {4, 1}], \
\" minutes\"];
Print[\"  Dispersive: \", nDisp, \"  (Retro: \", nRetro, \"  Pro: \", nPro, 
      \"  Indeterminate: \", nZero, \"  Mixed: \", nMix, \")\"];
Print[\"  Shear wave: \", nShear, \"  Pressure wave: \", nPress];
Print[\"\"];

\
\>", "Input",
 CellLabel->
  "In[249]:=",ExpressionUUID->"625a0f23-c4a6-e849-a96a-a282942a8e88"],

