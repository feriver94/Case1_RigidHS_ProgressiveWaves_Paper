(*     Section 2:  Grid resolution (ni, nj) - higher = smoother    *)
(*     Section 13: Dimensional parameters (VsLDim, hDim)           *)
(*     Section 18: Parametric sweep values (nuStudy, csStudy, hStudy) *)
(*                                                                    *)
(*   WHAT YOU SHOULD NOT CHANGE:                                     *)
(*     Sections 3-11: Core algorithms (determinant, root-finding)   *)
(*     \[Mu]L = 1, \[Rho]L = 1, h = 1: Normalization constants  *)
(*                                                                    *)
(* ================================================================ *)

(* ::Package:: *)

(* ================================================================ *)
(*                                                                    *)
(*   Progressive Waves in Layered Elastic Media                      *)
(*   Elastic Layer on Rigid Halfspace (4x4)                  *)
